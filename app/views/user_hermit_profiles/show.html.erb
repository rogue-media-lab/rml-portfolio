<!-- User Hermit Profile — Show -->
<section class="w-full min-h-screen bg-hermit-lt-blue pt-20">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="font-teko text-5xl md:text-6xl font-bold text-hermit-burnt uppercase tracking-wide mb-8">Your Profile</h1>

    <div class="bg-white/50 backdrop-blur-sm rounded-xl p-6 md:p-8 shadow-lg border border-hermit-burnt/10">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 rounded-full bg-hermit-dk-green flex items-center justify-center">
          <span class="font-kanit text-white text-xl font-bold"><%= current_user.email.first(2).upcase %></span>
        </div>
        <div>
          <p class="font-kanit text-hermit-burnt text-lg font-bold"><%= current_user.email %></p>
          <p class="font-mPlusCode text-hermit-burnt/60 text-sm">Member since <%= current_user.created_at.strftime("%B %Y") %></p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-kanit text-hermit-burnt font-bold text-sm uppercase tracking-wider mb-2">Waitlist Status</h3>
          <span class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider
            <%= case @profile.waitlist_status
                when 'approved' then 'bg-green-100 text-green-700'
                when 'declined' then 'bg-red-100 text-red-700'
                else 'bg-yellow-100 text-yellow-700'
                end %>">
            <%= @profile.waitlist_status %>
          </span>
        </div>

        <div>
          <h3 class="font-kanit text-hermit-burnt font-bold text-sm uppercase tracking-wider mb-2">Favorite Hermit</h3>
          <% if @profile.favorite_hermit %>
            <div class="flex items-center gap-2">
              <% if @profile.favorite_hermit.face_url.present? %>
                <%= image_tag @profile.favorite_hermit.face_url, alt: @profile.favorite_hermit.alias, class: "w-8 h-8 rounded-full object-cover" %>
              <% end %>
              <span class="font-kanit text-hermit-burnt font-bold"><%= @profile.favorite_hermit.alias %></span>
            </div>
          <% else %>
            <p class="text-hermit-burnt/50 font-mPlusCode text-sm">Not set</p>
          <% end %>
        </div>

        <div>
          <h3 class="font-kanit text-hermit-burnt font-bold text-sm uppercase tracking-wider mb-2">Notifications</h3>
          <span class="font-mPlusCode text-hermit-burnt/80 text-sm"><%= @profile.notifications_enabled ? "Enabled" : "Disabled" %></span>
        </div>

        <div>
          <h3 class="font-kanit text-hermit-burnt font-bold text-sm uppercase tracking-wider mb-2">Total Favorites</h3>
          <span class="font-mPlusCode text-hermit-burnt/80 text-sm"><%= current_user.favorites.count %> episodes</span>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-hermit-burnt/10">
        <%= link_to edit_user_hermit_profile_path, class: "inline-flex items-center gap-2 bg-hermit-dk-green hover:bg-hermit-lt-green text-hermit-yellow font-bold py-3 px-6 rounded-md uppercase tracking-wider font-mPlusCode transition-colors shadow-md" do %>
          Edit Profile
        <% end %>
      </div>
    </div>
  </div>
</section>
