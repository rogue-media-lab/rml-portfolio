<!-- Home Page: App Entry Point -->
<section class="w-full min-h-screen bg-hermit-lt-blue">
  <!-- Banner Slider Section — React ImgSlider style -->
  <div class="relative w-full pt-20" data-controller="banner-slider" data-banner-slider-interval-value="5000">
    <div class="relative w-full overflow-hidden">
      <% @hermits.select { |h| h.banner_url.present? }.each_with_index do |hermit, index| %>
        <div data-banner-slider-target="slide" class="absolute inset-0 transition-opacity duration-700 ease-in-out <%= index == 0 ? 'opacity-100 z-10' : 'opacity-0 z-0' %>">
          <%= link_to hermit_profile_path(hermit), data: { turbo_frame: "_top" } do %>
            <%= image_tag hermit.banner_url, alt: "#{hermit.alias} banner", class: "w-full h-[250px] md:h-[350px] lg:h-[400px] object-contain shadow-2xl border-4 border-transparent hover:border-white/80 transition-all duration-500" %>
          <% end %>
        </div>
      <% end %>
      <%# Filler if no banners %>
      <% if @hermits.none? { |h| h.banner_url.present? } %>
        <div class="w-full h-[300px] bg-hermit-dk-green flex items-center justify-center">
          <h1 class="font-teko text-6xl font-bold text-hermit-yellow uppercase tracking-wide">Hermitcraft Season 8</h1>
        </div>
      <% end %>
      <!-- Spacer for absolute slides -->
      <div class="w-full h-[250px] md:h-[350px] lg:h-[400px]"></div>
    </div>

    <!-- Dots indicator -->
    <% banners = @hermits.select { |h| h.banner_url.present? } %>
    <% if banners.length > 1 %>
      <div class="flex justify-center gap-2 mt-4">
        <% banners.each_with_index do |_hermit, index| %>
          <button data-banner-slider-target="dot"
                  data-index="<%= index %>"
                  data-action="click->banner-slider#goTo"
                  class="w-2.5 h-2.5 rounded-full transition-colors duration-300 <%= index == 0 ? 'bg-white' : 'bg-white/50' %>">
          </button>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Crews / Specials Section — React Specials style -->
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h2 class="font-teko text-4xl md:text-5xl font-bold text-hermit-burnt uppercase tracking-wide mb-2">Specials from Season 8</h2>
    <p class="text-hermit-burnt/60 font-mPlusCode text-sm mb-8">The crews that defined this season</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% @crews.each do |crew| %>
        <%= render "shared/crew_card", crew: crew %>
      <% end %>
    </div>
  </div>

  <!-- First Episodes Grid — React Videos style (Netflix hover) -->
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h2 class="font-teko text-4xl md:text-5xl font-bold text-hermit-burnt uppercase tracking-wide mb-2">
      First Episode from Every Hermit
    </h2>
    <p class="text-hermit-burnt/60 font-mPlusCode text-sm mb-8">Season 8 — Where it all began</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
      <% @first_episodes.each do |video| %>
        <%= render "shared/video_card", video: video %>
      <% end %>
    </div>
  </div>

  <!-- Hermit Roster Preview -->
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="flex justify-between items-end mb-8">
      <div>
        <h2 class="font-teko text-4xl md:text-5xl font-bold text-hermit-burnt uppercase tracking-wide">Meet the Hermits</h2>
        <p class="text-hermit-burnt/60 font-mPlusCode text-sm mt-1"><%= @hermits.count %> hermits in Season 8</p>
      </div>
      <%= link_to hermit_roster_path, class: "bg-hermit-dk-green hover:bg-hermit-lt-green text-hermit-yellow font-bold py-2.5 px-6 rounded-md uppercase tracking-wider font-mPlusCode transition-colors shadow-md" do %>
        View All &rarr;
      <% end %>
    </div>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
      <% @hermits.limit(16).each do |hermit| %>
        <%= render "shared/hermit_face_card", hermit: hermit %>
      <% end %>
    </div>
  </div>
</section>
