<%= turbo_frame_tag "dashboard_content" do %>
  <%= render "shared/admin_breadcrumbs", breadcrumbs: [{ name: "Restaurants", path: milk_admin_restaurants_path }, { name: @restaurant.name, path: milk_admin_restaurant_path(@restaurant) }, { name: "Hours", path: milk_admin_restaurant_hours_path(@restaurant) }, { name: @hour.day_name }] %>

  <div class="mb-6">
    <h2 class="text-3xl font-bold text-gray-900">Edit Hours — <%= @hour.day_name %></h2>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= form_with model: [:milk_admin, @restaurant, @hour], class: "space-y-6" do |form| %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <%= form.label :open_time, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.time_field :open_time, class: "w-full rounded-lg border border-gray-300 px-4 py-2" %>
        </div>
        <div>
          <%= form.label :close_time, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.time_field :close_time, class: "w-full rounded-lg border border-gray-300 px-4 py-2" %>
        </div>
        <div class="flex items-center gap-2 pt-6">
          <%= form.check_box :closed, class: "rounded" %>
          <%= form.label :closed, "Closed", class: "text-sm font-medium text-gray-700" %>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <%= form.submit class: "px-6 py-3 bg-orange-600 hover:bg-orange-500 text-white rounded-lg font-medium transition-colors cursor-pointer" %>
        <%= link_to "Cancel", milk_admin_restaurant_hours_path(@restaurant), data: { turbo_frame: "dashboard_content" }, class: "text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  </div>
<% end %>
