<%= turbo_frame_tag "dashboard_content" do %>
  <%= render "shared/admin_breadcrumbs", breadcrumbs: [{ name: "Restaurants", path: milk_admin_restaurants_path }, { name: @restaurant.name, path: milk_admin_restaurant_path(@restaurant) }, { name: "Hours" }] %>

  <h2 class="text-3xl font-bold text-gray-900 mb-6">Hours — <%= @restaurant.name %></h2>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Day</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Open</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Close</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @hours.each do |hour| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= hour.day_name %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= hour.open_time&.strftime("%l:%M %p") %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= hour.close_time&.strftime("%l:%M %p") %></td>
              <td class="px-4 py-3">
                <% if hour.closed? %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-800">Closed</span>
                <% else %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">Open</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right">
                <%= link_to "Edit", edit_milk_admin_restaurant_hour_path(@restaurant, hour), data: { turbo_frame: "dashboard_content" }, class: "text-sky-600 hover:text-sky-900 text-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
