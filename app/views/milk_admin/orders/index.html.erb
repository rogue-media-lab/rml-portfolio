<%# Turbo Stream subscription — must be OUTSIDE the turbo_frame %>
<%= turbo_stream_from "restaurant_#{@restaurant.id}_orders" %>

<%= turbo_frame_tag "dashboard_content" do %>
  <%= render "shared/admin_breadcrumbs", breadcrumbs: [{ name: "Restaurants", path: milk_admin_restaurants_path }, { name: @restaurant.name, path: milk_admin_restaurant_path(@restaurant) }, { name: "Orders" }] %>

  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-4">
      <h2 class="text-3xl font-bold text-gray-900">Orders — <%= @restaurant.name %></h2>
      <% if @pending_count > 0 %>
        <span class="px-3 py-1 text-sm font-medium rounded-full bg-yellow-100 text-yellow-800"><%= @pending_count %> pending</span>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order #</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Phone</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Total</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Pickup</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Placed</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody id="orders_list" class="divide-y divide-gray-200">
          <% if @orders.any? %>
            <% @orders.each do |order| %>
              <%= render "milk_admin/orders/order_row", order: order, restaurant: @restaurant %>
            <% end %>
          <% else %>
            <tr id="no_orders_message">
              <td colspan="8" class="px-4 py-12 text-center">
                <div class="flex flex-col items-center">
                  <svg class="w-12 h-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                  </svg>
                  <p class="text-gray-500">No orders yet — they'll appear here in real-time when customers order.</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
