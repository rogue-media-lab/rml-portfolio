<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <%= link_to "← Back to Shops", milk_admin_carus_shops_path, data: { turbo_frame: "dashboard_content" }, class: "text-sm text-sky-600 hover:text-sky-800" %>
      <h1 class="text-2xl font-bold text-gray-900 mt-2"><%= @shop.name %></h1>
      <p class="text-sm text-gray-500"><%= @shop.slug %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_milk_admin_carus_shop_path(@shop), data: { turbo_frame: "dashboard_content" }, class: "px-4 py-2 bg-sky-700 hover:bg-sky-600 text-white rounded-lg transition-colors" %>
      <%= link_to "Open in CarUs", carus_root_path, target: "_blank", class: "px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors" %>
    </div>
  </div>

  <%# Stats %>
  <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
    <div class="bg-white shadow rounded-lg p-4">
      <dt class="text-sm text-gray-500">Customers</dt>
      <dd class="text-2xl font-semibold text-gray-900"><%= @shop.car_owners.count %></dd>
    </div>
    <div class="bg-white shadow rounded-lg p-4">
      <dt class="text-sm text-gray-500">Technicians</dt>
      <dd class="text-2xl font-semibold text-gray-900"><%= @shop.technicians.count %></dd>
    </div>
    <div class="bg-white shadow rounded-lg p-4">
      <dt class="text-sm text-gray-500">Services</dt>
      <dd class="text-2xl font-semibold text-gray-900"><%= @shop.services.count %></dd>
    </div>
    <div class="bg-white shadow rounded-lg p-4">
      <dt class="text-sm text-gray-500">Flash Alerts</dt>
      <dd class="text-2xl font-semibold text-gray-900"><%= @shop.flash_alerts.count %></dd>
    </div>
  </div>

  <%# Details %>
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Details</h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
      <div><dt class="text-gray-500">Address</dt><dd class="text-gray-900"><%= @shop.address %></dd></div>
      <div><dt class="text-gray-500">Phone</dt><dd class="text-gray-900"><%= @shop.phone %></dd></div>
      <div><dt class="text-gray-500">Email</dt><dd class="text-gray-900"><%= @shop.email %></dd></div>
      <div><dt class="text-gray-500">Website</dt><dd class="text-gray-900"><%= @shop.website %></dd></div>
      <div class="sm:col-span-2"><dt class="text-gray-500">Description</dt><dd class="text-gray-900"><%= @shop.description %></dd></div>
      <div><dt class="text-gray-500">Status</dt><dd>
        <% if @shop.active? %><span class="text-green-600 font-medium">Active</span><% else %><span class="text-red-600 font-medium">Inactive</span><% end %>
      </dd></div>
    </dl>
  </div>

  <%# Technicians %>
  <% if @technicians.any? %>
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Technicians</h2>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Joined</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @technicians.each do |tech| %>
            <tr>
              <td class="px-4 py-2 text-sm text-gray-900"><%= tech.email %></td>
              <td class="px-4 py-2 text-sm text-gray-500"><%= tech.created_at.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>