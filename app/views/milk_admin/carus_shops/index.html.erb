<%= turbo_frame_tag "dashboard_content" do %>
<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">CarUs Shops</h1>
      <p class="text-sm text-gray-500 mt-1"><%= @shops.count %> shops</p>
    </div>
    <%= link_to "New Shop", new_milk_admin_carus_shop_path, data: { turbo_frame: "dashboard_content" }, class: "px-4 py-2 bg-sky-700 hover:bg-sky-600 text-white rounded-lg transition-colors" %>
  </div>

  <% if @shops.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Address</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customers</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @shops.each do |shop| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="font-medium text-gray-900"><%= shop.name %></div>
                <div class="text-xs text-gray-500"><%= shop.slug %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= shop.address %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= shop.car_owners.count %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if shop.active? %>
                  <span class="px-2 py-1 text-xs font-medium bg-green-100 text-green-700 rounded-full">Active</span>
                <% else %>
                  <span class="px-2 py-1 text-xs font-medium bg-gray-100 text-gray-700 rounded-full">Inactive</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= link_to "View", milk_admin_carus_shop_path(shop), data: { turbo_frame: "dashboard_content" }, class: "text-sky-600 hover:text-sky-800 font-medium" %>
                <%= link_to "Edit", edit_milk_admin_carus_shop_path(shop), data: { turbo_frame: "dashboard_content" }, class: "ml-3 text-gray-600 hover:text-gray-800 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-12 text-center">
      <p class="text-gray-500">No shops yet. Create your first one!</p>
    </div>
  <% end %>
</div>
<% end %>