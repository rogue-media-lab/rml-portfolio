<%= turbo_frame_tag "dashboard_content" do %>
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-3xl">Hermit Crews</h1>
    <%= link_to "New Crew", new_milk_admin_hermit_crew_path, data: { turbo_frame: "dashboard_content" }, class: "btn btn-primary" %>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full bg-white">
      <thead class="bg-gray-800 text-white">
        <tr>
          <th class="py-3 px-4 uppercase font-semibold text-sm">Name</th>
          <th class="py-3 px-4 uppercase font-semibold text-sm">Season</th>
          <th class="py-3 px-4 uppercase font-semibold text-sm">Members</th>
          <th class="py-3 px-4 uppercase font-semibold text-sm">Slug</th>
          <th class="text-left py-3 px-4 uppercase font-semibold text-sm">Actions</th>
        </tr>
      </thead>
      <tbody class="text-gray-700">
        <% @hermit_crews.each do |crew| %>
          <tr>
            <td class="py-3 px-4"><%= crew.name %></td>
            <td class="py-3 px-4"><%= crew.season %></td>
            <td class="py-3 px-4"><%= crew.hermits.count %></td>
            <td class="py-3 px-4"><%= crew.slug %></td>
            <td class="text-left py-3 px-4">
              <%= link_to "Edit", edit_milk_admin_hermit_crew_path(crew), data: { turbo_frame: "dashboard_content" }, class: "text-blue-500 hover:text-blue-700" %>
              <%= link_to "Delete", milk_admin_hermit_crew_path(crew), data: { "turbo-method": :delete, "turbo-confirm": "Are you sure?" }, class: "text-red-500 hover:text-red-700 ml-4" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
