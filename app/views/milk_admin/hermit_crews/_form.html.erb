<%= form_with(model: [:milk_admin, @hermit_crew], local: true, class: "space-y-4") do |form| %>
  <% if @hermit_crew.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <h2 class="font-bold"><%= pluralize(@hermit_crew.errors.count, "error") %> prohibited this crew from being saved:</h2>
      <ul class="list-disc ml-5">
        <% @hermit_crew.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-bold mb-1" %>
    <%= form.text_field :name, class: "w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= form.label :slug, class: "block text-sm font-bold mb-1" %>
    <%= form.text_field :slug, class: "w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-bold mb-1" %>
    <%= form.text_area :description, rows: 3, class: "w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= form.label :image_url, "Image URL", class: "block text-sm font-bold mb-1" %>
    <%= form.text_field :image_url, class: "w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= form.label :season, class: "block text-sm font-bold mb-1" %>
    <%= form.number_field :season, class: "w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <label class="block text-sm font-bold mb-2">Members</label>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-2 max-h-48 overflow-y-auto border rounded p-3">
      <% @hermits.each do |hermit| %>
        <label class="flex items-center gap-2 cursor-pointer">
          <%= check_box_tag "hermit_crew[hermit_ids][]", hermit.id, @hermit_crew.hermit_ids.include?(hermit.id), class: "rounded" %>
          <span class="text-sm"><%= hermit.alias %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex gap-2 pt-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", milk_admin_hermit_crews_dashboard_path, data: { turbo_frame: "dashboard_content" }, class: "btn btn-secondary" %>
  </div>
<% end %>
