<%= turbo_frame_tag "dashboard_content" do %>
  <%= render "shared/admin_breadcrumbs", breadcrumbs: [{ name: "Restaurants", path: milk_admin_restaurants_path }, { name: @restaurant.name, path: milk_admin_restaurant_path(@restaurant) }, { name: "Menu Items" }] %>

  <div class="flex items-center justify-between mb-6">
    <h2 class="text-3xl font-bold text-gray-900">Menu Items — <%= @restaurant.name %></h2>
    <%= link_to new_milk_admin_restaurant_menu_item_path(@restaurant), data: { turbo_frame: "dashboard_content" }, class: "inline-flex items-center gap-2 px-5 py-3 bg-orange-600 hover:bg-orange-500 text-white rounded-lg font-medium transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
      New Item
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Featured</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @menu_items.each do |item| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= item.name %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= item.menu_category.name %></td>
              <td class="px-4 py-3 text-sm text-gray-900">$<%= '%.2f' % item.price %></td>
              <td class="px-4 py-3">
                <% if item.featured? %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800">★ Featured</span>
                <% end %>
              </td>
              <td class="px-4 py-3">
                <% if item.active? %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">Active</span>
                <% else %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-800">Inactive</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to "Edit", edit_milk_admin_restaurant_menu_item_path(@restaurant, item), data: { turbo_frame: "dashboard_content" }, class: "text-sky-600 hover:text-sky-900 text-sm" %>
                  <%= button_to "Delete", milk_admin_restaurant_menu_item_path(@restaurant, item), method: :delete, data: { turbo_confirm: "Delete this item?" }, class: "text-red-600 hover:text-red-900 text-sm" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
