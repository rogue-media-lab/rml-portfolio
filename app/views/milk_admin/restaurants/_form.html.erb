<%= turbo_frame_tag "dashboard_content" do %>
  <%= render "shared/admin_breadcrumbs", breadcrumbs: [{ name: "Restaurants", path: milk_admin_restaurants_path }, { name: @restaurant.persisted? ? @restaurant.name : "New Restaurant" }] %>

  <div class="mb-6">
    <h2 class="text-3xl font-bold text-gray-900"><%= @restaurant.persisted? ? "Edit Restaurant" : "New Restaurant" %></h2>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= form_with model: [:milk_admin, @restaurant], class: "space-y-6" do |form| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :name, class: "w-full rounded-lg border border-gray-300 px-4 py-2" %>
        </div>
        <div>
          <%= form.label :slug, "URL Slug", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :slug, class: "w-full rounded-lg border border-gray-300 px-4 py-2", placeholder: "my-restaurant" %>
        </div>
      </div>

      <div>
        <%= form.label :tagline, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :tagline, class: "w-full rounded-lg border border-gray-300 px-4 py-2" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <%= form.label :address, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :address, class: "w-full rounded-lg border border-gray-300 px-4 py-2" %>
        </div>
        <div>
          <%= form.label :phone, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :phone, class: "w-full rounded-lg border border-gray-300 px-4 py-2" %>
        </div>
        <div>
          <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :email, class: "w-full rounded-lg border border-gray-300 px-4 py-2" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <%= form.label :primary_color, "Primary Color", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.color_field :primary_color, class: "w-full rounded-lg border border-gray-300 px-4 py-2 h-10" %>
        </div>
        <div>
          <%= form.label :accent_color, "Accent Color", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.color_field :accent_color, class: "w-full rounded-lg border border-gray-300 px-4 py-2 h-10" %>
        </div>
        <div>
          <%= form.label :dark_color, "Dark Color", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.color_field :dark_color, class: "w-full rounded-lg border border-gray-300 px-4 py-2 h-10" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :font_display, "Display Font", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :font_display, class: "w-full rounded-lg border border-gray-300 px-4 py-2" %>
        </div>
        <div>
          <%= form.label :font_body, "Body Font", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :font_body, class: "w-full rounded-lg border border-gray-300 px-4 py-2" %>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <%= form.submit class: "px-6 py-3 bg-orange-600 hover:bg-orange-500 text-white rounded-lg font-medium transition-colors cursor-pointer" %>
        <%= link_to "Cancel", milk_admin_restaurants_path, data: { turbo_frame: "dashboard_content" }, class: "text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  </div>
<% end %>
