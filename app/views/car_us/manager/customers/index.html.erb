<div class="space-y-6">
  <div class="bg-white shadow rounded-lg p-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-4">Customer Lookup</h1>

    <%= form_with url: search_manager_customers_path, method: :get, class: "flex gap-3" do |f| %>
      <div class="flex-1">
        <%= f.text_field :email,
            placeholder: "Enter email address",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg",
            autofocus: true %>
      </div>
      <%= f.submit "Search", class: "px-8 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors" %>
    <% end %>
  </div>

  <% if params[:customer_id].present? %>
    <% customer = CarOwner.find_by(id: params[:customer_id]) %>
    <% if customer %>
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-5 bg-blue-600 text-white rounded-t-lg flex justify-between items-center">
          <div>
            <h2 class="text-2xl font-bold"><%= customer.email %></h2>
            <p class="text-blue-100 mt-1">Customer</p>
          </div>
        </div>

        <div class="px-6 py-6">
          <div class="grid grid-cols-2 gap-6">
            <div>
              <h3 class="text-sm font-medium text-gray-500 mb-2">Account Information</h3>
              <div class="space-y-2 text-sm">
                <p><strong>Email:</strong> <%= customer.email %></p>
                <p><strong>Member Since:</strong> <%= customer.created_at.strftime("%B %d, %Y") %></p>
              </div>
            </div>

            <div>
              <h3 class="text-sm font-medium text-gray-500 mb-2">Status</h3>
              <div class="space-y-2 text-sm">
                <p><strong>Shop:</strong> <%= customer.shop&.name || "None" %></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-5 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">All Customers (<%= @customers.count %>)</h2>
    </div>

    <div class="overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Shop</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @customers.each do |customer| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900"><%= customer.email %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-500"><%= customer.shop&.name %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-500"><%= customer.created_at.strftime("%b %d, %Y") %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= link_to "View", manager_customers_path(customer_id: customer.id), class: "font-medium text-blue-600 hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>