<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to manager_root_path, class: "text-sm font-medium text-blue-600 hover:underline" do %>
      &larr; Back to Dashboard
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-5 border-b border-gray-200">
      <h1 class="text-2xl font-bold text-gray-900">Send Flash Sale</h1>
      <p class="mt-1 text-sm text-gray-500">Fill idle bays by alerting your <%= current_shop.car_owners.count %> customers instantly</p>
    </div>

    <div class="px-6 py-6">
      <%= form_with model: @flash_alert, url: manager_flash_alerts_path, local: true, class: "space-y-6" do |f| %>
        <% if @flash_alert.errors.any? %>
          <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded">
            <h3 class="font-medium">Please fix the following errors:</h3>
            <ul class="list-disc list-inside mt-2">
              <% @flash_alert.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :title, "Flash Sale Title", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.text_field :title,
              placeholder: "e.g., 50% Off Oil Change",
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg",
              autofocus: true,
              data: { action: "input->flash-alert#updatePreview" } %>
          <p class="mt-1 text-sm text-gray-500">Keep it short and compelling</p>
        </div>

        <div>
          <%= f.label :description, "Message (Optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.text_area :description,
              placeholder: "Limited time offer - next 2 hours only!",
              rows: 3,
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <%= f.label :discount_percentage, "Discount Percentage", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="relative">
            <%= f.number_field :discount_percentage,
                min: 1, max: 100, step: 1, value: 50,
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg font-semibold" %>
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 text-lg">%</span>
          </div>
          <div class="mt-2 flex gap-2">
            <% [25, 30, 50, 75].each do |pct| %>
              <button type="button" onclick="this.form.querySelector('#car_us_flash_alert_discount_percentage').value=<%= pct %>" class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50"><%= pct %>%</button>
            <% end %>
          </div>
        </div>

        <div>
          <%= f.label :duration_hours, "Sale Duration", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.number_field :duration_hours,
              min: 1, max: 24, step: 1, value: 2,
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg font-semibold" %>
          <div class="mt-2 flex gap-2">
            <% [2, 4, 8, 24].each do |hrs| %>
              <button type="button" onclick="this.form.querySelector('#car_us_flash_alert_duration_hours').value=<%= hrs %>" class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50"><%= hrs %> hours</button>
            <% end %>
          </div>
        </div>

        <div class="bg-gray-50 border-2 border-gray-200 rounded-lg p-4">
          <h3 class="text-sm font-medium text-gray-700 mb-2">Preview</h3>
          <div class="bg-white rounded-lg p-4 shadow">
            <div class="flex items-start">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path>
                </svg>
              </div>
              <div class="ml-3 flex-1">
                <p class="text-sm font-medium text-gray-900" id="preview-title">Flash Sale Alert!</p>
                <p class="text-sm text-gray-500 mt-1" id="preview-description">Tap to view offer</p>
              </div>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between pt-4">
          <%= link_to "Cancel", manager_root_path, class: "text-gray-600 hover:text-gray-900 font-medium" %>
          <%= f.submit "Send Flash Sale to #{current_shop.car_owners.count} Customers",
              class: "px-8 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors cursor-pointer",
              data: { confirm: "Send this Flash Sale to #{current_shop.car_owners.count} customers?" } %>
        </div>
      <% end %>
    </div>
  </div>
</div>