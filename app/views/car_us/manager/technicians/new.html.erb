<div class="max-w-md">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Add Technician</h1>

  <%= form_with model: [:manager, @technician], class: "space-y-4" do |f| %>
    <% if @technician.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded text-sm">
        <p class="font-medium">Please fix <%= pluralize(@technician.errors.count, "error") %>:</p>
        <ul class="list-disc list-inside mt-1">
          <% @technician.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-white shadow rounded-lg p-6 space-y-4">
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm", required: true %>
      </div>
      <div>
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm", required: true %>
      </div>
      <div>
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm", required: true %>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Create Technician", class: "px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg cursor-pointer" %>
      <%= link_to "Cancel", manager_technicians_path, class: "px-4 py-2.5 text-gray-600 hover:text-gray-800 text-sm" %>
    </div>
  <% end %>
</div>