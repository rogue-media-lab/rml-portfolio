<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to manager_technicians_path, class: "text-sm text-gray-500 hover:text-gray-700" do %>
      ← Back to Technicians
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-1"><%= @technician.email %></h1>
  <p class="text-sm text-gray-500 mb-8">Per-Technician Targets</p>

  <%= form_with model: @technician, url: manager_technician_path(@technician), method: :patch,
        local: true, data: { turbo: false }, class: "space-y-6" do |f| %>

    <%# Weekly Hours Target %>
    <div class="bg-white rounded-lg border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Weekly Hours Target</h2>

      <div class="space-y-4">
        <div>
          <%= f.label :target_hours, "Manager Minimum (floor)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="flex items-center gap-2">
            <%= f.number_field :target_hours, step: 0.5, min: 0, max: 100,
                  class: "w-24 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
            <span class="text-sm text-gray-500">hours/week</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">The minimum the manager expects. Sets the floor for reports.</p>
        </div>

        <div class="border-t border-gray-100 pt-4">
          <%= f.label :preferred_hours, "Tech's Own Target", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="flex items-center gap-2">
            <%= f.number_field :preferred_hours, value: @technician.preferred_hours || 40,
                  step: 0.5, min: 0, max: 100,
                  class: "w-24 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
            <span class="text-sm text-gray-500">hours/week</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">The tech's personal ambition target. Displayed on their weekly report.</p>
        </div>
      </div>
    </div>

    <%# Target Services %>
    <div class="bg-white rounded-lg border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Target Services</h2>
      <p class="text-sm text-gray-500 mb-4">Select the services this tech should aim to complete each week.</p>

      <% if @shop_services.any? %>
        <div class="space-y-2">
          <% @shop_services.each do |svc| %>
            <label class="flex items-center gap-3 py-1 cursor-pointer">
              <%= check_box_tag "technician[target_service_ids][]", svc.id,
                    @technician.target_service_ids&.include?(svc.id),
                    class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
              <span class="text-sm text-gray-700"><%= svc.name %></span>
              <% if svc.duration_minutes %>
                <span class="text-xs text-gray-400"><%= svc.duration_minutes %> min</span>
              <% end %>
            </label>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-6">
          <p class="text-sm text-gray-500 mb-3">No services configured yet.</p>
          <%= link_to "Add Services", manager_services_path, class: "text-sm text-blue-600 hover:text-blue-800 font-medium" %>
        </div>
      <% end %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Save Targets", class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg cursor-pointer transition-colors" %>
      <%= link_to "Cancel", manager_technicians_path, class: "text-sm text-gray-500 hover:text-gray-700 px-5 py-2.5" %>
    </div>
  <% end %>
</div>