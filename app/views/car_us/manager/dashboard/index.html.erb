<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Manager Dashboard</h1>
      <p class="mt-1 text-sm text-gray-500"><%= current_shop.name %></p>
    </div>
    <%= link_to "Send Flash Sale", new_manager_flash_alert_path, class: "inline-flex items-center px-6 py-3 bg-blue-600 border border-transparent text-base font-medium rounded-md text-white hover:bg-blue-700 transition-colors" %>
  </div>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-4">
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <dt class="text-sm font-medium text-gray-500 truncate">Weekly Hours</dt>
        <dd class="mt-1 text-3xl font-semibold text-green-600"><%= @weekly_hours.round(1) %></dd>
        <dd class="mt-1 text-xs text-gray-400"><%= @week_start.strftime("%b %d") %> – <%= @week_end.strftime("%b %d") %></dd>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <dt class="text-sm font-medium text-gray-500 truncate">Jobs This Week</dt>
        <dd class="mt-1 text-3xl font-semibold text-gray-900"><%= @weekly_job_count %></dd>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <dt class="text-sm font-medium text-gray-500 truncate">Total Customers</dt>
        <dd class="mt-1 text-3xl font-semibold text-gray-900"><%= @total_customers %></dd>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <dt class="text-sm font-medium text-gray-500 truncate">Active Flash Sales</dt>
        <dd class="mt-1 text-3xl font-semibold text-blue-600"><%= @active_flash_alerts %></dd>
      </div>
    </div>
  </div>

  <div class="flex gap-3">
    <%= link_to manager_shop_report_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-blue-700 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100" do %>
      Shop Report →
    <% end %>
    <%= link_to manager_tech_leaderboard_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-blue-700 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100" do %>
      Tech Leaderboard →
    <% end %>
  </div>

  <% if @unnotified_count > 0 %>
    <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3">
      <p class="text-sm text-green-800">
        <span class="font-bold"><%= pluralize(@unnotified_count, "new booking") %></span> since your last visit.
      </p>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h2 class="text-lg font-medium text-gray-900 mb-4">Recent Flash Sales</h2>
      <% if @recent_flash_alerts.any? %>
        <div class="space-y-4">
          <% @recent_flash_alerts.each do |alert| %>
            <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg <%= alert.expired? ? 'bg-gray-50' : 'bg-green-50' %>">
              <div class="flex-1">
                <h3 class="text-sm font-medium text-gray-900"><%= alert.title %></h3>
                <p class="text-sm text-gray-500 mt-1"><%= alert.description %></p>
                <div class="mt-2 flex items-center space-x-4 text-xs text-gray-500">
                  <span><%= alert.discount_percentage %>% off</span>
                  <span>-</span>
                  <span><%= alert.redemptions.count %> redemptions</span>
                  <span>-</span>
                  <span><%= alert.expired? ? "Expired" : "Active" %></span>
                </div>
              </div>
              <div class="ml-4">
                <%= link_to "View", manager_flash_alert_path(alert), class: "text-sm font-medium text-blue-600 hover:underline" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-8">No Flash Sales yet. Create your first one!</p>
      <% end %>
      <div class="mt-4 text-center">
        <%= link_to "View All Flash Sales", manager_flash_alerts_path, class: "text-sm font-medium text-blue-600 hover:underline" %>
      </div>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h2 class="text-lg font-medium text-gray-900 mb-4">Upcoming Appointments</h2>
      <% if @upcoming_bookings.any? %>
        <div class="space-y-3">
          <% @upcoming_bookings.each do |booking| %>
            <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg bg-blue-50">
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <h3 class="text-sm font-semibold text-gray-900">
                    <%= booking.vehicle.car_owner.first_name %> <%= booking.vehicle.car_owner.last_name %>
                  </h3>
                  <span class="text-xs text-gray-500">·</span>
                  <span class="text-sm text-gray-700"><%= booking.vehicle.year %> <%= booking.vehicle.make %> <%= booking.vehicle.model %></span>
                </div>
                <p class="text-sm text-gray-600 mt-1">
                  <span class="font-medium">Services:</span> <%= booking.service_types %>
                </p>
                <div class="mt-1.5 flex items-center gap-3 text-xs text-gray-500">
                  <span><%= booking.preferred_date&.strftime("%B %-d, %Y") %> at <%= booking.preferred_time %></span>
                  <% if booking.notes.present? %>
                    <span class="text-gray-400">Note: <%= booking.notes.truncate(40) %></span>
                  <% end %>
                </div>
              </div>
              <div class="ml-4 flex-shrink-0 flex items-center gap-2">
                <%= link_to "Edit", edit_manager_booking_path(booking), class: "text-xs font-medium text-blue-600 hover:text-blue-800" %>
                <% if booking.technician %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <%= booking.technician.display_name %>
                  </span>
                <% else %>
                  <%= form_with model: booking, url: manager_booking_path(booking), method: :patch, local: true, data: { turbo: false } do |f| %>
                    <div class="flex items-center gap-1.5">
                      <%= select_tag :technician_id, options_from_collection_for_select(@technicians, :id, :display_name), prompt: "Assign…", class: "text-xs rounded-md border-gray-300 py-1 px-1.5 focus:ring-blue-500 focus:border-blue-500" %>
                      <%= f.submit "→", class: "text-xs px-2 py-1 bg-blue-600 text-white rounded-md hover:bg-blue-700 cursor-pointer" %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-8">No upcoming appointments.</p>
      <% end %>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h2 class="text-lg font-medium text-gray-900 mb-4">Quick Actions</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <%= link_to manager_customers_path, class: "flex items-center p-4 border-2 border-gray-200 rounded-lg hover:border-blue-500 transition-colors" do %>
          <svg class="h-8 w-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <div class="ml-4">
            <h3 class="text-sm font-medium text-gray-900">Customer Lookup</h3>
            <p class="text-sm text-gray-500">Search by email or name</p>
          </div>
        <% end %>

        <%= link_to new_manager_flash_alert_path, class: "flex items-center p-4 border-2 border-gray-200 rounded-lg hover:border-blue-500 transition-colors" do %>
          <svg class="h-8 w-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <div class="ml-4">
            <h3 class="text-sm font-medium text-gray-900">Send Flash Sale</h3>
            <p class="text-sm text-gray-500">Fill idle bays now</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>