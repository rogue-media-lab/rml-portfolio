<% content_for(:title, "Edit Booking — #{@booking.vehicle.car_owner.first_name} #{@booking.vehicle.car_owner.last_name}") %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to manager_root_path, class: "text-sm text-gray-500 hover:text-gray-700" do %>
      ← Back to Dashboard
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-1">Edit Booking</h1>
  <p class="text-sm text-gray-500 mb-6">
    <%= @booking.vehicle.car_owner.first_name %> <%= @booking.vehicle.car_owner.last_name %> ·
    <%= @booking.vehicle.year %> <%= @booking.vehicle.make %> <%= @booking.vehicle.model %>
  </p>

  <%= form_with model: @booking, url: manager_booking_path(@booking), method: :patch, local: true, data: { turbo: false }, class: "space-y-5" do |f| %>
    <% if @booking.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm">
        <%= @booking.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <%# Services %>
    <div>
      <%= f.label :service_types, "Services", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :service_types, value: @booking.service_types,
            class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
      <p class="text-xs text-gray-400 mt-1">Comma-separated: Oil Change, Brake Pads, etc.</p>
    </div>

    <%# Date & Time %>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :preferred_date, "Date", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :preferred_date, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
      </div>
      <div>
        <%= f.label :preferred_time, "Time", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :preferred_time, options_for_select([
          ["8:00 AM", "8:00 AM"], ["10:00 AM", "10:00 AM"],
          ["1:00 PM", "1:00 PM"], ["3:00 PM", "3:00 PM"]
        ], @booking.preferred_time), {}, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
      </div>
    </div>

    <%# Notes %>
    <div>
      <%= f.label :notes, "Notes", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :notes, rows: 3, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
    </div>

    <%# Assign Technician %>
    <div>
      <%= f.label :technician_id, "Assign To", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :technician_id, @technicians, :id, :display_name,
            { include_blank: "Unassigned" },
            class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
    </div>

    <%# Status %>
    <div class="flex items-center gap-3 pt-2">
      <span class="text-sm text-gray-500">Status:</span>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 capitalize"><%= @booking.status %></span>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit "Save Changes", class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg cursor-pointer transition-colors" %>
      <%= link_to "Cancel", manager_root_path, class: "text-sm text-gray-500 hover:text-gray-700 px-5 py-2.5" %>
    </div>
  <% end %>
</div>
