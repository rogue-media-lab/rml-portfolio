<div class="max-w-3xl mx-auto space-y-6">
  <%# Back link %>
  <div class="mb-6">
    <%= link_to manager_root_path, class: "text-sm text-gray-500 hover:text-gray-700" do %>
      ← Back to Dashboard
    <% end %>
  </div>

  <%# Header %>
  <div class="flex justify-between items-start">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Tech Leaderboard</h1>
      <p class="text-sm text-gray-500 mt-1">
        <%= current_shop.name %> ·
        <%= @week_start.strftime("%b %-d") %> – <%= @week_end.strftime("%b %-d, %Y") %>
      </p>
    </div>
    <%= link_to "Shop Report", manager_shop_report_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 border border-transparent text-sm font-medium rounded-md text-white hover:bg-blue-700 transition-colors" %>
  </div>

  <%# Tech cards %>
  <% if @tech_stats.any? %>
    <div class="space-y-4">
      <% @tech_stats.each do |stat| %>
        <% tech = stat[:technician] %>
        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
          <%# Card header — tech name and role %>
          <div class="px-6 py-4 flex items-center justify-between border-b border-gray-100">
            <div class="flex items-center gap-3">
              <h2 class="text-lg font-semibold text-gray-900"><%= tech.display_name %></h2>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                <%= tech.role.to_s.titleize %>
              </span>
            </div>

            <%# Status badge %>
            <% case stat[:status]
               when "killing_it" %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-green-100 text-green-800">
                🔥 Killing It
              </span>
            <% when "on_track" %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-yellow-100 text-yellow-800">
                On Track
              </span>
            <% when "behind" %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-red-100 text-red-800">
                Behind
              </span>
            <% end %>
          </div>

          <%# Card body — progress and services %>
          <div class="px-6 py-4 space-y-4">
            <%# Progress bar %>
            <div>
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-gray-600">
                  <%= stat[:pct] %>% of target
                </span>
                <span class="text-gray-500">
                  <%= stat[:total_hours].round(1) %> / <%= stat[:target_hours].round(1) %> hrs
                </span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-3 overflow-hidden">
                <% bar_color = case stat[:status]
                               when "killing_it" then "bg-green-500"
                               when "on_track" then "bg-yellow-500"
                               else "bg-red-500"
                               end %>
                <div class="<%= bar_color %> h-3 rounded-full transition-all duration-300"
                     style="width: <%= stat[:pct].clamp(0, 100) %>%"></div>
              </div>
            </div>

            <%# Stats row — jobs and hours to go %>
            <div class="flex gap-6 text-sm">
              <div>
                <span class="text-gray-500">Jobs:</span>
                <span class="font-semibold text-gray-900 ml-1"><%= stat[:total_jobs] %></span>
              </div>
              <% hours_to_go = [(stat[:target_hours] - stat[:total_hours]).round(1), 0].max %>
              <div>
                <span class="text-gray-500">Hours to go:</span>
                <span class="font-semibold text-gray-900 ml-1"><%= hours_to_go %></span>
              </div>
            </div>

            <%# Service checklist — only show if services exist %>
            <% if stat[:services].any? %>
              <div class="border-t border-gray-100 pt-3">
                <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Target Services</p>
                <div class="flex flex-wrap gap-2">
                  <% stat[:services].each do |svc| %>
                    <% if svc[:done] %>
                      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">
                        <span>✓</span>
                        <%= svc[:name] %>
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-gray-50 text-gray-500 border border-gray-200">
                        <span>○</span>
                        <%= svc[:name] %>
                      </span>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border border-gray-200 p-12 text-center">
      <p class="text-gray-500">No technician data for this week.</p>
    </div>
  <% end %>
</div>