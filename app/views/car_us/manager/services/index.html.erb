<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Services</h1>
      <p class="text-sm text-gray-500"><%= @services.count %> services for <%= current_shop.name %></p>
    </div>
    <%= link_to "Add Service", new_manager_service_path, class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors" %>
  </div>

  <% if @services.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Duration</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @services.each do |service| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4">
                <div class="font-medium text-gray-900"><%= service.name %></div>
                <div class="text-xs text-gray-500"><%= truncate(service.description, length: 60) %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm"><%= number_to_currency(service.price) if service.price %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm"><%= "#{service.duration_minutes} min" if service.duration_minutes %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if service.active? %>
                  <span class="px-2 py-1 text-xs font-medium bg-green-100 text-green-700 rounded-full">Active</span>
                <% else %>
                  <span class="px-2 py-1 text-xs font-medium bg-gray-100 text-gray-700 rounded-full">Inactive</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm space-x-3">
                <%= link_to "Edit", edit_manager_service_path(service), class: "text-blue-600 hover:text-blue-800 font-medium" %>
                <%= link_to "Delete", manager_service_path(service), data: { turbo_method: :delete, turbo_confirm: "Remove this service?" }, class: "text-red-600 hover:text-red-800 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-12 text-center">
      <p class="text-gray-500">No services yet. Add your first one!</p>
    </div>
  <% end %>
</div>