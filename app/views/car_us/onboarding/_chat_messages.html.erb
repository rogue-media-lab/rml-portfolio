<%# Chat messages partial — used for both full page load and Turbo Stream updates %>
<div class="flex-1 flex flex-col gap-4 pb-4">
  <%# Conversation history %>
  <% messages.each do |msg| %>
    <% if msg[:role] == "assistant" %>
      <%# AI message — left aligned %>
      <div class="flex gap-3 max-w-[85%]">
        <div class="w-8 h-8 rounded-full bg-carus-green/10 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-carus-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"></path>
          </svg>
        </div>
        <div class="bg-carus-panel border border-white/5 rounded-2xl rounded-tl-sm px-4 py-3">
          <p class="text-sm text-white/80 leading-relaxed"><%= msg[:content] %></p>
        </div>
      </div>
    <% else %>
      <%# Owner message — right aligned %>
      <div class="flex justify-end">
        <div class="max-w-[80%] bg-carus-green/10 border border-carus-green/20 rounded-2xl rounded-tr-sm px-4 py-3">
          <p class="text-sm text-white/80 leading-relaxed"><%= msg[:content] %></p>
        </div>
      </div>
    <% end %>
  <% end %>

  <%# Current question from the system %>
  <% if next_question.present? %>
    <div class="flex gap-3 max-w-[85%]">
      <div class="w-8 h-8 rounded-full bg-carus-green/10 flex items-center justify-center shrink-0 mt-0.5">
        <svg class="w-4 h-4 text-carus-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"></path>
        </svg>
      </div>
      <div class="bg-carus-panel border border-white/5 rounded-2xl rounded-tl-sm px-4 py-3">
        <p class="text-sm text-white/80 leading-relaxed"><%= next_question %></p>
      </div>
    </div>

    <%# Input bar %>
    <div class="mt-auto pt-4">
      <%= form_with url: onboarding_chat_path, method: :post, local: true, class: "flex gap-2" do |f| %>
        <%= f.hidden_field :question_index, value: question_index %>
        <%= f.text_field :message, placeholder: "Type your answer...", autofocus: true,
              class: "flex-1 bg-carus-field border border-[#2A2A2A] rounded-xl py-3.5 px-4 text-sm text-white placeholder:text-white/25 focus:outline-none focus:border-carus-green/40" %>
        <%= f.submit "Send", class: "px-5 py-3.5 bg-carus-green text-carus-black text-sm font-bold rounded-xl hover:bg-carus-green/90 transition" %>
      <% end %>
    </div>
  <% else %>
    <%# All done — redirecting %>
    <div class="flex-1 flex items-center justify-center">
      <div class="text-center space-y-4">
        <div class="w-16 h-16 mx-auto rounded-full bg-carus-green/10 flex items-center justify-center">
          <svg class="h-8 w-8 text-carus-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <p class="text-white/60 text-sm">Got it. Taking you to your garage...</p>
        <meta http-equiv="refresh" content="1.5;url=<%= carus_welcome_path %>">
      </div>
    </div>
  <% end %>
</div>