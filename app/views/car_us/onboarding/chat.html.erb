<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat flex flex-col">
  <%# Header %>
  <div class="flex flex-col items-center pt-14 pb-6 px-6">
    <p class="tracking-[3px] uppercase mb-2 opacity-80 text-[11px]/[14px] font-bold text-carus-green">
      Getting to Know Your Car
    </p>
    <h1 class="text-[20px]/[26px] font-extrabold text-white tracking-[-0.4px] text-center">
      Let's talk about your <%= @vehicle.make.presence || "car" %>
    </h1>
  </div>

  <%# Chat area %>
  <div id="onboarding_chat" class="flex-1 flex flex-col px-6">
    <%= render "car_us/onboarding/chat_messages",
          messages: @messages,
          question_index: @question_index,
          next_question: @question,
          vehicle: @vehicle %>
  </div>
</div>