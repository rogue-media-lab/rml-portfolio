<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="max-w-[375px] mx-auto min-h-screen bg-carus-black font-montserrat flex flex-col items-center justify-center px-6 text-center">
  <div class="flex flex-col items-center gap-6">
    <%# Pulsing car icon %>
    <div class="relative">
      <div class="w-20 h-20 rounded-full bg-carus-green/10 flex items-center justify-center">
        <svg class="h-10 w-10 text-carus-green animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"></path>
        </svg>
      </div>
      <%# Ripple effect %>
      <div class="absolute inset-0 rounded-full border-2 border-carus-green/20 animate-ping"></div>
    </div>

    <div class="space-y-2">
      <h1 class="text-2xl font-extrabold text-white tracking-tight">Getting to know your <%= @vehicle.make.presence || "car" %></h1>
      <p class="text-white/40 text-sm max-w-xs mx-auto">
        Decoding specs. Analyzing the photo. Building your car's profile. This'll just take a moment.
      </p>
    </div>

    <%# Progress dots %>
    <div class="flex gap-2">
      <div class="w-2 h-2 rounded-full bg-carus-green animate-bounce"></div>
      <div class="w-2 h-2 rounded-full bg-carus-green animate-bounce" style="animation-delay: 0.15s"></div>
      <div class="w-2 h-2 rounded-full bg-carus-green animate-bounce" style="animation-delay: 0.3s"></div>
    </div>

    <%# Auto-redirect %>
    <meta http-equiv="refresh" content="3;url=<%= onboarding_chat_path %>">
  </div>
</div>