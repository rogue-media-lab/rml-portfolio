<%= content_for :head do %>
<%= render "car_us/shared/top_menu" %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="max-w-[375px] mx-auto min-h-screen bg-carus-black font-montserrat flex flex-col pb-20">
  <%# Header %>
  <div class="flex flex-col pt-14 gap-0.75 px-6">
    <h1 class="text-[22px]/[28px] font-extrabold text-white tracking-[-0.4px]">Service History</h1>
    <p class="text-xs/[16px] text-[#FFFFFF59]">
      <%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %> · <%= @vehicle.engine_size %>
    </p>
  </div>

  <%# Timeline %>
  <div class="grow flex flex-col pt-5 px-6">
    <% if @service_records.any? %>
      <% @service_records.each_with_index do |record, i| %>
        <div class="flex gap-3.5">
          <%# Timeline dot + line %>
          <div class="flex flex-col items-center shrink-0">
            <div class="mt-1 rounded-full shrink-0 size-2.5 <%= i == 0 ? 'bg-carus-green' : 'bg-[#FFFFFF33]' %>"></div>
            <% unless i == @service_records.length - 1 %>
              <div class="w-0.5 grow bg-[#FFFFFF14] my-1"></div>
            <% end %>
          </div>

          <%# Card %>
          <div class="grow mb-2.5 rounded-2xl py-3.5 px-4 bg-carus-field border border-[#FFFFFF0F]">
            <div class="flex justify-between items-start mb-2">
              <span class="text-[13px]/[16px] font-extrabold text-white"><%= record.service_date.strftime("%b %-d, %Y") %></span>
              <span class="text-[11px]/[14px] text-[#FFFFFF4D]"><%= number_with_delimiter(record.mileage) %> mi</span>
            </div>

            <div class="flex flex-col mb-2.5 gap-1">
              <% record.description.split("\n").each do |line| %>
                <span class="text-xs/[16px] text-[#FFFFFFB3]">· <%= line.strip %></span>
              <% end %>
            </div>

            <div class="flex justify-between items-center">
              <span class="text-[11px]/[14px] text-[#FFFFFF40]">Tech: <%= record.technician_name || "—" %></span>
              <span class="text-xs/[16px] font-bold text-carus-green"><%= number_to_currency(record.cost, precision: 0) %></span>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>

    <%# Older records placeholder %>
    <div class="flex items-start gap-3.5">
      <div class="flex flex-col items-center shrink-0">
        <div class="mt-1 rounded-full shrink-0 border-2 border-[#FFFFFF1F] size-2.5"></div>
      </div>
      <p class="mt-0.5 text-[11px]/[14px] text-carus-text-dim">
        <%= @service_records.any? ? "Older records not yet imported" : "No service history yet" %>
      </p>
    </div>
  </div>

  <%# Bottom tab bar — History active %>
</div>
  <%= render "car_us/shared/customer_tab_bar" %>
</div>