<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="max-w-[375px] mx-auto min-h-screen bg-carus-black font-montserrat flex flex-col">
  <div class="pt-14 pb-4 px-5">
    <p class="opacity-45 tracking-[1.5px] uppercase mb-1 text-[11px]/[14px] font-semibold text-white">Tech Tools</p>
    <h1 class="mb-4 text-[26px]/[32px] font-extrabold text-white tracking-[-0.5px]">Customer Lookup</h1>
    <div class="flex items-center rounded-xl py-[13px] px-4 gap-2.5 bg-carus-field border border-[#2A2A2A]">
      <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
        <circle cx="7" cy="7" r="5" fill="none" stroke="#FFFFFF4D" stroke-width="1.4"/>
        <line x1="11" y1="11" x2="14" y2="14" stroke="#FFFFFF4D" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <span class="opacity-25 text-[13px]/[16px] font-medium text-white">Name, plate, or phone...</span>
    </div>
  </div>

  <div class="flex flex-col pb-8 gap-3 px-5">
    <p class="opacity-35 tracking-[1.5px] uppercase text-[10px]/[12px] font-bold text-white">Recent Customers</p>
    <div class="flex flex-col gap-2">
      <% if @customers.any? %>
        <% @customers.each do |customer| %>
          <% latest_vehicle = customer.vehicles.order(created_at: :desc).first %>
          <div class="flex items-center rounded-[14px] gap-3.5 p-4 bg-carus-field border border-[#2A2A2A]">
            <div class="flex items-center justify-center shrink-0 rounded-[22px] bg-[#0D2B0D] border-[1.5px] border-carus-green size-11">
              <span class="text-sm/[18px] font-extrabold text-carus-green"><%= customer.first_name.to_s.first(2).upcase %></span>
            </div>
            <div class="grow">
              <p class="mb-0.5 text-sm/[18px] font-bold text-white"><%= customer.first_name %> <%= customer.last_name %></p>
              <% if latest_vehicle %>
                <p class="opacity-40 text-[11px]/[14px] font-medium text-white"><%= [latest_vehicle.year, latest_vehicle.make, latest_vehicle.model].compact.join(" ") %></p>
              <% else %>
                <p class="opacity-25 text-[11px]/[14px] font-medium text-white">No vehicles</p>
              <% end %>
            </div>
            <div class="text-right">
              <p class="mb-0.5 text-[11px]/[14px] font-medium text-carus-green"><%= customer.vehicles.count %> vehicle<%= "s" if customer.vehicles.count != 1 %></p>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="rounded-[14px] p-6 bg-carus-field border border-[#2A2A2A] text-center">
          <p class="opacity-30 text-sm font-medium text-white">No customers yet.</p>
        </div>
      <% end %>
    </div>

    <p class="opacity-35 tracking-[1.5px] uppercase mt-2 mb-1 text-[10px]/[12px] font-bold text-white">Due In This Week</p>
    <div class="rounded-[14px] overflow-hidden bg-carus-field border border-[#2A2A2A]">
      <% if @due_this_week.any? %>
        <% @due_this_week.each_with_index do |booking, i| %>
          <div class="flex items-center justify-between py-3.5 px-4 <%= 'border-b border-[#2A2A2A]' unless i == @due_this_week.size - 1 %>">
            <div>
              <p class="mb-0.5 text-[13px]/[16px] font-bold text-white">
                <%= booking.vehicle.car_owner.first_name %> <%= booking.vehicle.car_owner.last_name %> · <%= booking.vehicle.year %> <%= booking.vehicle.make %> <%= booking.vehicle.model %>
              </p>
              <p class="opacity-35 text-[11px]/[14px] text-white"><%= booking.service_types&.truncate(40) %> · <%= booking.preferred_date&.strftime("%b %-d") %> at <%= booking.preferred_time %></p>
            </div>
            <div class="rounded-md py-0.75 px-2 bg-carus-green/15">
              <span class="text-[9px]/[12px] font-bold text-carus-green uppercase"><%= booking.technician&.display_name || "Unassigned" %></span>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="flex items-center justify-center py-6">
          <p class="opacity-30 text-sm font-medium text-white">No appointments due this week.</p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Tab bar %>
  <%= render "car_us/shared/tech_tab_bar" %>
</div>