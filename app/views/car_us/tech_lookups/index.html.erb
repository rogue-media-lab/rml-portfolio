<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="max-w-[375px] mx-auto min-h-screen bg-carus-black font-montserrat flex flex-col">
  <div class="flex justify-between items-start pt-14 gap-0.75 px-6">
    <div class="flex flex-col gap-0.75">
      <p class="uppercase tracking-[1.5px] text-[11px]/[14px] font-semibold text-carus-green">Tech View</p>
      <h1 class="text-[22px]/[28px] font-extrabold text-white tracking-[-0.4px]">Vehicle Lookup</h1>
      <p class="text-xs/[16px] text-[#FFFFFF59]">Find specs by year, make, and model</p>
    </div>
    <%= button_to "Sign Out", destroy_technician_session_path, method: :delete, class: "mt-1 text-[11px]/[14px] font-medium text-[#FFFFFF33] hover:text-[#FF6260] transition bg-transparent border-0 p-0 cursor-pointer" %>
  </div>

  <%# Search / VIN lookup %>
  <%= form_with url: tech_lookups_path, method: :get, local: true, data: { turbo: false }, class: "mt-5 mx-6" do |f| %>
    <div class="flex items-center rounded-[14px] py-3 px-4 gap-2.5 bg-carus-field border border-carus-border focus-within:border-carus-green/40">
      <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
        <circle cx="7" cy="7" r="5" fill="none" stroke="#FFFFFF4D" stroke-width="1.4"/>
        <line x1="11" y1="11" x2="14" y2="14" stroke="#FFFFFF4D" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <%= f.text_field :q, value: params[:q], placeholder: "Search VIN, make, or model...",
            class: "bg-transparent w-full text-sm/[18px] font-medium text-white placeholder:text-white/25 focus:outline-none" %>
      <% if params[:q].present? || params[:year].present? || params[:make].present? %>
        <%= link_to tech_lookups_path, class: "shrink-0 text-[#FFFFFF33] hover:text-white" do %>
          <svg width="14" height="14" viewBox="0 0 14 14"><line x1="3" y1="3" x2="11" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="3" x2="3" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# Year / Make / Model filters %>
  <div class="mt-3.5 flex gap-2.5 mx-6">
    <%= form_with url: tech_lookups_path, method: :get, local: true, data: { turbo: false }, class: "contents" do |f| %>
      <%= f.hidden_field :q, value: params[:q] %>
      <%= f.select :year, options_for_select(@years.map { |y| [y, y] }, params[:year]),
            { include_blank: "Year" },
            onchange: "this.form.requestSubmit()",
            class: "grow appearance-none rounded-xl py-3 px-3.5 bg-carus-field border border-carus-border text-[13px]/[16px] font-semibold text-white focus:outline-none focus:border-carus-green/40" %>
      <%= f.select :make, options_for_select(@makes.map { |m| [m, m] }, params[:make]),
            { include_blank: "Make" },
            onchange: "this.form.requestSubmit()",
            class: "grow-[2] appearance-none rounded-xl py-3 px-3.5 bg-carus-field border border-carus-border text-[13px]/[16px] font-semibold text-white focus:outline-none focus:border-carus-green/40" %>
      <%= f.select :model, options_for_select(@models.map { |m| [m, m] }, params[:model]),
            { include_blank: "Model" },
            onchange: "this.form.requestSubmit()",
            class: "grow-[2] appearance-none rounded-xl py-3 px-3.5 bg-carus-field border border-carus-border text-[13px]/[16px] font-semibold text-white focus:outline-none focus:border-carus-green/40" %>
    <% end %>
  </div>

  <%# Assigned Appointments %>
  <% if @assigned_bookings.any? %>
    <p class="mt-5.5 uppercase tracking-[1px] text-[11px]/[14px] font-bold text-carus-text-muted mx-6">My Appointments</p>
    <div class="flex flex-col pt-2.5 gap-2 px-6">
      <% @assigned_bookings.each do |booking| %>
        <div class="rounded-[14px] py-3.5 px-4 bg-carus-field border border-carus-green/20">
          <div class="flex justify-between items-start">
            <div class="flex flex-col gap-0.5">
              <span class="text-sm/[18px] font-bold text-white"><%= booking.vehicle.car_owner.first_name %> <%= booking.vehicle.car_owner.last_name %></span>
              <span class="text-[11px]/[14px] text-carus-text-muted"><%= booking.vehicle.year %> <%= booking.vehicle.make %> <%= booking.vehicle.model %></span>
            </div>
            <span class="text-xs/[16px] font-semibold text-carus-green"><%= booking.preferred_date&.strftime("%b %-d") %> at <%= booking.preferred_time %></span>
          </div>
          <div class="mt-2 pt-2 border-t border-[#FFFFFF0F]">
            <p class="text-[11px]/[14px] text-[#FFFFFF59]"><%= booking.service_types %></p>
            <% if booking.notes.present? %>
              <p class="text-[10px]/[12px] text-[#FFFFFF33] mt-1">Note: <%= booking.notes.truncate(50) %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Vehicle list %>
  <div class="flex justify-between items-center mx-6 mt-5.5">
    <p class="uppercase tracking-[1px] text-[11px]/[14px] font-bold text-carus-text-muted">Vehicles</p>
    <%= link_to new_tech_lookup_path, class: "text-xs font-semibold text-carus-green" do %>+ Add<% end %>
  </div>

  <div class="grow flex flex-col pt-2.5 gap-2 px-6">
    <% if @vehicles.any? %>
      <% @vehicles.each do |v| %>
        <%= link_to tech_lookup_path(v), class: "flex items-center rounded-[14px] gap-3 p-3.5 bg-carus-field border border-[#2A2A2A] hover:border-carus-green/30 transition" do %>
          <div class="flex items-center justify-center shrink-0 rounded-xl bg-[#0D2B0D] size-10">
            <span class="text-xs font-extrabold text-carus-green"><%= v.make.to_s.first(2).upcase %></span>
          </div>
          <div class="grow min-w-0">
            <p class="text-sm/[18px] font-bold text-white"><%= [v.year, v.make, v.model].compact.join(" ") %></p>
            <p class="text-[11px]/[14px] text-[#FFFFFF4D] truncate"><%= [v.engine_size, v.transmission].compact.join(" · ") %></p>
          </div>
          <span class="text-xs/[16px] font-semibold text-carus-green shrink-0">View →</span>
        <% end %>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center py-16 gap-3 opacity-40">
        <p class="text-sm font-medium text-white">No vehicles yet</p>
        <p class="text-xs text-[#FFFFFF4D]">Add one to get started.</p>
      </div>
    <% end %>
  </div>

  <%# Tab bar %>
  <%= render "car_us/shared/tech_tab_bar" %>
</div>
