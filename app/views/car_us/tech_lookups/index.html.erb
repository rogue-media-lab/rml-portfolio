<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat flex flex-col">
  <div class="flex flex-col pt-14 gap-0.75 px-6">
    <p class="uppercase tracking-[1.5px] text-[11px]/[14px] font-semibold text-carus-green">Tech View</p>
    <h1 class="text-[22px]/[28px] font-extrabold text-white tracking-[-0.4px]">Vehicle Lookup</h1>
    <p class="text-xs/[16px] text-[#FFFFFF59]">Find specs by year, make, and model</p>
  </div>

  <div class="mt-5 flex items-center rounded-[14px] py-3.5 px-4 gap-2.5 bg-carus-field border border-carus-border mx-6">
    <div class="shrink-0 rounded-full border-2 border-[#FFFFFF40] size-4"></div>
    <span class="text-sm/[18px] font-medium text-[#FFFFFF40]">Search or scan VIN...</span>
  </div>

  <div class="mt-3.5 flex gap-2.5 mx-6">
    <div class="grow flex justify-between items-center rounded-xl py-3 px-3.5 bg-carus-field border border-carus-border">
      <span class="text-[13px]/[16px] font-semibold text-white">2020</span>
      <span class="text-[10px]/[12px] text-carus-text-muted">▾</span>
    </div>
    <div class="grow-[2] flex justify-between items-center rounded-xl py-3 px-3.5 bg-carus-field border border-carus-border">
      <span class="text-[13px]/[16px] font-semibold text-white">Honda</span>
      <span class="text-[10px]/[12px] text-carus-text-muted">▾</span>
    </div>
    <div class="grow-[2] flex justify-between items-center rounded-xl py-3 px-3.5 bg-carus-green">
      <span class="text-[13px]/[16px] font-bold text-black">Accord</span>
      <span class="text-[10px]/[12px] text-black/40">▾</span>
    </div>
  </div>

  <p class="mt-5.5 uppercase tracking-[1px] text-[11px]/[14px] font-bold text-carus-text-muted mx-6">Recent Lookups</p>

  <div class="grow flex flex-col pt-2.5 gap-2 px-6">
    <% [
      ["2020 Honda Accord", "2.0T Sport · 2.0L I4 · Today"],
      ["1998 Chevy Silverado", "1500 Z71 · 5.7L V8 · Yesterday"],
      ["2015 Toyota Camry", "SE · 2.5L I4 · Oct 1"],
      ["2018 Ford F-150", "5.0L V8 · Sep 29"]
    ].each do |name, detail| %>
      <div class="flex justify-between items-center rounded-[14px] py-3.5 px-4 bg-carus-field border border-[#FFFFFF0F]">
        <div class="flex flex-col gap-0.5">
          <span class="text-sm/[18px] font-bold text-white"><%= name %></span>
          <span class="text-[11px]/[14px] text-carus-text-muted"><%= detail %></span>
        </div>
        <span class="text-xs/[16px] font-semibold text-carus-green">View →</span>
      </div>
    <% end %>
  </div>

  <%# Tab bar %>
  <div class="h-20.5 flex items-center justify-around shrink-0 pb-4 px-4 bg-[#111111] border-t border-[#FFFFFF12] mt-auto">
    <div class="flex flex-col items-center gap-1.25">
      <div class="flex items-center justify-center rounded-[7px] shrink-0 bg-carus-green/15 size-6">
        <div class="w-2.75 h-2.75 rounded-xs shrink-0 border-2 border-carus-green"></div>
      </div>
      <span class="text-[10px]/[12px] font-bold text-carus-green">Lookup</span>
    </div>
    <%= link_to customer_lookups_path, class: "flex flex-col items-center gap-1.25" do %>
      <div class="flex items-center justify-center shrink-0 size-6">
        <div class="rounded-[3px] shrink-0 border-2 border-[#FFFFFF33] size-3.5"></div>
      </div>
      <span class="text-[10px]/[12px] font-medium text-carus-text-dim">Customers</span>
    <% end %>
    <%= link_to tech_profile_path, class: "flex flex-col items-center gap-1.25" do %>
      <div class="flex items-center justify-center shrink-0 size-6">
        <div class="rounded-full shrink-0 border-2 border-[#FFFFFF33] size-3.5"></div>
      </div>
      <span class="text-[10px]/[12px] font-medium text-carus-text-dim">Profile</span>
    <% end %>
  </div>
</div>