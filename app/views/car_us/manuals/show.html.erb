<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat pb-8">
  <div class="pt-14 pb-4 px-5">
    <p class="opacity-45 tracking-[1.5px] uppercase mb-1 text-[11px]/[14px] font-semibold text-white">
      <%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %>
    </p>
    <h1 class="mb-4 text-[26px]/[32px] font-extrabold text-white tracking-[-0.5px]">Digital Manual</h1>

    <%# Search bar %>
    <div class="flex items-center rounded-xl py-[13px] px-4 gap-2.5 bg-carus-field border border-[#2A2A2A]">
      <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
        <circle cx="7" cy="7" r="5" fill="none" stroke="#FFFFFF4D" stroke-width="1.4"/>
        <line x1="11" y1="11" x2="14" y2="14" stroke="#FFFFFF4D" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <span class="opacity-25 text-[13px]/[16px] font-medium text-white">Search warning lights, controls...</span>
    </div>
  </div>

  <div class="flex flex-col gap-5 px-5">
    <%# Warning Lights %>
    <div>
      <p class="opacity-35 tracking-[1.5px] uppercase mb-2.5 text-[10px]/[12px] font-bold text-white">Warning Lights</p>
      <div class="flex flex-col gap-2">
        <% [
          { icon: "engine", title: "Check Engine", badge: "Service Soon", badge_color: "[#FF6260]", bg: "[#2B0D0D]", desc: "Emissions or engine system fault detected." },
          { icon: "oil", title: "Oil Pressure", badge: "Stop Now", badge_color: "[#FF6260]", bg: "[#2B0D0D]", desc: "Oil pressure critically low. Stop driving immediately." },
          { icon: "tire", title: "Tire Pressure (TPMS)", badge: "Check Soon", badge_color: "[#E8A020]", bg: "[#2B1400]", desc: "One or more tires significantly under-inflated." },
          { icon: "battery", title: "Battery / Charging", badge: "Check Soon", badge_color: "[#E8A020]", bg: "[#2B1400]", desc: "Battery not charging. Alternator may be failing." }
        ].each do |item| %>
          <div class="flex items-center rounded-[14px] py-3.5 px-4 gap-3.5 bg-carus-field border border-[#2A2A2A]">
            <div class="flex items-center justify-center shrink-0 rounded-[10px] bg-<%= item[:bg] %> size-11">
              <svg width="24" height="24" viewBox="0 0 24 24" class="shrink-0">
                <circle cx="12" cy="12" r="10" fill="none" stroke="<%= item[:badge_color] %>" stroke-width="1.5"/>
                <text x="12" y="17" text-anchor="middle" fill="<%= item[:badge_color] %>" font-size="10" font-weight="bold">!</text>
              </svg>
            </div>
            <div class="grow">
              <div class="flex items-center justify-between mb-0.75">
                <span class="text-[13px]/[16px] font-bold text-white"><%= item[:title] %></span>
                <div class="rounded-md py-0.5 px-1.75 bg-<%= item[:badge_color] %>/15">
                  <span class="uppercase text-[9px]/[12px] font-bold text-<%= item[:badge_color] %>"><%= item[:badge] %></span>
                </div>
              </div>
              <p class="opacity-40 text-[11px]/[14px] font-medium text-white"><%= item[:desc] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Controls & Features %>
    <div>
      <p class="opacity-35 tracking-[1.5px] uppercase mb-2.5 text-[10px]/[12px] font-bold text-white">Controls & Features</p>
      <div class="flex gap-2">
        <% [
          { title: "Headlights", desc: "Auto, on/off, high beam operation", color: "[#4A9EFF]", bg: "[#0D1A2B]" },
          { title: "Turn Signals", desc: "Stalk operation, lane change tap", color: "[#4A9EFF]", bg: "[#0D1A2B]" },
          { title: "Wipers", desc: "Speed settings, washer fluid", color: "[#0FB900]", bg: "[#0D1A0D]" }
        ].each do |item| %>
          <div class="grow flex flex-col rounded-[14px] gap-2 p-4 bg-carus-field border border-[#2A2A2A]">
            <div class="flex items-center justify-center rounded-[10px] shrink-0 bg-<%= item[:bg] %> size-9">
              <svg width="20" height="20" viewBox="0 0 20 20" class="shrink-0">
                <circle cx="10" cy="10" r="7" fill="none" stroke="<%= item[:color] %>" stroke-width="1.4"/>
              </svg>
            </div>
            <span class="text-xs/[16px] font-bold text-white"><%= item[:title] %></span>
            <span class="opacity-35 text-[10px]/[12px] font-medium text-white"><%= item[:desc] %></span>
          </div>
        <% end %>
      </div>
    </div>

    <%# Fluids & Capacities %>
    <div>
      <p class="opacity-35 tracking-[1.5px] uppercase mb-2.5 text-[10px]/[12px] font-bold text-white">Fluids & Capacities</p>
      <div class="rounded-[14px] overflow-hidden bg-carus-field border border-[#2A2A2A]">
        <% [
          ["Engine Oil", "0W-20 · 4.4 qts"],
          ["Coolant", "Honda Blue Type 2"],
          ["Brake Fluid", "DOT 3"],
          ["Tire Pressure", "35 PSI F · 33 PSI R"]
        ].each_with_index do |(label, value), i| %>
          <div class="flex justify-between items-center py-[13px] px-4 <%= 'border-b border-[#2A2A2A]' unless i == 3 %>">
            <span class="text-xs/[16px] font-semibold text-white"><%= label %></span>
            <span class="text-xs/[16px] font-bold text-carus-green"><%= value %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>