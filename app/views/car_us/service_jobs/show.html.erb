<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat flex flex-col">
  <div class="shrink-0 flex items-center gap-3 pt-14 px-6 pb-3">
    <%= link_to tech_lookup_path(@job.vehicle), class: "flex items-center justify-center rounded-[18px] shrink-0 bg-carus-field border border-[#2A2A2A] size-9" do %>
      <svg width="16" height="16" viewBox="0 0 16 16"><path d="M10 4L6 8L10 12" fill="none" stroke="#FFFFFF80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <% end %>
    <div class="grow min-w-0">
      <h1 class="text-[17px]/[22px] font-extrabold text-white truncate">Job Details</h1>
      <p class="text-[11px]/[14px] text-[#FFFFFF4D]"><%= @job.vehicle.year %> <%= @job.vehicle.make %> <%= @job.vehicle.model %></p>
    </div>
  </div>

  <div class="px-6 py-4 space-y-4">
    <div class="rounded-2xl p-4 bg-carus-field border border-[#2A2A2A] space-y-3">
      <div>
        <p class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Service</p>
        <p class="mt-1 text-[15px] font-bold text-white"><%= @job.description %></p>
      </div>

      <div class="flex gap-6">
        <div>
          <p class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Book Hours</p>
          <p class="mt-1 text-sm font-bold text-carus-green"><%= @job.book_hours.present? ? "#{@job.book_hours} hrs" : "—" %></p>
        </div>
        <div>
          <p class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Status</p>
          <p class="mt-1 text-sm font-semibold">
            <% if @job.open? %>
              <span class="text-[#E8A020]">Open</span>
            <% else %>
              <span class="text-carus-green">Completed</span> <span class="opacity-50 text-[11px] text-white"><%= @job.completed_at&.strftime("%b %-d, %Y") %></span>
            <% end %>
          </p>
        </div>
      </div>

      <div>
        <p class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Technician</p>
        <p class="mt-1 text-sm font-semibold text-white"><%= @job.technician&.display_name || "—" %></p>
      </div>
    </div>

    <% if @job.job_parts.any? %>
      <div class="rounded-2xl p-4 bg-carus-field border border-[#2A2A2A]">
        <p class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white mb-3">Parts Used</p>
        <% @job.job_parts.each do |part| %>
          <div class="flex justify-between py-2 border-b border-[#FFFFFF08] last:border-0">
            <p class="text-sm text-white"><%= part.name %> × <%= part.quantity %></p>
            <p class="text-sm text-[#FFFFFF4D]"><%= number_to_currency(part.cost) if part.cost %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @job.open? %>
    <%= form_with url: complete_tech_lookup_service_job_path(@job.vehicle, @job), method: :post, local: true, class: "px-6 py-2" do |f| %>
      <div class="rounded-2xl p-4 bg-carus-field border border-carus-green/30 space-y-3">
        <p class="text-[13px]/[16px] font-bold text-carus-green">Complete Job</p>
        <div class="flex gap-3">
          <%= f.number_field :book_hours, value: @job.book_hours, step: 0.1, placeholder: "Hours", class: "w-28 bg-[#1A1A1A] border border-[#2A2A2A] rounded-lg py-2.5 px-3 text-sm font-bold text-carus-green placeholder:text-white/20 focus:outline-none focus:border-carus-green/40" %>
          <%= f.submit "Complete Job", class: "grow rounded-lg py-2.5 bg-carus-green text-sm font-extrabold text-black cursor-pointer" %>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="px-6 py-4 flex gap-3">
    <%= link_to edit_tech_lookup_service_job_path(@job.vehicle, @job), class: "flex-1 flex items-center justify-center gap-2 rounded-xl bg-carus-field border border-[#2A2A2A] text-white text-[15px] font-bold py-3.5" do %>
      <svg width="16" height="16" viewBox="0 0 16 16"><path d="M4 12l7-7M13 4v3a1 1 0 01-1 1h-2M3 5v7a1 1 0 001 1h8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Edit Job
    <% end %>
    <%= button_to tech_lookup_service_job_path(@job.vehicle, @job), method: :delete, form: { data: { turbo_confirm: "Delete this job? This can't be undone." } }, class: "flex-1 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-[15px] font-bold py-3.5" do %>
      Delete Job
    <% end %>
  </div>
</div>