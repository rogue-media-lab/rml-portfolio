<%= content_for :head do %>
<%= render "car_us/shared/top_menu" %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="max-w-[375px] mx-auto min-h-screen bg-carus-black font-montserrat flex flex-col pb-20">
  <%# Gradient header %>
  <div class="flex flex-col items-center pt-14 pb-7 px-6 bg-gradient-to-br from-[#2E4A3A] to-carus-black">
    <%# Avatar — tap to edit %>
    <%= link_to edit_profile_path, class: "relative mb-3.5" do %>
      <div class="w-21 h-21 flex items-center justify-center rounded-[42px] bg-carus-field border-[3px] border-carus-green overflow-hidden">
        <% if @car_owner.avatar.attached? %>
          <%= image_tag @car_owner.avatar.variant(resize_to_limit: [168, 168]), class: "w-full h-full object-cover" %>
        <% else %>
          <span class="text-[28px]/[34px] font-extrabold text-carus-green tracking-[-1px]">
            <%= @car_owner.email.first(2).upcase %>
          </span>
        <% end %>
      </div>
    <% end %>

    <h1 class="mb-1 text-[22px]/[28px] font-extrabold text-white tracking-[-0.5px]">
      <%= [@car_owner.first_name, @car_owner.last_name].compact.join(" ").presence || @car_owner.email.split("@").first.capitalize %>
    </h1>
    <p class="opacity-40 mb-0 text-xs/[16px] font-medium text-white"><%= @car_owner.email %></p>
    <% if @car_owner.address.present? %>
      <p class="opacity-25 mb-1.5 text-[11px]/[14px] font-medium text-white"><%= @car_owner.address %></p>
    <% else %>
      <p class="opacity-25 mb-1.5 text-[11px]/[14px] font-medium text-white">No address on file</p>
    <% end %>

    <div class="rounded-[20px] py-1 px-3 bg-carus-green/15 border border-carus-green/40">
      <span class="text-base/[20px] text-white"><%= @car_owner.shop&.name || "Customer" %></span>
    </div>
  </div>

  <%# Stats row %>
  <div class="flex gap-px bg-[#2A2A2A]">
    <div class="grow py-4 px-2 bg-carus-field">
      <p class="mb-0.75 text-center text-xl/[24px] font-extrabold text-carus-green"><%= @car_owner.vehicles.count %></p>
      <p class="opacity-35 tracking-[0.5px] uppercase text-center text-[9px]/[12px] font-semibold text-white">Vehicles</p>
    </div>
    <div class="grow py-4 px-2 bg-carus-field">
      <p class="mb-0.75 text-center text-xl/[24px] font-extrabold text-[#E8A020]">0</p>
      <p class="opacity-35 tracking-[0.5px] uppercase text-center text-[9px]/[12px] font-semibold text-white">Alerts</p>
    </div>
    <div class="grow py-4 px-2 bg-carus-field">
      <p class="mb-0.75 text-center text-xl/[24px] font-extrabold text-carus-green">0</p>
      <p class="opacity-35 tracking-[0.5px] uppercase text-center text-[9px]/[12px] font-semibold text-white">Services</p>
    </div>
  </div>

  <%# Preferences %>
  <div class="flex flex-col pb-6 gap-3 px-5">
    <p class="opacity-35 tracking-[1.5px] uppercase mt-0 mb-1 text-[10px]/[12px] font-bold text-white">Preferences</p>

    <div class="rounded-[14px] overflow-hidden bg-carus-field border border-[#2A2A2A]">
      <%# Notifications toggle %>
      <div class="flex items-center justify-between p-4 border-b border-[#2A2A2A]">
        <div>
          <p class="mb-0.5 text-[13px]/[16px] font-semibold text-white">Notifications</p>
          <p class="opacity-35 text-[11px]/[14px] font-medium text-white">Service alerts & reminders</p>
        </div>
        <div class="w-11 h-6.5 flex items-center justify-end rounded-[13px] pr-0.75 shrink-0 bg-carus-green">
          <div class="rounded-[10px] shrink-0 bg-white size-5"></div>
        </div>
      </div>

      <%# Mileage Tracking toggle %>
      <div class="flex items-center justify-between p-4 border-b border-[#2A2A2A]">
        <div>
          <p class="mb-0.5 text-[13px]/[16px] font-semibold text-white">Mileage Tracking</p>
          <p class="opacity-35 text-[11px]/[14px] font-medium text-white">Passive driving detection</p>
        </div>
        <div class="w-11 h-6.5 flex items-center justify-end rounded-[13px] pr-0.75 shrink-0 bg-carus-green">
          <div class="rounded-[10px] shrink-0 bg-white size-5"></div>
        </div>
      </div>

      <%# Linked Shop %>
      <div class="flex items-center justify-between p-4">
        <div>
          <p class="mb-0.5 text-[13px]/[16px] font-semibold text-white">Linked Shop</p>
          <p class="opacity-35 text-[11px]/[14px] font-medium text-white">
            <%= @car_owner.shop&.name || "Not linked" %>
          </p>
        </div>
        <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
          <path d="M6 4L10 8L6 12" fill="none" stroke="#FFFFFF4D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <%# Account %>
    <p class="opacity-35 tracking-[1.5px] uppercase mt-2 mb-1 text-[10px]/[12px] font-bold text-white">Account</p>

    <div class="rounded-[14px] overflow-hidden bg-carus-field border border-[#2A2A2A]">
      <div class="flex items-center justify-between p-4 border-b border-[#2A2A2A]">
        <span class="text-[13px]/[16px] font-semibold text-white">Change Password</span>
        <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
          <path d="M6 4L10 8L6 12" fill="none" stroke="#FFFFFF4D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <%= link_to destroy_car_owner_session_path, data: { turbo_method: :delete }, class: "flex items-center justify-between p-4" do %>
        <span class="text-[13px]/[16px] font-semibold text-[#FF6260]">Sign Out</span>
        <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
          <path d="M6 4L10 8L6 12" fill="none" stroke="#FF626080" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      <% end %>
    </div>
  </div>
</div>
  <%= render "car_us/shared/customer_tab_bar" %>
</div>
