<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="max-w-[375px] mx-auto min-h-screen bg-carus-black font-montserrat flex flex-col pb-20">
  <%= render "car_us/shared/top_menu" %>

  <div class="pt-14 pb-5 px-5">
    <div class="flex items-center mb-4 gap-3">
      <%= link_to new_vehicle_booking_request_path(@vehicle), class: "flex items-center justify-center rounded-[18px] shrink-0 bg-carus-field border border-[#2A2A2A] size-9" do %>
        <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0"><path d="M10 4L6 8L10 12" fill="none" stroke="#FFFFFF80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <% end %>
      <span class="opacity-40 text-[13px]/[16px] font-medium text-white">Step 2 of 2</span>
    </div>
    <p class="opacity-45 tracking-[1.5px] uppercase mb-1 text-[11px]/[14px] font-semibold text-white"><%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %></p>
    <h1 class="text-[26px]/[32px] font-extrabold text-white tracking-[-0.5px]">Confirm Appointment</h1>
  </div>

  <div class="flex flex-col gap-4 px-5">
    <%# Selected services %>
    <div>
      <p class="opacity-35 tracking-[1.5px] uppercase mb-2 text-[10px]/[12px] font-bold text-white">Services</p>
      <div class="rounded-[14px] overflow-hidden bg-carus-field border border-[#2A2A2A]">
        <% @selected_services.each_with_index do |svc, i| %>
          <div class="flex justify-between items-center py-3.5 px-4 <%= 'border-b border-[#2A2A2A]' unless i == @selected_services.length - 1 %>">
            <span class="text-sm/[18px] font-semibold text-white"><%= svc.name %></span>
            <span class="text-sm/[18px] font-bold text-carus-green"><%= number_to_currency(svc.price || 0, precision: 0) %></span>
          </div>
        <% end %>
        <%# Fees & Tax %>
        <% if @breakdown[:has_supplies] %>
          <div class="flex justify-between items-center py-2.5 px-4 border-b border-[#2A2A2A]">
            <span class="text-xs/[16px] text-[#FFFFFF59]"><%= @breakdown[:supplies_label] %></span>
            <span class="text-xs/[16px] text-[#FFFFFF59]"><%= number_to_currency(@breakdown[:supplies_fee], precision: 0) %></span>
          </div>
        <% end %>
        <% if @breakdown[:has_travel] %>
          <div class="flex justify-between items-center py-2.5 px-4 border-b border-[#2A2A2A]">
            <span class="text-xs/[16px] text-[#FFFFFF59]"><%= @breakdown[:travel_label] %></span>
            <span class="text-xs/[16px] text-[#FFFFFF59]"><%= number_to_currency(@breakdown[:travel_fee], precision: 0) %></span>
          </div>
        <% end %>
        <% if @breakdown[:has_tax] %>
          <div class="flex justify-between items-center py-2.5 px-4 border-b border-[#2A2A2A]">
            <span class="text-xs/[16px] text-[#FFFFFF59]">Tax (<%= @breakdown[:tax_rate] %>%)</span>
            <span class="text-xs/[16px] text-[#FFFFFF59]"><%= number_to_currency(@breakdown[:tax], precision: 0) %></span>
          </div>
        <% end %>
        <%# Discount %>
        <% if @applied_alert %>
          <div class="flex justify-between items-center py-2.5 px-4 border-b border-[#2A2A2A]">
            <span class="text-xs/[16px] font-medium text-carus-green"><%= @applied_alert.title %> (<%= @applied_alert.discount_percentage %>% off)</span>
            <span class="text-xs/[16px] font-bold text-carus-green">-<%= number_to_currency(@discount, precision: 0) %></span>
          </div>
        <% end %>
        <div class="flex justify-between items-center py-3.5 px-4 bg-[#222222]">
          <span class="text-xs/[16px] font-bold text-[#555555] uppercase tracking-[0.5px]">Total</span>
          <span class="text-[15px]/[18px] font-extrabold text-white"><%= number_to_currency(@breakdown[:total] - @discount, precision: 0) %></span>
        </div>
      </div>
    </div>

    <%# Coupon / Flash Deal %>
    <% if @flash_alerts.any? %>
      <div>
        <p class="opacity-35 tracking-[1.5px] uppercase mb-2 text-[10px]/[12px] font-bold text-white">Apply a Deal</p>
        <div class="flex flex-col gap-2">
          <% @flash_alerts.each do |alert| %>
            <% selected = @applied_alert&.id == alert.id %>
            <%= link_to confirm_vehicle_booking_requests_path(@vehicle, 
                  service_types: @selected, 
                  preferred_date: params[:preferred_date], 
                  preferred_time: params[:preferred_time],
                  notes: params[:notes],
                  flash_alert_id: (selected ? nil : alert.id)),
                  class: "flex items-center justify-between rounded-[14px] py-3.5 px-4 #{selected ? 'bg-carus-green/10 border border-carus-green' : 'bg-carus-field border border-[#2A2A2A]'}" do %>
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center shrink-0 rounded-full size-5 border-2 <%= selected ? 'border-carus-green bg-carus-green' : 'border-[#3A3A3A]' %>">
                  <% if selected %>
                    <svg width="10" height="10" viewBox="0 0 10 10"><polyline points="2 5 4 7 8 3" fill="none" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <% end %>
                </div>
                <div>
                  <span class="text-xs/[16px] font-semibold text-white"><%= alert.title %></span>
                  <span class="opacity-40 text-[10px]/[12px] font-medium text-white ml-2"><%= alert.discount_percentage %>% off</span>
                </div>
              </div>
              <% if selected %>
                <span class="text-[10px]/[12px] font-bold text-carus-green">-$<%= @discount %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Date & Time %>
    <div class="rounded-[14px] p-4 bg-carus-field border border-[#2A2A2A]">
      <p class="text-[10px]/[12px] font-bold text-[#FFFFFF4D] uppercase tracking-[0.8px] mb-2">Date & Time</p>
      <p class="text-[15px]/[18px] font-extrabold text-white"><%= params[:preferred_date].presence || Date.tomorrow.strftime("%B %-d, %Y") %> at <%= params[:preferred_time].presence || "8:00 AM" %></p>
    </div>

    <%# Notes %>
    <% if params[:notes].present? %>
      <div class="rounded-[14px] p-4 bg-carus-field border border-[#2A2A2A]">
        <p class="text-[10px]/[12px] font-bold text-[#FFFFFF4D] uppercase tracking-[0.8px] mb-1">Notes</p>
        <p class="text-[13px] text-[#AAAAAA]"><%= params[:notes] %></p>
      </div>
    <% end %>

    <%# Confirm form %>
    <%= form_with model: [@vehicle, CarUs::BookingRequest.new], url: vehicle_booking_requests_path(@vehicle), method: :post, local: true, data: { turbo: false }, class: "mt-2" do |f| %>
      <%= f.hidden_field :service_types, value: @selected.join(", ") %>
      <%= f.hidden_field :preferred_date, value: params[:preferred_date].presence || Date.tomorrow %>
      <%= f.hidden_field :preferred_time, value: params[:preferred_time].presence || "8:00 AM" %>
      <%= f.hidden_field :notes, value: params[:notes] %>
      <%= f.hidden_field :flash_alert_id, value: @applied_alert&.id %>

      <% if @applied_alert %>
        <div class="flex items-center rounded-[14px] py-3.5 px-4 gap-2.5 bg-carus-green/10 border border-carus-green/20 mb-3">
          <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0"><polyline points="2 8 6 12 14 4" fill="none" stroke="#0FB900" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <div>
            <p class="text-[11px]/[14px] font-bold text-carus-green"><%= @applied_alert.title %> applied · -$<%= @discount %></p>
            <p class="text-[10px]/[12px] font-medium text-white/50">Final total: <%= number_to_currency(@breakdown[:total] - @discount, precision: 0) %></p>
          </div>
        </div>
      <% end %>

      <div class="flex items-center rounded-[14px] py-3.5 px-4 gap-2.5 bg-carus-field border border-[#E8A020]/30 mb-3">
        <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0"><circle cx="8" cy="8" r="6.5" fill="none" stroke="#E8A020" stroke-width="1.3"/><line x1="8" y1="5" x2="8" y2="9" stroke="#E8A020" stroke-width="1.3" stroke-linecap="round"/><circle cx="8" cy="11.5" r="0.75" fill="#E8A020"/></svg>
        <p class="text-[11px]/[14px] font-medium text-[#E8A020]">Appointment will be sent to <%= @shop&.name || "your shop" %> for review.</p>
      </div>

      <%= f.submit "Confirm & Send to Shop", class: "w-full rounded-[14px] p-4.5 bg-carus-green text-[15px]/[18px] font-extrabold text-black cursor-pointer" %>
    <% end %>
  </div>

  <%= render "car_us/shared/customer_tab_bar" %>
</div>