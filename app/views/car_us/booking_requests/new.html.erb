<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat flex flex-col">
  <%# Header %>
  <div class="pt-14 pb-5 px-5">
    <div class="flex items-center mb-4 gap-3">
      <%= link_to vehicle_path(@vehicle), class: "flex items-center justify-center rounded-[18px] shrink-0 bg-carus-field border border-[#2A2A2A] size-9" do %>
        <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
          <path d="M10 4L6 8L10 12" fill="none" stroke="#FFFFFF80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      <% end %>
      <span class="opacity-40 text-[13px]/[16px] font-medium text-white">Schedule maintenance</span>
    </div>
    <p class="opacity-45 tracking-[1.5px] uppercase mb-1 text-[11px]/[14px] font-semibold text-white">
      <%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %>
    </p>
    <h1 class="text-[26px]/[32px] font-extrabold text-white tracking-[-0.5px]">Book a Service</h1>
  </div>

  <%# Form %>
  <%= form_with model: [@vehicle, @booking], url: vehicle_booking_requests_path(@vehicle), class: "flex flex-col pb-8 gap-3 px-5" do |f| %>
    <%# Service selection — Oil Change (selected) %>
    <div class="flex items-center justify-between rounded-[14px] p-4 bg-carus-field border border-carus-green">
      <div>
        <p class="mb-0.5 text-sm/[18px] font-bold text-white">Oil Change</p>
        <p class="opacity-40 text-xs/[16px] font-medium text-white">Full synthetic 0W-20 · ~$89</p>
      </div>
      <div class="w-5.5 h-5.5 flex items-center justify-center rounded-[11px] shrink-0 bg-carus-green">
        <svg width="12" height="12" viewBox="0 0 12 12" class="shrink-0">
          <path d="M2 6L5 9L10 3" fill="none" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <%# Tire Rotation (unselected) %>
    <div class="flex items-center justify-between rounded-[14px] p-4 bg-carus-field border border-[#2A2A2A]">
      <div>
        <p class="mb-0.5 text-sm/[18px] font-bold text-white">Tire Rotation</p>
        <p class="opacity-40 text-xs/[16px] font-medium text-white">Recommended with oil change · ~$30</p>
      </div>
      <div class="w-5.5 h-5.5 rounded-[11px] shrink-0 bg-[#2A2A2A] border-[1.5px] border-[#3A3A3A]"></div>
    </div>

    <%# Hidden service_type — Oil Change is pre-selected %>
    <%= f.hidden_field :service_type, value: "Oil Change" %>

    <%# Date picker %>
    <p class="opacity-35 tracking-[1.5px] uppercase mt-2 mb-1 text-[10px]/[12px] font-bold text-white">Select a Date</p>

    <div class="rounded-[14px] p-4 bg-carus-field border border-[#2A2A2A]">
      <%# Month nav %>
      <div class="flex justify-between items-center mb-3.5">
        <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0"><path d="M10 4L6 8L10 12" fill="none" stroke="#FFFFFF66" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span class="text-[13px]/[16px] font-bold text-white"><%= Date.today.strftime("%B %Y") %></span>
        <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0"><path d="M6 4L10 8L6 12" fill="none" stroke="#FFFFFF66" stroke-width="1.5" stroke-linecap="round"/></svg>
      </div>

      <%# Day headers %>
      <div class="flex justify-between mb-2">
        <% %w[S M T W T F S].each do |d| %>
          <span class="opacity-30 w-10 text-center shrink-0 text-[10px]/[12px] font-semibold text-white"><%= d %></span>
        <% end %>
      </div>

      <%# Day grid — 2 rows for this month %>
      <div class="flex flex-wrap gap-1">
        <% 1.upto(14).each do |day| %>
          <% if day == 10 %>
            <div class="w-10 h-8 flex items-center justify-center rounded-lg shrink-0 bg-carus-green">
              <span class="text-xs/[16px] font-extrabold text-black"><%= day %></span>
            </div>
          <% else %>
            <span class="w-10 text-center shrink-0 text-xs/[16px] font-bold text-white py-1.5"><%= day %></span>
          <% end %>
        <% end %>
      </div>
    </div>

    <%= f.hidden_field :preferred_date, value: Date.today.strftime("%Y-%m-%d") %>

    <%# Time slots %>
    <p class="opacity-35 tracking-[1.5px] uppercase mt-2 mb-1 text-[10px]/[12px] font-bold text-white">Select a Time</p>

    <div class="flex gap-2">
      <% ["8:00 AM", "10:00 AM", "1:00 PM", "3:00 PM"].each_with_index do |time, i| %>
        <% if i == 0 %>
          <div class="grow rounded-[10px] p-2.5 bg-carus-green">
            <span class="text-center text-xs/[16px] font-extrabold text-black w-full inline-block"><%= time %></span>
          </div>
        <% else %>
          <div class="grow rounded-[10px] p-2.5 bg-carus-field border border-[#2A2A2A]">
            <span class="text-center text-xs/[16px] font-semibold text-white w-full inline-block"><%= time %></span>
          </div>
        <% end %>
      <% end %>
    </div>

    <%= f.hidden_field :preferred_time, value: "8:00 AM" %>

    <%# Submit %>
    <%= f.submit "Confirm Appointment", class: "w-full mt-2 rounded-[14px] p-4.5 bg-carus-green text-[15px]/[18px] font-extrabold text-black cursor-pointer" %>
  <% end %>

  <%# Shop info %>
  <div class="flex items-center rounded-[14px] py-3.5 px-4 gap-2.5 bg-carus-field border border-[#2A2A2A] mx-5 mb-8">
    <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
      <circle cx="8" cy="8" r="6.5" fill="none" stroke="#FFFFFF4D" stroke-width="1.3"/>
      <line x1="8" y1="5" x2="8" y2="9" stroke="#FFFFFF4D" stroke-width="1.3" stroke-linecap="round"/>
      <circle cx="8" cy="11.5" r="0.75" fill="#FFFFFF4D"/>
    </svg>
    <p class="opacity-35 text-[11px]/[14px] font-medium text-white">SpeeDee Rock Hill · 123 Main St · (803) 555-0192</p>
  </div>
</div>