<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="max-w-[375px] mx-auto min-h-screen bg-carus-black font-montserrat flex flex-col pb-20">
  <%= render "car_us/shared/top_menu" %>

  <div class="pt-14 pb-5 px-5">
    <div class="flex items-center mb-4 gap-3">
      <%= link_to vehicle_path(@vehicle), class: "flex items-center justify-center rounded-[18px] shrink-0 bg-carus-field border border-[#2A2A2A] size-9" do %>
        <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0"><path d="M10 4L6 8L10 12" fill="none" stroke="#FFFFFF80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <% end %>
      <span class="opacity-40 text-[13px]/[16px] font-medium text-white">Step 1 of 2</span>
    </div>
    <p class="opacity-45 tracking-[1.5px] uppercase mb-1 text-[11px]/[14px] font-semibold text-white"><%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %></p>
    <h1 class="text-[26px]/[32px] font-extrabold text-white tracking-[-0.5px]">Select Services</h1>
  </div>

  <%= form_with url: confirm_vehicle_booking_requests_path(@vehicle), method: :post, local: true, data: { turbo: false }, class: "flex flex-col gap-3 px-5" do |f| %>
    <% if @services.any? %>
      <% @services.each do |service| %>
        <label class="flex items-center gap-3 rounded-[14px] p-4 cursor-pointer bg-carus-field border border-[#2A2A2A] has-[:checked]:border-carus-green transition">
          <%= check_box_tag "service_types[]", service.name, false, class: "sr-only peer" %>
          <div class="w-5.5 h-5.5 flex items-center justify-center rounded-md shrink-0 bg-[#2A2A2A] border-[1.5px] border-[#3A3A3A] peer-checked:bg-carus-green peer-checked:border-carus-green transition">
            <svg width="12" height="12" viewBox="0 0 12 12" class="shrink-0 hidden peer-checked:block"><path d="M2 6L5 9L10 3" fill="none" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="grow">
            <p class="mb-0.5 text-sm/[18px] font-bold text-white"><%= service.name %></p>
            <p class="opacity-40 text-xs/[16px] font-medium text-white"><%= service.description&.truncate(60) %></p>
          </div>
          <span class="text-sm/[18px] font-bold text-carus-green shrink-0"><%= number_to_currency(service.price || 0, precision: 0) %></span>
        </label>
      <% end %>
    <% else %>
      <div class="rounded-[14px] p-4 bg-carus-field border border-[#2A2A2A] opacity-50">
        <p class="text-sm text-[#FFFFFF66]">No services available from your shop yet.</p>
      </div>
    <% end %>

    <%# Date picker %>
    <p class="opacity-35 tracking-[1.5px] uppercase mt-2 mb-1 text-[10px]/[12px] font-bold text-white">Select a Date</p>
    <%= f.date_field :preferred_date, value: Date.tomorrow, min: Date.tomorrow, class: "w-full bg-carus-field border border-carus-border rounded-xl py-3.5 px-4 text-sm text-white focus:outline-none focus:border-carus-green/40 [color-scheme:dark]" %>

    <%# Time slots with availability %>
    <p class="opacity-35 tracking-[1.5px] uppercase mt-2 mb-1 text-[10px]/[12px] font-bold text-white">Select a Time</p>
    <div class="flex gap-2">
      <% @available_slots.each do |slot| %>
        <% if slot[:available] %>
          <label class="grow rounded-[10px] p-2.5 text-center cursor-pointer bg-carus-field border border-[#2A2A2A] has-[:checked]:bg-carus-green has-[:checked]:border-carus-green transition">
            <%= f.radio_button :preferred_time, slot[:time], checked: (slot[:time] == "8:00 AM"), class: "sr-only peer" %>
            <span class="text-xs/[16px] font-semibold text-white peer-checked:text-black"><%= slot[:time] %></span>
            <% if slot[:count] >= slot[:max] - 1 && slot[:count] < slot[:max] %>
              <span class="block text-[9px]/[12px] text-[#E8A020] mt-0.5">1 spot left</span>
            <% end %>
          </label>
        <% else %>
          <div class="grow rounded-[10px] p-2.5 text-center bg-carus-field border border-[#2A2A2A] opacity-30 cursor-not-allowed">
            <span class="text-xs/[16px] font-semibold text-[#FFFFFF33]"><%= slot[:time] %></span>
            <span class="block text-[9px]/[12px] text-[#FFFFFF33] mt-0.5">Full</span>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Notes %>
    <div class="flex flex-col gap-1.5 mt-2">
      <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Notes for the shop</label>
      <%= f.text_area :notes, rows: 2, placeholder: "Any specific concerns...", class: "w-full bg-carus-field border border-carus-border rounded-xl py-3 px-4 text-[13px] text-white placeholder:text-white/20 focus:outline-none focus:border-carus-green/40 resize-none" %>
    </div>

    <%= hidden_field_tag :preferred_date_hidden, Date.tomorrow, id: nil %>

    <%= f.submit "Review Appointment →", class: "w-full mt-2 rounded-[14px] p-4.5 bg-carus-green text-[15px]/[18px] font-extrabold text-black cursor-pointer" %>
  <% end %>

  <%# Shop info %>
  <div class="flex items-center rounded-[14px] py-3.5 px-4 gap-2.5 bg-carus-field border border-[#2A2A2A] mx-5 mt-4">
    <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0"><circle cx="8" cy="8" r="6.5" fill="none" stroke="#FFFFFF4D" stroke-width="1.3"/><line x1="8" y1="5" x2="8" y2="9" stroke="#FFFFFF4D" stroke-width="1.3" stroke-linecap="round"/><circle cx="8" cy="11.5" r="0.75" fill="#FFFFFF4D"/></svg>
    <p class="opacity-35 text-[11px]/[14px] font-medium text-white"><%= @shop&.name || "Your shop" %> · <%= @shop&.address || "" %></p>
  </div>

  <%= render "car_us/shared/customer_tab_bar" %>
</div>