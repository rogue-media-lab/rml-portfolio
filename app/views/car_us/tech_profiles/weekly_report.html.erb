<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat flex flex-col">
  <div class="pt-14 pb-5 px-5">
    <p class="opacity-45 tracking-[1.5px] uppercase mb-1 text-[11px]/[14px] font-semibold text-white">Weekly Report</p>
    <h1 class="text-[26px]/[32px] font-extrabold text-white tracking-[-0.5px]">
      <%= @report[:week_start].strftime("%b %d") %> – <%= @report[:week_end].strftime("%b %d, %Y") %>
    </h1>
  </div>

  <div class="flex flex-col pb-6 gap-3 px-5">
    <%# Progress bar — hours toward target %>
    <% pct = [(@report[:total_hours] / @report[:target] * 100).round, 100].min %>
    <div class="rounded-xl p-4 bg-carus-field border border-[#2A2A2A]">
      <div class="flex items-center justify-between mb-2">
        <span class="text-[13px]/[16px] font-semibold text-white">Target: <%= @report[:target].round %>h</span>
        <span class="text-[13px]/[16px] font-bold text-carus-green"><%= @report[:total_hours].round(1) %>h</span>
      </div>
      <div class="w-full h-2 rounded-full bg-[#1A1A1A] overflow-hidden">
        <div class="h-full rounded-full bg-carus-green transition-all" style="width: <%= pct %>%"></div>
      </div>
      <div class="flex items-center justify-between mt-1.5">
        <span class="opacity-35 text-[10px]/[14px] font-medium text-white"><%= @report[:total_jobs] %> jobs completed</span>
        <span class="opacity-35 text-[10px]/[14px] font-medium text-white"><%= (@report[:target] - @report[:total_hours]).round(1) %>h to go</span>
      </div>
    </div>

    <%# Stats row %>
    <div class="flex gap-2">
      <div class="grow rounded-xl p-3.5 bg-carus-field border border-[#2A2A2A]">
        <p class="mb-0.5 text-center text-lg/[22px] font-extrabold text-carus-green"><%= @report[:total_hours].round(1) %></p>
        <p class="opacity-35 tracking-[0.5px] uppercase text-center text-[9px]/[12px] font-semibold text-white">Book Hours</p>
      </div>
      <div class="grow rounded-xl p-3.5 bg-carus-field border border-[#2A2A2A]">
        <p class="mb-0.5 text-center text-lg/[22px] font-extrabold text-[#E8A020]"><%= @report[:total_jobs] %></p>
        <p class="opacity-35 tracking-[0.5px] uppercase text-center text-[9px]/[12px] font-semibold text-white">Jobs Completed</p>
      </div>
    </div>

    <%# Completed jobs list %>
    <% if @report[:completed].any? %>
      <p class="opacity-35 tracking-[1.5px] uppercase mt-2 mb-1 text-[10px]/[12px] font-bold text-white">Completed This Week</p>
      <% @report[:completed].each do |job| %>
        <div class="flex items-center rounded-xl gap-3 p-3 bg-carus-field border border-[#2A2A2A]">
          <div class="grow">
            <p class="text-[12px]/[16px] font-semibold text-white"><%= job.description %></p>
            <p class="opacity-35 text-[10px]/[14px] font-medium text-white">
              <%= job.vehicle&.year %> <%= job.vehicle&.make %> <%= job.vehicle&.model %>
            </p>
          </div>
          <div class="flex items-center gap-2">
            <span class="rounded-lg py-0.5 px-2 bg-carus-green/[0.12] border border-carus-green/35 text-[10px] font-bold text-carus-green">
              <%= job.book_hours %>h
            </span>
            <span class="opacity-35 text-[10px]/[14px] font-medium text-white">
              <%= job.completed_at&.strftime("%a %l:%M%p") %>
            </span>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="rounded-xl p-6 bg-carus-field border border-[#2A2A2A] text-center">
        <p class="opacity-45 text-[13px]/[16px] font-medium text-white">No jobs completed yet this week.</p>
      </div>
    <% end %>
  </div>

  <%= render "car_us/shared/tech_tab_bar" %>
</div>