<%# CarUs Customer Bottom Tab Bar — shared across all customer views %>
<div class="fixed bottom-0 inset-x-0 h-20 flex items-center justify-around pb-6 px-4 bg-[#111111] border-t border-[#FFFFFF12] z-50">
  <%= link_to vehicles_path, class: "flex flex-col items-center gap-1.25" do %>
    <svg width="22" height="22" viewBox="0 0 22 22" class="shrink-0">
      <path d="M4 18L4 8L11 3L18 8V18" fill="none" stroke="<%= request.path.match?(/\/vehicles/) ? '#0FB900' : '#FFFFFF59' %>" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <rect x="8" y="13" width="6" height="5" rx="1" fill="none" stroke="<%= request.path.match?(/\/vehicles/) ? '#0FB900' : '#FFFFFF59' %>" stroke-width="1.5"/>
    </svg>
    <span class="text-[10px]/[12px] <%= request.path.match?(/\/vehicles/) ? 'font-bold text-carus-green' : 'font-medium text-carus-text-dim' %>">Garage</span>
  <% end %>

  <%= link_to vehicles_path, class: "flex flex-col items-center gap-1.25" do %>
    <svg width="22" height="22" viewBox="0 0 22 22" class="shrink-0">
      <path d="M4 4H18V14.5C18 16.5 17 18 11 18C5 18 4 16.5 4 14.5V4Z" fill="none" stroke="#FFFFFF59" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M4 8H18" fill="none" stroke="#FFFFFF59" stroke-width="1.5"/>
      <circle cx="8" cy="12" r="1" fill="#FFFFFF59"/>
      <circle cx="11" cy="12" r="1" fill="#FFFFFF59"/>
      <circle cx="14" cy="12" r="1" fill="#FFFFFF59"/>
    </svg>
    <span class="text-[10px]/[12px] font-medium text-carus-text-dim">Chat</span>
  <% end %>

  <%= link_to notifications_path, class: "flex flex-col items-center gap-1.25" do %>
    <svg width="22" height="22" viewBox="0 0 22 22" class="shrink-0">
      <circle cx="11" cy="11" r="7.5" fill="none" stroke="<%= current_page?(notifications_path) ? '#0FB900' : '#FFFFFF59' %>" stroke-width="1.5"/>
      <line x1="11" y1="8" x2="11" y2="12" stroke="<%= current_page?(notifications_path) ? '#0FB900' : '#FFFFFF59' %>" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="11" cy="14.5" r="0.75" fill="<%= current_page?(notifications_path) ? '#0FB900' : '#FFFFFF59' %>"/>
    </svg>
    <span class="text-[10px]/[12px] <%= current_page?(notifications_path) ? 'font-bold text-carus-green' : 'font-medium text-carus-text-dim' %>">Alerts</span>
  <% end %>

  <%= link_to profile_path, class: "flex flex-col items-center gap-1.25" do %>
    <svg width="22" height="22" viewBox="0 0 22 22" class="shrink-0">
      <circle cx="11" cy="8" r="3.5" fill="none" stroke="<%= current_page?(profile_path) ? '#0FB900' : '#FFFFFF59' %>" stroke-width="1.5"/>
      <path d="M4 19C4 15.134 7.134 12 11 12C14.866 12 18 15.134 18 19" fill="none" stroke="<%= current_page?(profile_path) ? '#0FB900' : '#FFFFFF59' %>" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <span class="text-[10px]/[12px] <%= current_page?(profile_path) ? 'font-bold text-carus-green' : 'font-medium text-carus-text-dim' %>">Profile</span>
  <% end %>
</div>