<%# Shared tech tab bar — Lookup | Chat | Customers | Profile %>
<% current_path = request.path %>
<div class="h-20.5 flex items-center justify-around shrink-0 pb-4 px-4 bg-[#111111] border-t border-[#FFFFFF12] mt-auto">
  <%= link_to tech_lookups_path, class: "flex flex-col items-center gap-1.25" do %>
    <div class="flex items-center justify-center shrink-0 size-6">
      <svg width="14" height="14" viewBox="0 0 14 14" class="shrink-0">
        <circle cx="6" cy="6" r="4.5" fill="none" stroke="<%= current_path.include?('/tech_lookups') ? '#0FB900' : '#FFFFFF59' %>" stroke-width="1.3"/>
        <line x1="9.5" y1="9.5" x2="13" y2="13" stroke="<%= current_path.include?('/tech_lookups') ? '#0FB900' : '#FFFFFF59' %>" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
    </div>
    <span class="text-[10px]/[12px] <%= current_path.include?('/tech_lookups') ? 'font-bold text-carus-green' : 'font-medium text-carus-text-dim' %>">Lookup</span>
  <% end %>

  <%= link_to conversations_path, class: "flex flex-col items-center gap-1.25" do %>
    <div class="flex items-center justify-center shrink-0 size-6">
      <svg width="14" height="14" viewBox="0 0 14 14" class="shrink-0">
        <path d="M2 4C2 3.172 2.672 2.5 3.5 2.5H10.5C11.328 2.5 12 3.172 12 4V9C12 9.828 11.328 10.5 10.5 10.5H5.5L2 12V4Z" fill="none" stroke="<%= current_path.include?('/conversations') ? '#0FB900' : '#FFFFFF59' %>" stroke-width="1.3" stroke-linejoin="round"/>
      </svg>
    </div>
    <span class="text-[10px]/[12px] <%= current_path.include?('/conversations') ? 'font-bold text-carus-green' : 'font-medium text-carus-text-dim' %>">Chat</span>
  <% end %>

  <%= link_to customer_lookups_path, class: "flex flex-col items-center gap-1.25" do %>
    <div class="flex items-center justify-center shrink-0 size-6">
      <div class="rounded-[3px] shrink-0 border-2 <%= current_path.include?('/customer_lookups') ? 'border-carus-green' : 'border-[#FFFFFF33]' %> size-3.5"></div>
    </div>
    <span class="text-[10px]/[12px] <%= current_path.include?('/customer_lookups') ? 'font-bold text-carus-green' : 'font-medium text-carus-text-dim' %>">Customers</span>
  <% end %>

  <%= link_to tech_profile_path, class: "flex flex-col items-center gap-1.25" do %>
    <div class="flex items-center justify-center shrink-0 size-6">
      <div class="rounded-full shrink-0 border-2 <%= current_path.include?('/tech_profile') ? 'border-carus-green' : 'border-[#FFFFFF33]' %> size-3.5"></div>
    </div>
    <span class="text-[10px]/[12px] <%= current_path.include?('/tech_profile') ? 'font-bold text-carus-green' : 'font-medium text-carus-text-dim' %>">Profile</span>
  <% end %>
</div>