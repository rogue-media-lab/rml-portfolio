<div class="max-w-4xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">My Coupons</h1>
      <p class="mt-1 text-sm text-gray-500"><%= current_car_owner.shop&.name || "No shop selected" %></p>
    </div>
  </div>

  <% if @active_coupons.any? %>
    <div class="space-y-4">
      <h2 class="text-lg font-semibold text-gray-900">Active Offers</h2>
      <% @active_coupons.each do |coupon| %>
        <div class="bg-white rounded-lg shadow-md overflow-hidden border-2 border-blue-600">
          <div class="p-6">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <div class="flex items-center space-x-3">
                  <span class="inline-flex items-center justify-center w-16 h-16 rounded-full text-white font-bold text-2xl bg-blue-600">
                    <%= coupon.discount_percentage %>%
                  </span>
                  <div>
                    <h3 class="text-2xl font-bold text-gray-900"><%= coupon.title %></h3>
                    <p class="text-gray-600 mt-1"><%= coupon.description %></p>
                  </div>
                </div>

                <div class="mt-4 flex items-center space-x-4 text-sm text-gray-500">
                  <span class="flex items-center">
                    <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Expires: <%= coupon.expires_at.strftime("%b %d at %I:%M %p") %>
                  </span>
                </div>

                <div class="mt-3 p-3 bg-gray-50 rounded-lg" data-controller="countdown" data-countdown-end-value="<%= coupon.expires_at.iso8601 %>">
                  <p class="text-xs text-gray-500 mb-1">Time Remaining</p>
                  <p class="text-2xl font-bold text-blue-600" data-countdown-target="display">Calculating...</p>
                </div>
              </div>

              <div class="ml-6">
                <%= link_to "Use Coupon", coupon_path(coupon), class: "inline-flex items-center px-6 py-3 bg-blue-600 border border-transparent text-base font-medium rounded-md text-white hover:bg-blue-700" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow p-12 text-center">
      <svg class="mx-auto h-16 w-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">No Active Offers</h3>
      <p class="mt-2 text-sm text-gray-500">Check back soon for exclusive deals!</p>
    </div>
  <% end %>

  <% if @expired_coupons.any? %>
    <div class="mt-8">
      <h2 class="text-lg font-semibold text-gray-700 mb-4">Recently Expired</h2>
      <div class="space-y-2">
        <% @expired_coupons.each do |coupon| %>
          <div class="bg-gray-50 rounded-lg p-4 opacity-60">
            <div class="flex items-center justify-between">
              <div>
                <h4 class="font-medium text-gray-900"><%= coupon.title %></h4>
                <p class="text-sm text-gray-500">Expired <%= time_ago_in_words(coupon.expires_at) %> ago</p>
              </div>
              <span class="text-2xl font-bold text-gray-400"><%= coupon.discount_percentage %>%</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>