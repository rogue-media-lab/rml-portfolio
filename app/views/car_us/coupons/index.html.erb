<%= content_for :head do %>
<%= render "car_us/shared/top_menu" %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat flex flex-col pb-20">
  <div class="pt-14 px-6">
    <h1 class="text-[22px]/[28px] font-extrabold text-white tracking-[-0.4px]">Deals</h1>
    <p class="text-xs/[16px] text-[#FFFFFF59] mt-0.75"><%= current_car_owner.shop&.name || "Active offers" %></p>
  </div>

  <div class="grow flex flex-col pt-5 gap-3 px-6">
    <% if @active_coupons.any? %>
      <% @active_coupons.each do |coupon| %>
        <div class="rounded-2xl p-5 bg-carus-field border border-carus-green/40">
          <div class="flex items-start gap-4">
            <div class="flex items-center justify-center shrink-0 rounded-2xl bg-carus-green w-16 h-16">
              <span class="text-2xl font-extrabold text-black"><%= coupon.discount_percentage %>%</span>
            </div>
            <div class="grow">
              <h3 class="text-[15px]/[18px] font-bold text-white"><%= coupon.title %></h3>
              <p class="text-[12px] text-[#FFFFFF66] mt-1"><%= coupon.description %></p>
              <p class="text-[10px] text-carus-text-dim mt-2">Expires <%= coupon.expires_at.strftime("%b %d at %I:%M %p") %></p>
            </div>
          </div>
          <%= link_to "Use Deal", coupon_path(coupon), class: "block mt-4 text-center rounded-xl py-3 bg-carus-green text-sm font-extrabold text-black" %>
        </div>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center py-16 gap-3 opacity-40">
        <p class="text-sm font-medium text-white">No active deals</p>
        <p class="text-xs text-[#FFFFFF4D]">Check back soon for offers from your shop.</p>
      </div>
    <% end %>
  </div>

  <%= render "car_us/shared/customer_tab_bar" %>
</div>