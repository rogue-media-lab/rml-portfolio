<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to coupons_path, class: "text-sm font-medium text-blue-600 hover:underline" do %>
      &larr; Back to Coupons
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow-2xl overflow-hidden">
    <div class="p-8 text-center bg-blue-600">
      <p class="text-white text-sm font-medium uppercase tracking-wide mb-2">Flash Sale</p>
      <h1 class="text-white text-5xl font-bold"><%= @coupon.discount_percentage %>% OFF</h1>
      <p class="text-blue-100 text-xl mt-2"><%= @coupon.title %></p>
    </div>

    <div class="px-8 py-6 bg-gray-50 border-b border-gray-200">
      <p class="text-gray-700 text-center"><%= @coupon.description %></p>
    </div>

    <div class="px-8 py-8 bg-white">
      <p class="text-sm text-gray-500 text-center mb-4">Show this code to the cashier</p>

      <div class="bg-white p-6 border-2 border-gray-300 rounded-lg">
        <div class="flex justify-center">
          <span class="text-2xl font-mono font-bold tracking-widest text-gray-900 bg-gray-100 px-6 py-3 rounded"><%= @coupon.code %></span>
        </div>
      </div>
    </div>

    <div class="px-8 py-6 bg-gray-50">
      <div class="text-center">
        <p class="text-sm text-gray-500 mb-2">Expires</p>
        <p class="text-lg font-semibold text-gray-900"><%= @coupon.expires_at.strftime("%B %d, %Y at %I:%M %p") %></p>

        <div class="mt-4 p-4 bg-white rounded-lg" data-controller="countdown" data-countdown-end-value="<%= @coupon.expires_at.iso8601 %>">
          <p class="text-xs text-gray-500 mb-1">Time Remaining</p>
          <p class="text-3xl font-bold text-blue-600" data-countdown-target="display">Calculating...</p>
        </div>
      </div>
    </div>

    <div class="px-8 py-6 bg-gray-100">
      <h3 class="font-semibold text-gray-900 mb-3">How to Use This Coupon:</h3>
      <ol class="space-y-2 text-sm text-gray-600">
        <li class="flex items-start">
          <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center rounded-full text-white text-xs font-bold mr-3 bg-blue-600">1</span>
          <span>Visit <%= current_car_owner.shop&.name || "your shop" %> before the expiration time</span>
        </li>
        <li class="flex items-start">
          <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center rounded-full text-white text-xs font-bold mr-3 bg-blue-600">2</span>
          <span>Show this screen to the service advisor at checkout</span>
        </li>
        <li class="flex items-start">
          <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center rounded-full text-white text-xs font-bold mr-3 bg-blue-600">3</span>
          <span>They'll verify the code and apply your discount</span>
        </li>
      </ol>
    </div>
  </div>

  <div class="mt-6 flex gap-4">
    <%= link_to "View All Coupons", coupons_path, class: "flex-1 text-center px-6 py-3 border-2 border-gray-300 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition-colors" %>
    <%= link_to "View Services", services_path, class: "flex-1 text-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors" %>
  </div>
</div>