<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat">
  <div class="flex flex-col pt-14 gap-1.5 px-6">
    <%# Progress bar — 3 segments %>
    <div class="flex mb-1 gap-1.25">
      <div class="grow h-0.75 rounded-xs bg-carus-green"></div>
      <div class="grow h-0.75 rounded-xs bg-carus-green"></div>
      <div class="grow h-0.75 rounded-xs bg-[#FFFFFF1F]"></div>
    </div>

    <div class="text-[11px]/[14px] text-carus-text-muted font-medium">Step 2 of 3</div>

    <h1 class="text-[22px]/[28px] font-extrabold text-white tracking-[-0.4px]">Add Your Vehicle</h1>

    <p class="text-[13px] leading-[150%] text-[#FFFFFF66]">VIN + a photo. We'll decode the specs and learn your car's story.</p>
  </div>

  <%# Form %>
  <%= form_with model: @vehicle, url: vehicles_path, class: "grow flex flex-col pt-6 gap-3.5 px-6" do |f| %>
    <%# Error summary %>
    <% if @vehicle.errors.any? %>
      <div class="rounded-xl p-3 bg-red-500/10 border border-red-500/20">
        <% @vehicle.errors.full_messages.each do |msg| %>
          <p class="text-red-400 text-xs"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%# VIN — required, first field %>
    <div class="flex flex-col gap-1.5">
      <div class="flex justify-between items-center">
        <label class="uppercase tracking-[0.8px] text-[10px]/[12px] font-bold text-carus-green">VIN <span class="text-carus-green/60">*</span></label>
        <span class="text-[10px]/[12px] font-medium text-white/25">17 characters</span>
      </div>
      <%= f.text_field :vin, placeholder: "1HGCV2F34LA984823", required: true, class: "w-full bg-carus-field border border-carus-green/30 rounded-xl py-[13px] px-3.5 text-[13px]/[16px] font-bold text-carus-green placeholder:text-carus-green/20 focus:outline-none focus:border-carus-green tracking-wider" %>
      <p class="text-[10px]/[12px] text-carus-text-dim px-0.5">We decode this to pull your vehicle's factory specs — engine, transmission, everything.</p>
    </div>

    <%# Photo — required %>
    <div class="flex flex-col gap-1.5">
      <div class="flex justify-between items-center">
        <label class="uppercase tracking-[0.8px] text-[10px]/[12px] font-bold text-carus-green">Vehicle Photo <span class="text-carus-green/60">*</span></label>
      </div>
      <%= f.file_field :photo, accept: "image/*", required: true, class: "w-full bg-carus-field border border-carus-green/30 rounded-xl py-[13px] px-3.5 text-sm/[18px] text-white file:mr-3 file:bg-carus-green file:text-black file:border-0 file:rounded-lg file:py-1 file:px-3 file:text-xs file:font-bold focus:outline-none" %>
      <p class="text-[10px]/[12px] text-carus-text-dim px-0.5">We analyze the color, condition, and type. This helps your car find its voice.</p>
    </div>

    <%# Year + Make side by side (auto-filled from VIN decode) %>
    <div class="flex gap-2.5">
      <div class="grow flex flex-col gap-1.5">
        <label class="uppercase tracking-[0.8px] text-[10px]/[12px] font-bold text-[#FFFFFF59]">Year</label>
        <%= f.text_field :year, placeholder: "2020", class: "w-full bg-carus-field border border-carus-border rounded-xl py-[13px] px-3.5 text-sm/[18px] font-bold text-white placeholder:text-carus-text-dim focus:outline-none focus:border-carus-green/40" %>
      </div>
      <div class="grow-[1.8] flex flex-col gap-1.5">
        <label class="uppercase tracking-[0.8px] text-[10px]/[12px] font-bold text-[#FFFFFF59]">Make</label>
        <%= f.text_field :make, placeholder: "Honda", class: "w-full bg-carus-field border border-carus-border rounded-xl py-[13px] px-3.5 text-sm/[18px] font-bold text-white placeholder:text-carus-text-dim focus:outline-none focus:border-carus-green/40" %>
      </div>
    </div>

    <%# Model %>
    <div class="flex flex-col gap-1.5">
      <label class="uppercase tracking-[0.8px] text-[10px]/[12px] font-bold text-[#FFFFFF59]">Model</label>
      <%= f.text_field :model, placeholder: "Accord — 2.0T Sport", class: "w-full bg-carus-field border border-carus-border rounded-xl py-[13px] px-3.5 text-sm/[18px] font-bold text-white placeholder:text-carus-text-dim focus:outline-none focus:border-carus-green/40" %>
    </div>

    <%# Engine (auto-filled from VIN) %>
    <div class="flex flex-col gap-1.5">
      <label class="uppercase tracking-[0.8px] text-[10px]/[12px] font-bold text-[#FFFFFF59]">Engine</label>
      <div class="flex justify-between items-center rounded-xl py-[13px] px-3.5 bg-[#141414] border border-[#FFFFFF0D]">
        <%= f.text_field :engine_size, placeholder: "2.0L I4 Turbo", class: "bg-transparent w-full text-sm/[18px] font-bold text-[#FFFFFF73] placeholder:text-carus-text-dim focus:outline-none" %>
        <span class="shrink-0 rounded-lg py-0.75 px-2 bg-[#0FB90014] text-[10px]/[12px] font-semibold text-[#0FB90099]">Auto-filled</span>
      </div>
    </div>

    <%# Transmission %>
    <div class="flex flex-col gap-1.5">
      <label class="uppercase tracking-[0.8px] text-[10px]/[12px] font-bold text-[#FFFFFF59]">Transmission</label>
      <%= f.text_field :transmission, placeholder: "Automatic", class: "w-full bg-carus-field border border-carus-border rounded-xl py-[13px] px-3.5 text-sm/[18px] font-bold text-white placeholder:text-carus-text-dim focus:outline-none focus:border-carus-green/40" %>
    </div>

    <%# Current Mileage %>
    <div class="flex flex-col gap-1.5">
      <label class="uppercase tracking-[0.8px] text-[10px]/[12px] font-bold text-[#FFFFFF59]">Current Mileage</label>
      <div class="flex items-center rounded-xl py-[13px] px-3.5 gap-2 bg-carus-field border border-carus-border focus-within:border-carus-green/40">
        <%= f.text_field :mileage, placeholder: "68,080", class: "bg-transparent w-full text-sm/[18px] font-extrabold text-white placeholder:text-carus-text-dim focus:outline-none" %>
        <span class="text-xs/[16px] text-[#FFFFFF40]">mi</span>
      </div>
      <p class="text-[10px]/[12px] text-carus-text-dim px-0.5">Current odometer reading. Helps us track maintenance intervals.</p>
    </div>

    <%# Submit %>
    <%= f.submit "Add to My Garage", class: "w-full mt-1 rounded-[14px] py-4 px-4.5 bg-carus-green text-[15px]/[18px] font-extrabold text-black cursor-pointer hover:bg-carus-green/90 transition-colors" %>
  <% end %>
</div>