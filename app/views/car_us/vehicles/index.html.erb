<%= content_for :head do %>
<%= render "car_us/shared/top_menu" %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<% active_id = params[:car].presence&.to_i || @vehicles.first&.id %>
<% active_vehicle = @vehicles.find { |v| v.id == active_id } %>
<%
  specs = active_vehicle&.ai_specs.is_a?(Hash) ? active_vehicle.ai_specs : {}
  oil_type = specs["oil_type"] || specs["oil"] || specs["recommended_oil"] || specs["engine_oil"]
  oil_capacity = specs["oil_capacity"] || specs["capacity"]
  engine = active_vehicle&.engine_size.presence || specs["engine"]
  chat_messages = active_vehicle&.chat_messages.is_a?(Array) ? active_vehicle.chat_messages : []
%>

<div class="min-h-screen bg-carus-black font-montserrat flex flex-col pb-20">

  <%# ── Header ──────────────────────────────────────────────────────── %>
  <div class="shrink-0 pt-14 pb-3 px-5">
    <div class="flex justify-between items-center">
      <div>
        <p class="text-[11px]/[14px] font-semibold text-white opacity-45 tracking-[1.5px] uppercase">My Garage</p>
        <h1 class="text-[26px]/[32px] font-extrabold text-white tracking-[-0.5px]">Your Vehicles</h1>
      </div>
      <%= link_to new_vehicle_path, class: "flex items-center justify-center rounded-full shrink-0 bg-carus-field border border-[#2A2A2A] size-10" do %>
        <svg width="16" height="16" viewBox="0 0 16 16"><line x1="8" y1="3" x2="8" y2="13" stroke="#FFFFFF80" stroke-width="1.5" stroke-linecap="round"/><line x1="3" y1="8" x2="13" y2="8" stroke="#FFFFFF80" stroke-width="1.5" stroke-linecap="round"/></svg>
      <% end %>
    </div>
    <p class="text-[12px]/[16px] font-medium text-white opacity-30"><%= @vehicles.count %> of 4 slots used</p>
  </div>

  <%# ── Vehicle Cards (compact) ─────────────────────────────────────── %>
  <div class="shrink-0 flex flex-col px-5 gap-3">
    <% @vehicles.each do |vehicle| %>
      <% is_active = vehicle.id == active_id %>
      <% vspecs = vehicle.ai_specs.is_a?(Hash) ? vehicle.ai_specs : {} %>

      <div class="rounded-2xl overflow-hidden border <%= is_active ? 'border-carus-green/40' : 'border-[#2A2A2A]' %> bg-carus-field transition-colors">
        <div class="flex gap-3 p-3">
          <div class="shrink-0 size-14 rounded-xl overflow-hidden bg-carus-black">
            <% if vehicle.photo.attached? %>
              <%= image_tag vehicle.photo.variant(resize_to_fill: [112, 112]), class: "size-full object-cover" %>
            <% else %>
              <div class="size-full flex items-center justify-center">
                <svg width="20" height="20" viewBox="0 0 20 20"><path d="M4 5L4 15L16 15L16 5Z" fill="none" stroke="#FFFFFF1A" stroke-width="1.2"/></svg>
              </div>
            <% end %>
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex justify-between items-start gap-2">
              <div class="min-w-0">
                <h3 class="text-[15px]/[18px] font-extrabold text-white truncate">
                  <%= [vehicle.year, vehicle.make, vehicle.model].compact.join(" ") %>
                </h3>
                <p class="text-[11px]/[14px] font-medium text-white opacity-35">
                  <%= [vehicle.engine_size, vehicle.trim].compact.join(" · ").presence || "#{number_with_delimiter(vehicle.mileage || 0)} mi" %>
                </p>
              </div>
              <%= link_to vehicle_path(vehicle), class: "shrink-0 flex items-center gap-1 rounded-full py-1 px-2.5 bg-carus-black border border-[#FFFFFF0A]" do %>
                <span class="text-[11px]/[12px] font-bold text-carus-green">View</span>
                <svg width="10" height="10" viewBox="0 0 10 10"><path d="M3 2L7 5L3 8" fill="none" stroke="#0FB900" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
            </div>

            <div class="flex gap-2 mt-2">
              <div class="flex-1 rounded-lg py-1.5 px-2.5 bg-carus-black">
                <p class="text-[13px]/[16px] font-extrabold text-carus-green"><%= number_with_delimiter(vehicle.mileage || 0) %></p>
                <p class="text-[9px]/[10px] font-semibold text-white opacity-30 uppercase tracking-[0.5px]">Miles</p>
              </div>
              <div class="flex-1 rounded-lg py-1.5 px-2.5 bg-carus-black">
                <p class="text-[13px]/[16px] font-extrabold text-[#FFFFFF33]">—</p>
                <p class="text-[9px]/[10px] font-semibold text-white opacity-30 uppercase tracking-[0.5px]">Oil Due</p>
              </div>
              <div class="flex-1 rounded-lg py-1.5 px-2.5 bg-carus-black">
                <p class="text-[13px]/[16px] font-extrabold text-carus-green">0</p>
                <p class="text-[9px]/[10px] font-semibold text-white opacity-30 uppercase tracking-[0.5px]">Alerts</p>
              </div>
            </div>
          </div>
        </div>

        <% unless is_active %>
          <%= link_to vehicles_path(car: vehicle.id), class: "flex items-center justify-center gap-1.5 py-2 border-t border-[#FFFFFF06] text-[11px]/[12px] font-semibold text-white opacity-30 hover:opacity-60 transition-opacity" do %>
            <svg width="12" height="12" viewBox="0 0 12 12"><path d="M2 2H10V8C10 9.5 8 10 6 10C4 10 2 9.5 2 8V2Z" fill="none" stroke="currentColor" stroke-width="1.2"/></svg>
            Talk to this car
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%= link_to new_vehicle_path, class: "h-14 flex items-center justify-center rounded-2xl gap-2 shrink-0 bg-carus-field border border-dashed border-[#2A2A2A]" do %>
      <svg width="16" height="16" viewBox="0 0 16 16"><circle cx="8" cy="8" r="7" fill="none" stroke="#FFFFFF33" stroke-width="1.5"/><line x1="8" y1="5" x2="8" y2="11" stroke="#FFFFFF40" stroke-width="1.5" stroke-linecap="round"/><line x1="5" y1="8" x2="11" y2="8" stroke="#FFFFFF40" stroke-width="1.5" stroke-linecap="round"/></svg>
      <span class="text-[12px]/[14px] font-semibold text-white opacity-25">Add a Vehicle</span>
    <% end %>
  </div>

  <%# ── Chat ─────────────────────────────────────────────────────────── %>
  <% if active_vehicle %>
    <div class="flex-1 flex flex-col mt-4"
         data-controller="garage-chat"
         data-garage-chat-chat-url-value="<%= vehicle_chat_path(active_vehicle) %>">

      <%# Messages — from DB or seed intro %>
      <div class="flex-1 overflow-y-auto px-5 flex flex-col gap-3 pb-2"
           data-garage-chat-target="messages">

        <% if chat_messages.any? %>
          <%# Render persisted messages %>
          <% chat_messages.each do |msg| %>
            <% if msg["role"] == "owner" %>
              <div class="flex justify-end">
                <div class="rounded-2xl rounded-tr-sm bg-carus-green px-4 py-3 max-w-[240px]">
                  <p class="text-[14px]/[20px] font-medium text-black"><%= msg["content"] %></p>
                </div>
              </div>
            <% else %>
              <div class="flex gap-2.5">
                <div class="shrink-0 size-7 rounded-full overflow-hidden bg-carus-field mt-0.5">
                  <% if active_vehicle.photo.attached? %>
                    <%= image_tag active_vehicle.photo.variant(resize_to_fill: [56, 56]), class: "size-full object-cover" %>
                  <% end %>
                </div>
                <div class="flex flex-col gap-1 max-w-[265px]">
                  <div class="rounded-2xl rounded-tl-sm bg-carus-panel border border-[#FFFFFF08] px-4 py-3">
                    <p class="text-[13px]/[19px] font-medium text-white"><%= msg["content"] %></p>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <%# Seed: car introduces itself %>
          <div class="flex gap-2.5">
            <div class="shrink-0 size-7 rounded-full overflow-hidden bg-carus-field mt-0.5">
              <% if active_vehicle.photo.attached? %>
                <%= image_tag active_vehicle.photo.variant(resize_to_fill: [56, 56]), class: "size-full object-cover" %>
              <% end %>
            </div>
            <div class="flex flex-col gap-1 max-w-[265px]">
              <div class="rounded-2xl rounded-tl-sm bg-carus-panel border border-[#FFFFFF08] px-4 py-3">
                <p class="text-[13px]/[19px] font-medium text-white">
                  Hey — I'm your <%= [active_vehicle.year, active_vehicle.make, active_vehicle.model].compact.join(" ") %>.
                  <% if engine.present? %>
                    <%= engine %> engine,
                  <% end %>
                  <%= number_with_delimiter(active_vehicle.mileage || 0) %> miles.
                  <% if active_vehicle.ai_plain_english.present? %>
                    <%= active_vehicle.ai_plain_english %>
                  <% end %>
                </p>
              </div>
            </div>
          </div>

          <%# Seed: oil change prompt using known data %>
          <div class="flex gap-2.5">
            <div class="shrink-0 size-7 rounded-full overflow-hidden bg-carus-field mt-0.5">
              <% if active_vehicle.photo.attached? %>
                <%= image_tag active_vehicle.photo.variant(resize_to_fill: [56, 56]), class: "size-full object-cover" %>
              <% end %>
            </div>
            <div class="flex flex-col gap-1 max-w-[265px]">
              <div class="rounded-2xl rounded-tl-sm bg-carus-panel border border-[#FFFFFF08] px-4 py-3">
                <p class="text-[13px]/[19px] font-medium text-white">
                  <% if oil_type.present? && oil_capacity.present? %>
                    I take <%= oil_type %><%= ", #{oil_capacity}" if oil_capacity.present? %>.
                  <% elsif oil_type.present? %>
                    My specs call for <%= oil_type %>.
                  <% elsif engine.present? %>
                    I don't have my oil spec yet — a tech lookup at your shop would fill that in.
                  <% else %>
                    I need a tech to look me up — that'll pull my oil specs and service schedule.
                  <% end %>
                  <% if active_vehicle.mileage.present? && active_vehicle.mileage > 75000 %>
                    At <%= number_with_delimiter(active_vehicle.mileage) %> miles, high-mileage full synthetic is the move — good for 5,000–7,500 miles.
                  <% elsif oil_type.present? %>
                    Full synthetic, good for 5,000–7,500 miles depending on how hard you drive me.
                  <% end %>
                  When was my last oil change? That way I can tell you when the next one's due.
                </p>
              </div>
            </div>
          </div>
        <% end %>

      </div>

      <%# Issue chips %>
      <div class="shrink-0 flex gap-2 px-5 pb-2 overflow-x-auto hide-scrollbar">
        <% if oil_type.present? %>
        <div class="shrink-0 flex items-center rounded-full gap-1.5 py-1 px-3 bg-carus-panel border border-[#FFFFFF08]">
          <div class="shrink-0 size-1.5 rounded-full bg-carus-green"></div>
          <span class="text-[10px]/[12px] font-semibold text-white opacity-60"><%= oil_type.to_s.upcase %></span>
        </div>
        <% end %>
        <% if active_vehicle.mileage.present? && active_vehicle.mileage > 100000 %>
        <div class="shrink-0 flex items-center rounded-full gap-1.5 py-1 px-3 bg-carus-panel border border-[#FFFFFF08]">
          <div class="shrink-0 size-1.5 rounded-full bg-amber-400"></div>
          <span class="text-[10px]/[12px] font-semibold text-white opacity-60">HIGH MILEAGE · <%= number_with_delimiter(active_vehicle.mileage) %></span>
        </div>
        <% end %>
        <div class="shrink-0 flex items-center rounded-full gap-1.5 py-1 px-3 bg-carus-panel border border-[#FFFFFF08]">
          <div class="shrink-0 size-1.5 rounded-full bg-amber-400"></div>
          <span class="text-[10px]/[12px] font-semibold text-white opacity-60">OIL · NEEDS LAST CHANGE DATE</span>
        </div>
      </div>

      <%# Input bar — wired to Stimulus %>
      <div class="shrink-0 px-4 pb-3 pt-2 border-t border-[#FFFFFF08] bg-carus-black">
        <div class="flex items-center gap-2 bg-carus-field rounded-full border border-[#2A2A2A] px-4 py-2.5">
          <input type="text"
                 placeholder="Reply to your <%= active_vehicle.make || 'car' %>..."
                 class="flex-1 bg-transparent border-none outline-none text-[14px]/[20px] font-medium text-white placeholder:text-white/25 font-montserrat"
                 data-garage-chat-target="input"
                 data-action="keydown->garage-chat#handleKeydown">
          <button class="shrink-0 size-8 rounded-full bg-carus-green flex items-center justify-center"
                  data-garage-chat-target="button"
                  data-action="click->garage-chat#submit">
            <svg width="14" height="14" viewBox="0 0 14 14"><path d="M2 2L12 7L2 12Z" fill="#0D0D0D"/></svg>
          </button>
        </div>
      </div>
    </div>
  <% else %>
    <div class="flex-1"></div>
  <% end %>

  <%= render "car_us/shared/customer_tab_bar" %>
</div>