<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat">
  <%# Hero image banner %>
  <div class="relative w-full h-55 overflow-hidden shrink-0">
    <div class="w-full h-full bg-carus-field"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-carus-black/25 via-transparent to-carus-black/85"></div>

    <%# Overlay content %>
    <div class="absolute top-12 bottom-4 flex flex-col justify-end inset-x-5">
      <div class="flex justify-between items-end">
        <div>
          <p class="opacity-70 tracking-[1px] uppercase mb-1 text-[11px]/[14px] font-semibold text-white">
            <%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %>
          </p>
          <p class="opacity-45 text-[11px]/[14px] font-medium text-white">
            <%= [@vehicle.trim, @vehicle.engine_size].compact.join(" · ") %>
          </p>
        </div>
      </div>
    </div>

    <%# Back button %>
    <%= link_to vehicles_path, class: "absolute top-3.5 left-4 flex items-center justify-center rounded-[18px] bg-black/45 size-9" do %>
      <svg width="18" height="18" viewBox="0 0 18 18" class="shrink-0">
        <path d="M11 4L6 9L11 14" fill="none" stroke="#FFFFFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    <% end %>

    <%# Menu button %>
    <div class="absolute top-3.5 right-4 flex items-center justify-center rounded-[18px] bg-black/45 size-9">
      <svg width="18" height="18" viewBox="0 0 18 18" class="shrink-0">
        <rect x="3" y="5" width="12" height="1.5" rx="0.75" fill="#FFFFFF"/>
        <rect x="3" y="8.25" width="12" height="1.5" rx="0.75" fill="#FFFFFF"/>
        <rect x="3" y="11.5" width="12" height="1.5" rx="0.75" fill="#FFFFFF"/>
      </svg>
    </div>
  </div>

  <%# Title area %>
  <div class="flex justify-between items-start pt-1 px-6">
    <div class="flex flex-col gap-0.5">
      <h2 class="text-xl/[24px] font-extrabold text-white tracking-[-0.4px]">
        <%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %>
      </h2>
      <p class="text-[11px]/[14px] text-[#FFFFFF59]">
        <%= [@vehicle.trim, @vehicle.engine_size].compact.join(" · ") %>
        <% if @vehicle.vin.present? %> · VIN ···<%= @vehicle.vin.last(6) %><% end %>
      </p>
    </div>
    <div class="flex items-center justify-center shrink-0 mt-1 rounded-full bg-carus-field border border-carus-border size-8">
      <div class="rounded-full shrink-0 size-1 bg-[#FFFFFF80] [box-shadow:#FFFFFF80_0px_-6px_0px,#FFFFFF80_0px_6px_0px]"></div>
    </div>
  </div>

  <%# Mileage card %>
  <div class="mt-2.5 mb-0 flex items-center justify-between rounded-[14px] py-3 px-4 bg-carus-field border border-[#FFFFFF0F] mx-6">
    <div class="flex flex-col gap-0.5">
      <p class="uppercase tracking-[0.8px] text-[9px]/[12px] font-semibold text-[#FFFFFF59]">Est. Current Mileage</p>
      <p class="text-lg/[22px] font-extrabold text-white">
        <%= number_with_delimiter(@vehicle.mileage || 0) %>
        <%# "+340 mi" is a placeholder — would be calculated from last recorded + time since %>
      </p>
    </div>
    <div class="flex flex-col items-end gap-0.5">
      <p class="uppercase tracking-[0.8px] text-[9px]/[12px] font-semibold text-[#FFFFFF59]">Last Recorded</p>
      <p class="text-[13px]/[16px] font-bold text-[#FFFFFF99]"><%= number_with_delimiter(@vehicle.mileage || 0) %></p>
    </div>
  </div>

  <%# Service filter chips %>
  <div class="mt-2.5 mb-0 flex gap-2 mx-6">
    <div class="grow flex justify-between items-center rounded-[11px] py-2.5 px-3.25 bg-carus-field border border-carus-green/40">
      <span class="text-xs/[16px] font-bold text-carus-green">All Services</span>
      <span class="text-[10px]/[12px] text-carus-green">▾</span>
    </div>
    <div class="rounded-[11px] py-2.5 px-3.25 bg-carus-field border border-carus-border">
      <span class="text-xs/[16px] font-semibold text-[#FFFFFF66]">Oil</span>
    </div>
    <div class="rounded-[11px] py-2.5 px-3.25 bg-carus-field border border-carus-border">
      <span class="text-xs/[16px] font-semibold text-[#FFFFFF66]">Brakes</span>
    </div>
    <div class="rounded-[11px] py-2.5 px-3.25 bg-carus-field border border-carus-border">
      <span class="text-xs/[16px] font-semibold text-[#FFFFFF66]">Tires</span>
    </div>
  </div>

  <%# Service cards %>
  <div class="grow flex flex-col pt-2.5 gap-2 px-6">
    <%# Book Service CTA %>
    <%= link_to new_vehicle_booking_request_path(@vehicle), class: "flex items-center justify-center rounded-2xl py-4 gap-2 bg-carus-green/10 border border-carus-green/20" do %>
      <span class="text-sm/[18px] font-bold text-carus-green">Book a Service</span>
      <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
        <path d="M3 8H13M10 5L13 8L10 11" fill="none" stroke="#0FB900" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    <% end %>
    <%# Placeholder — no service records yet %>
    <div class="flex rounded-2xl py-3.5 px-4 gap-3 bg-carus-field border border-[#FFFFFF0D] opacity-50">
      <div class="flex items-center justify-center shrink-0 rounded-[10px] bg-[#FFFFFF0A] size-10">
        <div class="rounded-[3px] shrink-0 size-4 border-2 border-[#FFFFFF33] border-dashed"></div>
      </div>
      <div class="flex flex-col grow gap-0.75">
        <div class="flex justify-between">
          <p class="text-[13px]/[16px] font-bold text-[#FFFFFF8C]">No service history yet</p>
        </div>
        <p class="text-[11px] leading-[150%] text-[#FFFFFF4D]">Services will appear here after your next shop visit.</p>
      </div>
    </div>
  </div>

  <%# Bottom tab bar %>
  <div class="h-20.5 flex items-center justify-around shrink-0 pb-4 px-4 bg-[#111111] border-t border-[#FFFFFF12] mt-auto">
    <div class="flex flex-col items-center gap-1.25">
      <div class="flex items-center justify-center rounded-[7px] shrink-0 bg-carus-green/15 size-6">
        <div class="w-2.75 h-2.75 rounded-xs shrink-0 border-2 border-carus-green"></div>
      </div>
      <span class="text-[10px]/[12px] font-bold text-carus-green">Garage</span>
    </div>
    <%= link_to vehicle_service_records_path(@vehicle), class: "flex flex-col items-center gap-1.25" do %>
      <div class="flex items-center justify-center shrink-0 size-6">
        <div class="rounded-[3px] shrink-0 border-2 border-[#FFFFFF33] size-3.5"></div>
      </div>
      <span class="text-[10px]/[12px] font-medium text-carus-text-dim">History</span>
    <% end %>
    <div class="flex flex-col items-center relative gap-1.25">
      <div class="flex items-center justify-center relative shrink-0 size-6">
        <div class="rounded-full shrink-0 border-2 border-[#FFFFFF33] size-3.5"></div>
        <div class="absolute top-0 right-0 w-1.75 h-1.75 rounded-full bg-[#FF6260] border-[1.5px] border-[#111111]"></div>
      </div>
      <span class="text-[10px]/[12px] font-medium text-carus-text-dim">Alerts</span>
    </div>
    <div class="flex flex-col items-center gap-1.25">
      <div class="flex items-center justify-center shrink-0 size-6">
        <div class="rounded-full shrink-0 border-2 border-[#FFFFFF33] size-3.5"></div>
      </div>
      <span class="text-[10px]/[12px] font-medium text-carus-text-dim">Profile</span>
    </div>
  </div>
</div>