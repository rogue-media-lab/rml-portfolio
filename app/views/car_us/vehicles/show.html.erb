<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat flex flex-col pb-20">
  <%# Hero image banner %>
  <div class="relative w-full h-55 overflow-hidden shrink-0">
    <% if @vehicle.photo.attached? %>
      <%= image_tag @vehicle.photo.variant(resize_to_limit: [780, 440]), class: "w-full h-full object-cover" %>
    <% else %>
      <div class="w-full h-full bg-carus-field"></div>
    <% end %>
    <div class="absolute inset-0 bg-gradient-to-b from-carus-black/25 via-transparent to-carus-black/85"></div>

    <%# Overlay content %>
    <div class="absolute top-12 bottom-4 flex flex-col justify-end inset-x-5">
      <div class="flex justify-between items-end">
        <div>
          <p class="opacity-70 tracking-[1px] uppercase mb-1 text-[11px]/[14px] font-semibold text-white">
            <%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %>
          </p>
          <p class="opacity-45 text-[11px]/[14px] font-medium text-white">
            <%= [@vehicle.trim, @vehicle.engine_size].compact.join(" · ") %>
          </p>
        </div>
      </div>
    </div>

    <%# Back button %>
    <%= link_to vehicles_path, class: "absolute top-3.5 left-4 flex items-center justify-center rounded-[18px] bg-black/45 size-9" do %>
      <svg width="18" height="18" viewBox="0 0 18 18" class="shrink-0">
        <path d="M11 4L6 9L11 14" fill="none" stroke="#FFFFFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    <% end %>

    <%# Hamburger menu — Home + Logout %>
    <%= render "car_us/shared/top_menu" %>
  </div>

  <%# Title area %>
  <div class="flex justify-between items-start pt-1 px-6">
    <div class="flex flex-col gap-0.5">
      <h2 class="text-xl/[24px] font-extrabold text-white tracking-[-0.4px]">
        <%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %>
      </h2>
      <p class="text-[11px]/[14px] text-[#FFFFFF59]">
        <%= [@vehicle.trim, @vehicle.engine_size].compact.join(" · ") %>
        <% if @vehicle.vin.present? %> · VIN ···<%= @vehicle.vin.last(6) %><% end %>
      </p>
    </div>
    <%= link_to edit_vehicle_path(@vehicle), class: "flex items-center justify-center shrink-0 mt-1 rounded-full bg-carus-field border border-carus-border size-8" do %>
      <div class="rounded-full shrink-0 size-1 bg-[#FFFFFF80] [box-shadow:#FFFFFF80_0px_-6px_0px,#FFFFFF80_0px_6px_0px]"></div>
    <% end %>
  </div>

  <%# Mileage card %>
  <div class="mt-2.5 mb-0 flex items-center justify-between rounded-[14px] py-3 px-4 bg-carus-field border border-[#FFFFFF0F] mx-6">
    <div class="flex flex-col gap-0.5">
      <p class="uppercase tracking-[0.8px] text-[9px]/[12px] font-semibold text-[#FFFFFF59]">Est. Current Mileage</p>
      <p class="text-lg/[22px] font-extrabold text-white">
        <%= number_with_delimiter(@vehicle.mileage || 0) %>
        <%# "+340 mi" is a placeholder — would be calculated from last recorded + time since %>
      </p>
    </div>
    <div class="flex flex-col items-end gap-0.5">
      <p class="uppercase tracking-[0.8px] text-[9px]/[12px] font-semibold text-[#FFFFFF59]">Last Recorded</p>
      <p class="text-[13px]/[16px] font-bold text-[#FFFFFF99]"><%= number_with_delimiter(@vehicle.mileage || 0) %></p>
    </div>
  </div>

  <%# Shop Services — from the linked shop %>
  <% if @services.any? %>
    <div class="mt-2.5 mb-0 flex gap-2 mx-6 overflow-x-auto hide-scrollbar">
      <% @services.first(5).each do |svc| %>
        <div class="shrink-0 rounded-[11px] py-2.5 px-3.25 bg-carus-field border border-carus-border">
          <span class="text-xs/[16px] font-semibold text-[#FFFFFF66] whitespace-nowrap"><%= svc.name %></span>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# History — bookings + service records %>
  <div class="grow flex flex-col pt-2.5 gap-2 px-6">
    <%# Book Service CTA %>
    <%= link_to new_vehicle_booking_request_path(@vehicle), class: "flex items-center justify-center rounded-2xl py-4 gap-2 bg-carus-green/10 border border-carus-green/20" do %>
      <span class="text-sm/[18px] font-bold text-carus-green">Book a Service</span>
      <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
        <path d="M3 8H13M10 5L13 8L10 11" fill="none" stroke="#0FB900" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    <% end %>

    <%# Digital Manual %>
    <%= link_to vehicle_manual_path(@vehicle), class: "flex items-center justify-center rounded-2xl py-4 gap-2 bg-carus-field border border-[#FFFFFF0D]" do %>
      <span class="text-sm/[18px] font-semibold text-white opacity-70">Digital Manual</span>
      <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
        <path d="M3 8H13M10 5L13 8L10 11" fill="none" stroke="#FFFFFF80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    <% end %>

    <%# Upcoming Bookings %>
    <% if @bookings.any? %>
      <p class="opacity-35 tracking-[1.5px] uppercase mt-1 text-[10px]/[12px] font-bold text-white px-1">Appointments</p>
      <% @bookings.each do |booking| %>
        <div class="flex rounded-2xl py-3.5 px-4 gap-3 bg-carus-field border border-[#FFFFFF0D]">
          <div class="flex flex-col items-center justify-center shrink-0 rounded-[10px] bg-carus-green/10 size-10">
            <span class="text-[10px]/[12px] font-extrabold text-carus-green"><%= booking.preferred_date&.strftime("%b") || "—" %></span>
            <span class="text-[15px]/[18px] font-extrabold text-carus-green"><%= booking.preferred_date&.strftime("%-d") || "—" %></span>
          </div>
          <div class="flex flex-col grow gap-0.75">
            <div class="flex justify-between">
              <p class="text-[13px]/[16px] font-bold text-white"><%= booking.service_types&.truncate(30) %></p>
              <span class="text-[10px]/[12px] font-semibold text-carus-green capitalize"><%= booking.status %></span>
            </div>
            <p class="text-[11px] leading-[150%] text-[#FFFFFF4D]">
              <%= booking.preferred_time || "TBD" %><%= " · #{booking.preferred_date&.strftime('%B %-d, %Y')}" if booking.preferred_date %>
            </p>
          </div>
        </div>
        <% end %>
      <% end %>
    <% end %>

    <%# Service Records + Completed Jobs %>
    <% if @service_records.any? || @service_jobs.any? %>
      <p class="opacity-35 tracking-[1.5px] uppercase mt-1 text-[10px]/[12px] font-bold text-white px-1">Service History</p>

      <% @service_jobs.each do |job| %>
        <%= link_to tech_lookup_service_job_path(@vehicle, job), class: "flex rounded-2xl py-3.5 px-4 gap-3 bg-carus-field border border-[#FFFFFF0D] hover:border-carus-green/20 transition" do %>
          <div class="flex items-center justify-center shrink-0 rounded-[10px] bg-carus-green/10 size-10">
            <svg width="18" height="18" viewBox="0 0 18 18"><circle cx="9" cy="9" r="6.5" fill="none" stroke="#0FB900" stroke-width="1.3"/><path d="M6 9L8 11L12 7" fill="none" stroke="#0FB900" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="flex flex-col grow gap-0.75">
            <div class="flex justify-between">
              <p class="text-[13px]/[16px] font-bold text-white"><%= job.description&.truncate(30) || "Service" %></p>
              <% if job.book_hours.present? %>
                <span class="text-xs/[16px] font-semibold text-carus-green"><%= job.book_hours %> hrs</span>
              <% end %>
            </div>
            <p class="text-[11px] leading-[150%] text-[#FFFFFF4D]">
              <%= job.completed_at&.strftime("%b %-d, %Y") || job.created_at&.strftime("%b %-d, %Y") %>
            </p>
          </div>
        <% end %>
      <% end %>

      <% @service_records.each do |record| %>
        <div class="flex rounded-2xl py-3.5 px-4 gap-3 bg-carus-field border border-[#FFFFFF0D]">
          <div class="flex items-center justify-center shrink-0 rounded-[10px] bg-[#FFFFFF0A] size-10">
            <svg width="18" height="18" viewBox="0 0 18 18"><circle cx="9" cy="9" r="6.5" fill="none" stroke="#FFFFFF33" stroke-width="1.3"/><path d="M6 9L8 11L12 7" fill="none" stroke="#FFFFFF33" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="flex flex-col grow gap-0.75">
            <div class="flex justify-between">
              <p class="text-[13px]/[16px] font-bold text-white"><%= record.description&.truncate(30) || "Service" %></p>
              <% if record.cost.present? %>
                <span class="text-xs/[16px] font-semibold text-carus-green"><%= number_to_currency(record.cost, precision: 0) %></span>
              <% end %>
            </div>
            <p class="text-[11px] leading-[150%] text-[#FFFFFF4D]">
              <%= record.service_date&.strftime("%b %-d, %Y") %><%= " · #{number_with_delimiter(record.mileage)} mi" if record.mileage.present? %><%= " · #{record.technician_name}" if record.technician_name.present? %>
            </p>
          </div>
        </div>
        <% end %>
      <% end %>
    <% end %>

    <%# Empty state — only show if no bookings AND no service records %>
    <% if @bookings.empty? && @service_records.empty? && @service_jobs.empty? %>
      <div class="flex rounded-2xl py-3.5 px-4 gap-3 bg-carus-field border border-[#FFFFFF0D] opacity-50">
        <div class="flex items-center justify-center shrink-0 rounded-[10px] bg-[#FFFFFF0A] size-10">
          <div class="rounded-[3px] shrink-0 size-4 border-2 border-[#FFFFFF33] border-dashed"></div>
        </div>
        <div class="flex flex-col grow gap-0.75">
          <div class="flex justify-between">
            <p class="text-[13px]/[16px] font-bold text-[#FFFFFF8C]">No service history yet</p>
          </div>
          <p class="text-[11px] leading-[150%] text-[#FFFFFF4D]">Services will appear here after your next shop visit.</p>
        </div>
      </div>
    <% end %>
  </div>

  <%= render "car_us/shared/customer_tab_bar" %>
</div>