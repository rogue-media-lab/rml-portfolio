<div class="max-w-4xl mx-auto space-y-6">
  <div class="text-center mb-8">
    <h1 class="text-4xl font-bold text-gray-900">My Rewards</h1>
    <p class="mt-2 text-gray-600"><%= current_car_owner.shop&.name || "CarUs" %></p>
  </div>

  <div class="bg-blue-600 rounded-lg shadow-xl p-8 text-white">
    <div class="text-center">
      <p class="text-sm font-medium uppercase tracking-wide">Your Rewards Balance</p>
      <p class="mt-2 text-6xl font-bold"><%= @points_balance %></p>
      <p class="mt-1 text-xl">Points</p>
      <div class="mt-4 pt-4 border-t border-blue-400">
        <p class="text-sm">Cash Value</p>
        <p class="text-3xl font-semibold">$<%= @points_value %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-md p-6">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">How Rewards Work</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="text-center">
        <div class="flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mx-auto mb-3">
          <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-2">Earn Points</h3>
        <p class="text-sm text-gray-600">Get 10 points for every $1 you spend on services</p>
      </div>

      <div class="text-center">
        <div class="flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 mx-auto mb-3">
          <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-2">Track Progress</h3>
        <p class="text-sm text-gray-600">Watch your rewards balance grow with each visit</p>
      </div>

      <div class="text-center">
        <div class="flex items-center justify-center w-16 h-16 rounded-full bg-purple-100 mx-auto mb-3">
          <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-2">Redeem Rewards</h3>
        <p class="text-sm text-gray-600">Use your points for discounts on future services</p>
      </div>
    </div>
  </div>

  <% if @redemptions.any? %>
    <div class="bg-white rounded-lg shadow-md">
      <div class="px-6 py-5 border-b border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900">Redemption History</h2>
      </div>
      <div class="divide-y divide-gray-200">
        <% @redemptions.each do |redemption| %>
          <div class="px-6 py-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-medium text-gray-900"><%= redemption.redeemable.try(:title) || "Reward Redeemed" %></p>
                <p class="text-sm text-gray-500"><%= redemption.redeemed_at&.strftime("%B %d, %Y at %I:%M %p") %></p>
              </div>
              <span class="text-green-600 font-semibold">Redeemed</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow-md p-8 text-center">
      <p class="text-gray-500">No redemptions yet. Start using your coupons!</p>
    </div>
  <% end %>
</div>