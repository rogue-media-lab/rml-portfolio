<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    input:-webkit-autofill,
    input:-webkit-autofill:hover,
    input:-webkit-autofill:focus,
    input:-webkit-autofill:active {
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: #ffffff !important;
      transition: background-color 5000s ease-in-out 0s;
      box-shadow: inset 0 0 0 1000px #1A1A1A !important;
      caret-color: #ffffff !important;
    }
  </style>
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat flex items-center justify-center p-4 md:p-8">
  <div class="w-full max-w-5xl flex flex-col md:flex-row gap-0 md:gap-12 lg:gap-20">

    <%# Left — Login Form %>
    <div class="w-full md:w-[420px] md:shrink-0 flex flex-col">
      <%# Brand %>
      <div class="flex flex-col items-center md:items-start pt-10 md:pt-0 pb-8 md:pb-10">
        <p class="tracking-[3px] uppercase mb-2 opacity-80 text-[11px]/[14px] font-bold text-carus-green">
          Technician Access
        </p>
        <h1 class="mb-1 text-[42px]/[52px] font-black text-white tracking-[-2px]">carus</h1>
        <p class="opacity-30 text-xs/[16px] font-medium text-white">Shop tools. Simplified.</p>
      </div>

      <%# Form %>
      <%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "flex flex-col gap-3" do |f| %>
        <div class="flex flex-col gap-1.5">
          <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Email</label>
          <div class="flex items-center rounded-xl gap-2.5 p-4 bg-carus-field border border-[#2A2A2A] focus-within:border-carus-green/40">
            <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
              <rect x="1" y="3" width="14" height="10" rx="2" fill="none" stroke="#FFFFFF4D" stroke-width="1.3"/>
              <path d="M1 5L8 9.5L15 5" fill="none" stroke="#FFFFFF4D" stroke-width="1.3"/>
            </svg>
            <%= f.email_field :email, placeholder: "tech@shop.com", class: "bg-transparent w-full text-sm/[18px] font-medium text-white placeholder:text-white/25 focus:outline-none" %>
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Password</label>
          <div class="flex items-center rounded-xl p-4 bg-carus-field border border-[#2A2A2A] focus-within:border-carus-green/40">
            <svg width="16" height="16" viewBox="0 0 16 16" class="shrink-0">
              <rect x="3" y="7" width="10" height="7" rx="1.5" fill="none" stroke="#FFFFFF4D" stroke-width="1.3"/>
              <path d="M5 7V5C5 3.343 6.343 2 8 2C9.657 2 11 3.343 11 5V7" fill="none" stroke="#FFFFFF4D" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            <%= f.password_field :password, placeholder: "········", class: "bg-transparent opacity-25 tracking-[3px] text-lg/[22px] text-white placeholder:text-white/25 focus:outline-none w-full" %>
          </div>
        </div>

        <% if flash.alert %>
          <p class="text-[#FF6260] text-xs"><%= flash.alert %></p>
        <% end %>

        <div class="flex justify-end">
          <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs/[16px] font-semibold text-carus-green" %>
        </div>

        <%= f.submit "Sign In", class: "w-full mt-2 rounded-[14px] p-4.5 bg-carus-green text-[15px]/[18px] font-extrabold text-black cursor-pointer tracking-[0.3px] hover:bg-carus-green/90 transition" %>
      <% end %>

      <%# Footer — mobile only %>
      <div class="flex justify-center mt-8 md:hidden">
        <p class="opacity-20 text-[11px]/[14px] font-medium text-white">Powered by Rogue Media Lab</p>
      </div>
    </div>

    <%# Right — Info panel (desktop only) %>
    <div class="hidden md:flex flex-1 flex-col justify-center min-h-0">
      <div class="space-y-8">
        <%# Headline %>
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-carus-green/10 border border-carus-green/20 text-carus-green text-xs font-semibold tracking-wider uppercase mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-carus-green"></span>
            For Shops
          </div>
          <h2 class="text-3xl lg:text-4xl font-extrabold text-white tracking-tight leading-tight">
            Customers arrive ready.<br>
            <span class="text-carus-green">You just execute.</span>
          </h2>
          <p class="mt-4 text-white/40 leading-relaxed text-sm lg:text-base max-w-md">
            CarUs customers come to you with a service need already identified — no selling required. Manage bookings, techs, and fleet accounts from one dashboard.
          </p>
        </div>

        <%# Feature bullets %>
        <div class="space-y-4">
          <% [
            { title: "Booking Pipeline", desc: "Customers book through the app. They show up ready. No phone tag." },
            { title: "Vehicle History Access", desc: "See what's been done. Know what's due. Build trust through data." },
            { title: "Fleet Accounts", desc: "Net-30 billing for commercial fleets. Landscapers, plumbers, delivery." },
            { title: "Direct Customer Line", desc: "Your regulars get a lightweight message channel. Nurture the relationship." }
          ].each do |feature| %>
            <div class="flex gap-3">
              <div class="mt-0.5 w-5 h-5 rounded-full bg-carus-green/10 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-carus-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white"><%= feature[:title] %></p>
                <p class="text-xs text-white/30 leading-relaxed"><%= feature[:desc] %></p>
              </div>
            </div>
          <% end %>
        </div>

        <%# Footer — desktop %>
        <div class="pt-8 border-t border-white/5">
          <p class="opacity-20 text-[11px]/[14px] font-medium text-white">Powered by Rogue Media Lab</p>
        </div>
      </div>
    </div>
  </div>
</div>