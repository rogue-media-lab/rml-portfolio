<%# Restaurant Homepage %>
<% content_for(:title) { @restaurant.name } %>

<%# Hero Section %>
<section style="background-color: var(--primary);" class="py-16 md:py-24 px-6 md:px-16">
  <div class="max-w-4xl mx-auto text-center">
    <h1 style="font-family: var(--font-display); color: var(--dark);" class="text-4xl md:text-6xl font-bold mb-4"><%= @restaurant.name %></h1>
    <% if @restaurant.tagline.present? %>
      <p style="color: var(--dark);" class="text-lg md:text-xl opacity-80"><%= @restaurant.tagline %></p>
    <% end %>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to "View Menu", restaurant_menu_path(@restaurant.slug), class: "inline-block px-8 py-3 rounded-lg font-bold text-white transition-colors", style: "background-color: var(--accent);" %>
      <%= link_to "Order Now", restaurant_menu_path(@restaurant.slug), class: "inline-block px-8 py-3 rounded-lg font-bold border-2 transition-colors", style: "border-color: var(--dark); color: var(--dark);" %>
    </div>
  </div>
</section>

<%# Featured Items %>
<% if @featured_items.any? %>
  <section class="py-16 px-6 md:px-16">
    <div class="max-w-6xl mx-auto">
      <h2 style="font-family: var(--font-display); color: var(--dark);" class="text-3xl font-bold text-center mb-12">Customer Favorites</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @featured_items.each do |item| %>
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            <div class="p-6">
              <h3 style="font-family: var(--font-display); color: var(--dark);" class="text-xl font-bold mb-2"><%= item.name %></h3>
              <p class="text-gray-600 text-sm mb-4"><%= item.description %></p>
              <div class="flex justify-between items-center">
                <span style="color: var(--accent);" class="text-xl font-bold">$<%= '%.2f' % item.price %></span>
                <%= button_to "Add to Cart", restaurant_cart_add_path(@restaurant.slug, menu_item_id: item.id), method: :post, class: "px-4 py-2 rounded-lg text-white text-sm font-medium transition-colors", style: "background-color: var(--accent);" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# Menu Preview %>
<% if @categories.any? %>
  <section style="background-color: var(--dark);" class="py-16 px-6 md:px-16">
    <div class="max-w-6xl mx-auto">
      <h2 style="font-family: var(--font-display); color: var(--primary);" class="text-3xl font-bold text-center mb-12">Our Menu</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% @categories.each do |category| %>
          <div class="bg-white/10 rounded-xl p-6">
            <h3 style="color: var(--primary);" class="text-xl font-bold mb-4"><%= category.name %></h3>
            <ul class="space-y-2">
              <% category.menu_items.active.limit(4).each do |item| %>
                <li class="flex justify-between text-gray-300 text-sm">
                  <span><%= item.name %></span>
                  <span>$<%= '%.2f' % item.price %></span>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
      <div class="text-center mt-8">
        <%= link_to "Full Menu", restaurant_menu_path(@restaurant.slug), class: "inline-block px-8 py-3 rounded-lg font-bold text-white transition-colors", style: "background-color: var(--accent);" %>
      </div>
    </div>
  </section>
<% end %>

<%# Testimonials %>
<% if @testimonials.any? %>
  <section class="py-16 px-6 md:px-16">
    <div class="max-w-6xl mx-auto">
      <h2 style="font-family: var(--font-display); color: var(--dark);" class="text-3xl font-bold text-center mb-12">What People Say</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% @testimonials.each do |testimonial| %>
          <div class="bg-white rounded-xl shadow-md p-6">
            <div class="flex gap-1 mb-3">
              <% testimonial.stars.times do %>
                <span style="color: var(--primary);" class="material-icons text-lg">star</span>
              <% end %>
            </div>
            <p class="text-gray-600 text-sm mb-4 italic">"<%= testimonial.quote %>"</p>
            <p style="color: var(--dark);" class="font-semibold text-sm"><%= testimonial.customer_name %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# Hours %>
<% if @hours.any? %>
  <section style="background-color: var(--primary);" class="py-16 px-6 md:px-16">
    <div class="max-w-2xl mx-auto text-center">
      <h2 style="font-family: var(--font-display); color: var(--dark);" class="text-3xl font-bold mb-8">Hours</h2>
      <div class="space-y-2">
        <% @hours.each do |hour| %>
          <div class="flex justify-between text-lg" style="color: var(--dark);">
            <span class="font-medium"><%= hour.day_name %></span>
            <span>
              <% if hour.closed? %>
                Closed
              <% else %>
                <%= hour.open_time&.strftime("%l:%M %p") %> - <%= hour.close_time&.strftime("%l:%M %p") %>
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# Contact %>
<section class="py-16 px-6 md:px-16">
  <div class="max-w-4xl mx-auto text-center">
    <h2 style="font-family: var(--font-display); color: var(--dark);" class="text-3xl font-bold mb-8">Visit Us</h2>
    <% if @restaurant.address.present? %>
      <p class="text-gray-600 mb-4"><%= @restaurant.address %></p>
    <% end %>
    <% if @restaurant.phone.present? %>
      <a href="tel:<%= @restaurant.phone %>" style="color: var(--accent);" class="text-lg font-semibold hover:underline"><%= @restaurant.phone %></a>
    <% end %>
    <% if @restaurant.place_id.present? %>
      <div class="mt-8 rounded-xl overflow-hidden shadow-lg">
        <iframe
          src="https://maps.google.com/maps?q=<%= CGI.escape(@restaurant.address || @restaurant.name) %>&t=&z=16&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="300"
          style="border:0;"
          allowfullscreen=""
          loading="lazy">
        </iframe>
      </div>
    <% end %>
  </div>
</section>
