<%# Order Confirmation %>
<% content_for(:title) { "Order Confirmed — #{@restaurant.name}" } %>

<section class="py-16 px-6 md:px-16">
  <div class="max-w-lg mx-auto text-center">
    <div class="bg-white rounded-xl shadow-md p-8 md:p-12">
      <span style="color: var(--accent);" class="material-icons text-6xl mb-4">check_circle</span>
      <h1 style="font-family: var(--font-display); color: var(--dark);" class="text-3xl font-bold mb-4">Order Confirmed!</h1>
      <p class="text-gray-600 mb-2">Thank you, <%= @order.customer_name %>!</p>
      <p class="text-gray-600 mb-6">
        Your order has been received.
        <% if @order.pickup_time.present? %>
          Pickup time: <strong><%= @order.pickup_time.strftime("%l:%M %p") %></strong>
        <% end %>
      </p>
      <div class="border-t pt-4 mb-6">
        <div class="flex justify-between font-bold text-lg" style="color: var(--dark);">
          <span>Total</span>
          <span style="color: var(--accent);">$<%= '%.2f' % @order.total %></span>
        </div>
      </div>
      <p class="text-gray-500 text-sm mb-6">We'll call you at <%= @order.phone %> when your order is ready.</p>
      <%= link_to "Back to #{@restaurant.name}", restaurant_home_path(@restaurant.slug), class: "inline-block px-8 py-3 rounded-lg text-white font-bold transition-colors", style: "background-color: var(--accent);" %>
    </div>
  </div>
</section>
