<%# Restaurant Footer — adapts to each restaurant's theme %>
<footer style="background-color: var(--dark);" class="py-12 px-6 md:px-16 mt-auto">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 style="font-family: var(--font-display); color: var(--primary);" class="text-xl font-bold mb-4"><%= @restaurant.name %></h3>
        <% if @restaurant.tagline.present? %>
          <p class="text-gray-300 text-sm"><%= @restaurant.tagline %></p>
        <% end %>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Quick Links</h4>
        <div class="flex flex-col gap-2">
          <%= link_to "Home", restaurant_home_path(@restaurant.slug), class: "text-gray-300 hover:text-yellow-300 text-sm transition-colors" %>
          <%= link_to "Menu", restaurant_menu_path(@restaurant.slug), class: "text-gray-300 hover:text-yellow-300 text-sm transition-colors" %>
          <%= link_to "About", restaurant_about_path(@restaurant.slug), class: "text-gray-300 hover:text-yellow-300 text-sm transition-colors" %>
          <%= link_to "Contact", restaurant_contact_path(@restaurant.slug), class: "text-gray-300 hover:text-yellow-300 text-sm transition-colors" %>
        </div>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Contact</h4>
        <div class="flex flex-col gap-2 text-gray-300 text-sm">
          <% if @restaurant.address.present? %>
            <p><%= @restaurant.address %></p>
          <% end %>
          <% if @restaurant.phone.present? %>
            <a href="tel:<%= @restaurant.phone %>" class="hover:text-yellow-300 transition-colors"><%= @restaurant.phone %></a>
          <% end %>
        </div>
      </div>
    </div>
    <div class="border-t border-gray-700 mt-8 pt-8 text-center">
      <p class="text-gray-500 text-xs">Powered by Rogue Media Lab</p>
    </div>
  </div>
</footer>
