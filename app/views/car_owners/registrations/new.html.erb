<%= content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="min-h-screen bg-carus-black font-montserrat flex flex-col justify-between">
  <%# Header %>
  <div class="flex flex-col items-center pt-20 px-10">
    <div class="mb-5 rounded-[20px] py-1.25 px-3.5 bg-carus-green/[0.12] border border-carus-green/30">
      <span class="text-center text-base/[20px] text-white">Step 1 of 3</span>
    </div>
    <h1 class="mb-2 text-[28px]/[34px] font-extrabold text-white tracking-[-0.5px] text-center">Create Your Account</h1>
    <p class="opacity-35 text-center text-[13px]/[16px] font-medium text-white">Enter your details to get started with carus.</p>
  </div>

  <%# Form %>
  <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), class: "flex flex-col px-6 gap-3" do |f| %>
    <%# Error messages %>
    <% if resource.errors.any? %>
      <div class="rounded-xl p-3 bg-[#FF6260]/10 border border-[#FF6260]/20">
        <% resource.errors.full_messages.each do |msg| %>
          <p class="text-[#FF6260] text-xs"><%= msg %></p>
        <% end %>
      </div>
    <% end %>
    <%# Name fields %>
    <div class="flex gap-2.5">
      <div class="grow flex flex-col gap-1.5">
        <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">First Name</label>
        <%= f.text_field :first_name, placeholder: "Mason", class: "w-full bg-carus-field border border-[#2A2A2A] rounded-xl py-[15px] px-3.5 text-sm/[18px] text-white placeholder:text-white/25 focus:outline-none focus:border-carus-green/40" %>
      </div>
      <div class="grow flex flex-col gap-1.5">
        <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Last Name</label>
        <%= f.text_field :last_name, placeholder: "Roberts", class: "w-full bg-carus-field border border-[#2A2A2A] rounded-xl py-[15px] px-3.5 text-sm/[18px] text-white placeholder:text-white/25 focus:outline-none focus:border-carus-green/40" %>
      </div>
    </div>

    <%# Address %>
    <div class="flex flex-col gap-1.5">
      <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Street Address</label>
      <%= f.text_field :address, placeholder: "123 Main St, Rock Hill, SC", class: "w-full bg-carus-field border border-[#2A2A2A] rounded-xl py-[15px] px-3.5 text-sm/[18px] text-white placeholder:text-white/25 focus:outline-none focus:border-carus-green/40" %>
      <span class="text-[10px]/[12px] text-white/20 px-0.5">So your car knows where home is.</span>
    </div>

    <%# Work Address %>
    <div class="flex flex-col gap-1.5">
      <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Work Address</label>
      <%= f.text_field :work_address, placeholder: "456 Commerce Dr, Charlotte, NC", class: "w-full bg-carus-field border border-[#2A2A2A] rounded-xl py-[15px] px-3.5 text-sm/[18px] text-white placeholder:text-white/25 focus:outline-none focus:border-carus-green/40" %>
      <span class="text-[10px]/[12px] text-white/20 px-0.5">Helps us understand your commute.</span>
    </div>

    <%# Email %>
    <div class="flex flex-col gap-1.5">
      <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Email</label>
      <%= f.email_field :email, placeholder: "you@email.com", required: true, class: "w-full bg-carus-field border border-[#2A2A2A] rounded-xl py-[15px] px-3.5 text-sm/[18px] text-white placeholder:text-white/25 focus:outline-none focus:border-carus-green/40" %>
    </div>

    <%# Shop selection (hidden when coming from a shop page) %>
    <% preselected_shop = params[:shop_id].present? ? CarUs::Shop.find_by(id: params[:shop_id]) : nil %>
    <% if preselected_shop %>
      <%= f.hidden_field :shop_id, value: preselected_shop.id %>
      <div class="flex flex-col gap-1.5">
        <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Your Shop</label>
        <div class="rounded-xl py-[15px] px-3.5 bg-carus-field border border-carus-green/40">
          <span class="text-sm/[18px] font-bold text-carus-green"><%= preselected_shop.name %></span>
        </div>
      </div>
    <% else %>
      <div class="flex flex-col gap-1.5">
        <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Choose Your Shop</label>
        <%= f.collection_select :shop_id, CarUs::Shop.where(active: true).order(:name), :id, :name, { include_blank: "Select a shop..." }, class: "w-full bg-carus-field border border-[#2A2A2A] rounded-xl py-[15px] px-3.5 text-sm/[18px] text-white focus:outline-none focus:border-carus-green/40 appearance-none" %>
      </div>
    <% end %>

    <%# Password %>
    <div class="flex flex-col gap-1.5">
      <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Password</label>
      <%= f.password_field :password, placeholder: "········", required: true, class: "w-full bg-carus-field border border-carus-green rounded-xl py-[15px] px-3.5 tracking-[3px] text-lg/[22px] text-white placeholder:text-white/25 focus:outline-none" %>
    </div>

    <%# Password Confirmation %>
    <div class="flex flex-col gap-1.5">
      <label class="opacity-50 tracking-[1px] uppercase text-[10px]/[12px] font-bold text-white">Confirm Password</label>
      <%= f.password_field :password_confirmation, placeholder: "········", required: true, class: "w-full bg-carus-field border border-[#2A2A2A] rounded-xl py-[15px] px-3.5 tracking-[3px] text-lg/[22px] text-white placeholder:text-white/25 focus:outline-none focus:border-carus-green/40" %>
    </div>

    <%# Submit %>
    <%= f.submit "Continue →", class: "w-full mt-1 rounded-[14px] p-4.5 bg-carus-green text-[15px]/[18px] font-extrabold text-black cursor-pointer" %>
  <% end %>

  <%# Footer %>
  <div class="flex justify-center pb-9">
    <%= link_to "Already have an account? Sign In", new_session_path(resource_name), class: "opacity-20 text-[11px]/[14px] font-medium text-white" %>
  </div>
</div>