<%# Restaurant Menu Page %>
<% content_for(:title) { "Menu — #{@restaurant.name}" } %>

<section class="py-16 px-6 md:px-16">
  <div class="max-w-4xl mx-auto">
    <h1 style="font-family: var(--font-display); color: var(--dark);" class="text-4xl font-bold text-center mb-12">Our Menu</h1>

    <% @categories.each do |category| %>
      <div class="mb-12">
        <h2 style="font-family: var(--font-display); color: var(--dark);" class="text-2xl font-bold mb-6 pb-2 border-b-2" style="border-color: var(--primary);"><%= category.name %></h2>
        <div class="space-y-4">
          <% category.menu_items.active.each do |item| %>
            <div class="flex justify-between items-start gap-4 py-3 border-b border-gray-200">
              <div class="flex-1">
                <h3 style="color: var(--dark);" class="font-semibold"><%= item.name %></h3>
                <% if item.description.present? %>
                  <p class="text-gray-500 text-sm mt-1"><%= item.description %></p>
                <% end %>
              </div>
              <div class="flex items-center gap-4">
                <span style="color: var(--accent);" class="font-bold text-lg">$<%= '%.2f' % item.price %></span>
                <%= button_to "Add", restaurant_cart_add_path(@restaurant.slug, menu_item_id: item.id), method: :post, class: "px-3 py-1.5 rounded-lg text-white text-sm font-medium transition-colors", style: "background-color: var(--accent);" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
