<%# Restaurant About Page %>
<% content_for(:title) { "About — #{@restaurant.name}" } %>

<section class="py-16 px-6 md:px-16">
  <div class="max-w-4xl mx-auto">
    <h1 style="font-family: var(--font-display); color: var(--dark);" class="text-4xl font-bold text-center mb-12">About Us</h1>
    <div class="bg-white rounded-xl shadow-md p-8 md:p-12">
      <p class="text-gray-600 text-lg leading-relaxed">
        Welcome to <%= @restaurant.name %><% if @restaurant.address.present? %>, located at <%= @restaurant.address %><% end %>.
      </p>
      <% if @restaurant.tagline.present? %>
        <p class="text-gray-600 text-lg leading-relaxed mt-4"><%= @restaurant.tagline %></p>
      <% end %>
      <p class="text-gray-600 text-lg leading-relaxed mt-4">
        We look forward to serving you!
      </p>
    </div>
  </div>
</section>
