<%# Italian Garden Homepage — adapted from standalone app %>
<% content_for(:title) { @restaurant.name } %>

<%# ─── HERO ─── %>
<section class="flex flex-col items-center justify-center px-6 md:px-12 py-20 md:py-28 text-center relative overflow-hidden" style="background-color: #8B1A1A;">
  <div class="w-16 h-0.5 mb-7" style="background-color: #C9A96E;"></div>
  <p class="text-sm font-medium uppercase tracking-[0.15em] mb-4" style="color: #C9A96E;">York, South Carolina — Family Owned</p>
  <h1 class="text-4xl md:text-6xl font-bold max-w-3xl leading-tight tracking-tight" style="color: #FAF3E8;"><%= @restaurant.name %></h1>
  <p class="text-base md:text-lg max-w-xl mt-5 leading-relaxed" style="color: rgba(250,243,232,0.8);"><%= @restaurant.tagline %></p>
  <div class="flex flex-col sm:flex-row gap-4 mt-10">
    <%= link_to "View Our Menu", restaurant_menu_path(@restaurant.slug), class: "text-sm font-semibold px-9 py-3.5 rounded", style: "background-color: #C9A96E; color: #8B1A1A;" %>
    <% if @restaurant.phone.present? %>
      <a href="tel:<%= @restaurant.phone&.gsub(/[^0-9]/, '') %>" class="text-sm font-semibold px-9 py-3.5 rounded border", style="color: #FAF3E8; border-color: rgba(250,243,232,0.4);">Call to Order</a>
    <% end %>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent to-transparent" style="background: linear-gradient(to right, transparent, #C9A96E, transparent);"></div>
</section>

<%# ─── SIGNATURE FAVORITES ─── %>
<% if @featured_items.any? %>
<section class="px-6 md:px-12 py-16 md:py-20" style="background-color: #FAF3E8;">
  <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2" style="color: #C9A96E;">From Our Kitchen</p>
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 tracking-tight" style="color: #3D2B1F;">Signature Favorites</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-7 max-w-6xl mx-auto">
    <% @featured_items.each do |item| %>
      <div class="bg-white rounded-lg overflow-hidden shadow-sm">
        <div class="h-48 flex items-center justify-center" style="background: linear-gradient(135deg, #D4A373, #8B1A1A);">
          <span class="text-5xl opacity-30">🍽️</span>
        </div>
        <div class="p-6">
          <h3 class="text-lg font-bold" style="color: #3D2B1F;"><%= item.name %></h3>
          <p class="text-sm mt-2 leading-relaxed" style="color: #6B6055;"><%= item.description %></p>
          <div class="flex items-center justify-between mt-4">
            <span class="text-lg font-bold" style="color: #8B1A1A;">$<%= '%.2f' % item.price %></span>
            <%= button_to "Add to Cart", restaurant_cart_add_path(@restaurant.slug, menu_item_id: item.id), method: :post, class: "text-sm font-semibold px-4 py-2.5 rounded cursor-pointer hover:opacity-90", style: "background-color: #8B1A1A; color: #FAF3E8;" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>
<% end %>

<%# ─── OUR STORY ─── %>
<% if @restaurant.tagline.present? %>
<section class="px-6 md:px-12 py-16 md:py-20" style="background-color: #F5E6CC;">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12 md:gap-16">
    <div class="flex-1 max-w-lg">
      <p class="text-xs font-medium uppercase tracking-[0.1em] mb-3" style="color: #8B1A1A;">Our Story</p>
      <h2 class="text-3xl md:text-4xl font-bold leading-tight tracking-tight mb-5" style="color: #3D2B1F;">Welcome to <%= @restaurant.name %></h2>
      <p class="text-base leading-relaxed" style="color: #5A4A3F;"><%= @restaurant.tagline %></p>
      <% if @restaurant.address.present? %>
        <p class="text-base leading-relaxed mt-4" style="color: #5A4A3F;">Visit us at <%= @restaurant.address %>. We look forward to serving you!</p>
      <% end %>
    </div>
    <div class="flex-1 max-w-sm h-72 rounded-lg overflow-hidden flex items-center justify-center" style="background: linear-gradient(135deg, #D4A373, #8B1A1A);">
      <div class="text-center">
        <p class="text-2xl font-bold text-white"><%= @restaurant.name %></p>
        <p class="text-xs text-white opacity-60 mt-1 uppercase tracking-wider"><%= @restaurant.address %></p>
      </div>
    </div>
  </div>
</section>
<% end %>

<%# ─── MENU PREVIEW ─── %>
<% if @categories.any? %>
<section class="px-6 md:px-12 py-16 md:py-20" style="background-color: #3D2B1F;">
  <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2" style="color: #C9A96E;">What We Serve</p>
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 tracking-tight" style="color: #FAF3E8;">Our Menu</h2>
  <p class="text-base text-center max-w-lg mx-auto mb-12" style="color: rgba(250,243,232,0.6);">From hearty Italian classics to American favorites — generous portions at honest prices.</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-6xl mx-auto">
    <% @categories.limit(3).each do |cat| %>
      <div>
        <h3 class="text-lg font-bold pb-3 mb-5" style="color: #C9A96E; border-bottom: 1px solid rgba(201,169,110,0.3);"><%= cat.name %></h3>
        <div class="space-y-3.5">
          <% cat.menu_items.active.limit(7).each do |item| %>
            <div class="flex justify-between items-baseline">
              <span class="text-sm font-medium" style="color: #FAF3E8;"><%= item.name %></span>
              <span class="text-sm" style="color: rgba(250,243,232,0.5);">$<%= '%.2f' % item.price %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-10">
    <%= link_to "View Full Menu →", restaurant_menu_path(@restaurant.slug), class: "text-sm font-medium uppercase tracking-wider pb-0.5 hover:opacity-80", style: "color: #C9A96E; border-bottom: 1px solid #C9A96E;" %>
  </div>
</section>
<% end %>

<%# ─── REVIEWS ─── %>
<section class="px-6 md:px-12 py-16 md:py-20" style="background-color: #FAF3E8;">
  <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2" style="color: #C9A96E;">What People Say</p>
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 tracking-tight" style="color: #3D2B1F;">Our Regulars Keep Coming Back</h2>

  <% if @restaurant.rating.present? %>
    <div class="flex items-center justify-center gap-3 mb-10">
      <span class="text-3xl font-bold" style="color: #3D2B1F;"><%= @restaurant.rating %></span>
      <div>
        <div class="flex gap-0.5">
          <% @restaurant.rating.to_i.times do %><span class="text-lg" style="color: #C9A96E;">★</span><% end %>
          <% (5 - @restaurant.rating.to_i).times do %><span class="text-lg" style="color: rgba(201,169,110,0.3);">★</span><% end %>
        </div>
        <p class="text-xs" style="color: #5A4A3F;">Google Reviews · <%= @restaurant.review_count %> reviews</p>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-7 max-w-6xl mx-auto">
    <% @testimonials.each do |t| %>
      <div class="bg-white rounded-lg p-8" style="border-left: 3px solid #C9A96E;">
        <div class="flex gap-1 mb-4">
          <% t.stars.times do %><span style="color: #C9A96E;">★</span><% end %>
        </div>
        <p class="text-sm leading-relaxed italic mb-5" style="color: #3D2B1F;">"<%= t.quote %>"</p>
        <p class="text-sm font-semibold" style="color: #8B1A1A;">— <%= t.customer_name %></p>
      </div>
    <% end %>
  </div>

  <% if @restaurant.place_id.present? %>
    <div class="text-center mt-10">
      <p class="text-xs font-medium uppercase tracking-[0.15em] mb-4" style="color: #C9A96E;">Leave a Review</p>
      <div class="flex items-center justify-center gap-6">
        <a href="https://www.google.com/maps/place/?q=place_id:<%= @restaurant.place_id %>" target="_blank" class="flex flex-col items-center gap-2 group">
          <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
            <span class="text-xl" style="color: #4285F4;">G</span>
          </div>
          <span class="text-xs opacity-60 group-hover:opacity-100" style="color: #3D2B1F;">Google</span>
        </a>
      </div>
    </div>
  <% end %>
</section>

<%# ─── CONTACT & MAP ─── %>
<section class="px-6 md:px-12 py-16 md:py-20" style="background-color: #8B1A1A;">
  <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2" style="color: #C9A96E;">Come See Us</p>
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 tracking-tight" style="color: #FAF3E8;">Visit <%= @restaurant.name %></h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-5xl mx-auto">
    <%# Hours %>
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-5" style="color: #C9A96E;">Hours</h3>
      <div class="space-y-3">
        <% @hours.each do |h| %>
          <div class="flex justify-between">
            <span class="text-sm" style="color: rgba(250,243,232,0.8);"><%= h.day_name %></span>
            <span class="text-sm font-medium" style="color: #FAF3E8;">
              <% if h.closed? %>
                Closed
              <% else %>
                <%= h.open_time&.strftime("%l:%M %p") %> - <%= h.close_time&.strftime("%l:%M %p") %>
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
    </div>

    <%# Contact %>
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-5" style="color: #C9A96E;">Contact</h3>
      <% if @restaurant.address.present? %>
        <p class="text-sm mb-1" style="color: rgba(250,243,232,0.8);"><%= @restaurant.address %></p>
      <% end %>
      <% if @restaurant.phone.present? %>
        <a href="tel:<%= @restaurant.phone&.gsub(/[^0-9]/, '') %>" class="text-lg font-semibold block mt-3" style="color: #C9A96E;"><%= @restaurant.phone %></a>
      <% end %>
      <% if @restaurant.email.present? %>
        <p class="text-sm mt-1" style="color: rgba(250,243,232,0.6);"><%= @restaurant.email %></p>
      <% end %>
    </div>

    <%# Map %>
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-5" style="color: #C9A96E;">Find Us</h3>
      <% if @restaurant.address.present? %>
        <div class="aspect-square rounded-lg overflow-hidden">
          <iframe src="https://maps.google.com/maps?q=<%= CGI.escape(@restaurant.address) %>&t=&z=16&ie=UTF8&iwloc=&output=embed" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      <% end %>
    </div>
  </div>
</section>
