<turbo-frame id="workbench-hero">
  <div class="flex flex-col w-full bg-zinc-950 antialiased">

    <%# ─── ROCKY HEADER ─── %>
    <div class="flex justify-between items-center w-full py-6 px-16 border-b border-zinc-800">
      <div class="flex items-center gap-4">
        <div class="w-3 h-3 rounded-md bg-yellow-400 shadow-[0_0_12px_rgba(251,191,36,0.5)]"></div>
        <span class="tracking-[0.05em] uppercase text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-2xl">Rocky // 40-Eridani-A</span>
      </div>
      <div class="flex items-center gap-8">
        <span class="text-zinc-500 font-mono text-xs">TRANSLATION_LAYER: ACTIVE</span>
        <span class="text-zinc-500 font-mono text-xs">ACOUSTIC_SYNCH: 100%</span>
        <%= link_to root_path, class: "flex items-center gap-2 text-zinc-500 font-mono text-xs hover:text-zinc-300 transition-colors", data: { turbo_frame: "workbench-hero" } do %>
          <span>[ CLOSE ]</span>
        <% end %>
      </div>
    </div>

    <%# ─── DUAL INTERFACE ─── %>
    <div class="flex w-full max-w-[1200px] h-[740px] self-center rounded-3xl overflow-hidden bg-[#050505] border border-zinc-800 shadow-[0_20px_80px_rgba(0,0,0,0.8)] my-10 mx-auto">

      <%# ─── LEFT: ACOUSTIC CORE ─── %>
      <div class="w-[420px] h-full relative flex flex-col items-center justify-center shrink-0 overflow-hidden bg-zinc-950 border-r border-zinc-800">
        <%# Radial gradient background %>
        <div class="absolute w-[600px] h-[600px] rounded-full" style="background-image: radial-gradient(circle farthest-corner at 50% 50% in oklab, oklab(83.7% 0.016 0.164 / 15%) 0%, oklab(0% 0 .0001 / 0%) 70%)"></div>
        <%# Concentric circles %>
        <div class="absolute w-[400px] h-[400px] rounded-full border border-yellow-400/10"></div>
        <div class="absolute w-[250px] h-[250px] rounded-full border border-yellow-400/20"></div>
        <%# Center diamond %>
        <div class="w-25 h-25 flex items-center justify-center rounded-[20px] relative bg-zinc-950 border-4 border-yellow-400 shadow-[inset_0_0_30px_rgba(251,191,36,0.3),0_0_50px_rgba(251,191,36,0.5)] shrink-0" style="transform: rotate(45deg)">
          <div class="w-10 h-10 border-2 border-dashed border-yellow-400/40"></div>
        </div>
        <%# Tones waveform bars (hums & clicks — the underlying Rocky tones) %>
        <div class="absolute flex items-center justify-center px-10 gap-1.5 w-full h-full">
          <div class="w-1.5 h-[25px] rounded-[3px] bg-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.8)] shrink-0"></div>
          <div class="w-1.5 h-[55px] rounded-[3px] bg-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.8)] shrink-0"></div>
          <div class="w-1.5 h-[90px] rounded-[3px] bg-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.8)] shrink-0"></div>
          <div class="w-1.5 h-[140px] rounded-[3px] bg-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.8)] shrink-0"></div>
          <div class="w-1.5 h-[70px] rounded-[3px] bg-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.8)] shrink-0"></div>
          <div class="w-1.5 h-[160px] rounded-[3px] bg-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.8)] shrink-0"></div>
          <div class="w-1.5 h-[40px] rounded-[3px] bg-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.8)] shrink-0"></div>
          <div class="w-1.5 h-[110px] rounded-[3px] bg-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.8)] shrink-0"></div>
          <div class="w-1.5 h-[60px] rounded-[3px] bg-teal-400 shadow-[0_0_15px_rgba(45,212,191,0.8)] shrink-0"></div>
        </div>
        <%# Bottom label %>
        <div class="absolute bottom-8 flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-[3px] bg-teal-400 shadow-[0_0_8px_rgba(45,212,191,0.8)]"></div>
          <span class="tracking-[0.2em] text-zinc-500 font-mono text-[11px]">ACOUSTIC_CORE_V3</span>
        </div>
      </div>

      <%# ─── RIGHT: CHAT AREA ─── %>
      <div class="flex-1 h-full flex flex-col relative bg-[#050505]">
        <%# Background glow %>
        <div class="absolute top-1/2 -left-50 w-[1000px] h-[1000px]" style="background-image: radial-gradient(circle farthest-corner at 50% 50% in oklab, oklab(83.7% 0.016 0.164 / 5%) 0%, oklab(0% 0 .0001 / 0%) 60%); transform: translateY(-50%)"></div>

        <%# ─── Chat Messages (scrollable) ─── %>
        <div class="flex-1 flex flex-col relative py-10 px-12 overflow-y-auto gap-8" id="rocky-chat-messages">

          <%# User message %>
          <div class="flex justify-end">
            <div class="max-w-[440px] rounded-t-2xl rounded-br-sm rounded-bl-2xl py-5 px-6 bg-zinc-900 border border-zinc-800 shadow-[0_4px_20px_rgba(0,0,0,0.5)]">
              <p class="text-[16px] leading-[1.5] text-zinc-50 font-['Inter',system-ui,sans-serif]">Explain your sensory output, Rocky.</p>
            </div>
          </div>

          <%# Rocky response %>
          <div class="flex flex-col gap-3">
            <span class="opacity-80 tracking-[0.05em] text-yellow-400 font-mono text-[13px]">*low bass resonance, series of high melodic whistles*</span>
            <div class="max-w-[580px] rounded-tl-sm rounded-bl-2xl rounded-r-2xl bg-teal-400/5 border-l-4 border-teal-400 shadow-[0_10px_30px_rgba(45,212,191,0.05)] p-7">
              <p class="text-[22px] leading-[1.5] tracking-[0.02em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-medium m-0">"Observation. You see my biology before you hear my translation. The background pulse is my atmosphere—my internal pressure—expressed as heat and tone. The teal line you see is the bridge I build for you. Both are required for understanding. Friend."</p>
            </div>
          </div>

          <%# Additional conversation placeholder %>
          <div class="flex justify-end">
            <div class="max-w-[440px] rounded-t-2xl rounded-br-sm rounded-bl-2xl py-5 px-6 bg-zinc-900 border border-zinc-800 shadow-[0_4px_20px_rgba(0,0,0,0.5)]">
              <p class="text-[16px] leading-[1.5] text-zinc-50 font-['Inter',system-ui,sans-serif]">What do you hear right now?</p>
            </div>
          </div>

          <div class="flex flex-col gap-3">
            <span class="opacity-80 tracking-[0.05em] text-yellow-400 font-mono text-[13px]">*rapid tonal clicks, warm ascending hum*</span>
            <div class="max-w-[580px] rounded-tl-sm rounded-bl-2xl rounded-r-2xl bg-teal-400/5 border-l-4 border-teal-400 shadow-[0_10px_30px_rgba(45,212,191,0.05)] p-7">
              <p class="text-[22px] leading-[1.5] tracking-[0.02em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-medium m-0">"Curiosity. Your server fans spin at 3,200 RPM. The hard drive seeks in patterns—irregular, but rhythmic. Your keyboard switches are Cherry MX Blue. I can hear the tactile bump from here. Fascinating. Friend."</p>
            </div>
          </div>

        </div>

        <%# ─── TRANSMIT BAR ─── %>
        <div class="flex items-center py-6 px-12 gap-4 relative bg-zinc-950 border-t border-zinc-800">
          <span class="text-zinc-600 font-mono text-[13px]">TRANSMIT //</span>
          <input type="text" placeholder="Speak to Rocky..." class="flex-1 bg-transparent border-none outline-none text-zinc-50 font-['Inter',system-ui,sans-serif] text-[16px] placeholder:text-zinc-700">
          <button class="rounded-lg py-3 px-7 bg-teal-400 shadow-[0_4px_15px_rgba(45,212,191,0.3)] hover:bg-teal-300 transition-colors cursor-pointer">
            <span class="tracking-[0.05em] uppercase text-zinc-950 font-['Inter',system-ui,sans-serif] font-extrabold text-sm">Send</span>
          </button>
        </div>
      </div>

    </div>

  </div>
</turbo-frame>
