<turbo-frame id="workbench-hero">
  <div class="flex flex-col w-full bg-zinc-950 antialiased"
       data-controller="rocky-chat"
       data-rocky-chat-messages-url-value="<%= rocky_messages_path %>"
       data-rocky-chat-tts-url-value="<%= rocky_tts_path %>"
       data-rocky-chat-tone-url-value="<%= rocky_tone_path %>"
       data-rocky-chat-prompt-count-value="<%= @prompt_count %>"
       data-rocky-chat-anon-limit-value="<%= @anon_limit %>"
       data-rocky-chat-logged-in-value="<%= @logged_in %>">

    <%# ─── ROCKY HEADER ─── %>
    <div class="flex flex-col md:flex-row justify-between items-center w-full py-4 md:py-6 px-4 md:px-16 border-b border-zinc-800 gap-3 md:gap-0">
      <div class="flex items-center gap-4">
        <div class="w-3 h-3 rounded-md bg-yellow-400 shadow-[0_0_12px_rgba(251,191,36,0.5)]" data-rocky-chat-target="statusDot"></div>
        <span class="tracking-[0.05em] uppercase text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-xl md:text-2xl">Rocky // 40-Eridani-A</span>
      </div>
      <div class="flex items-center gap-3 md:gap-8 flex-wrap justify-center">
        <span class="hidden md:inline text-zinc-500 font-mono text-xs">TRANSLATION_LAYER: ACTIVE</span>
        <span class="hidden md:inline text-zinc-500 font-mono text-xs">ACOUSTIC_SYNCH: 100%</span>
        <% unless @logged_in %>
          <span class="text-zinc-600 font-mono text-xs" data-rocky-chat-target="counter"><%= @anon_limit - @prompt_count %> prompts remaining</span>
        <% end %>
        <%= link_to root_path, class: "flex items-center gap-2 text-zinc-500 font-mono text-xs hover:text-zinc-300 transition-colors", data: { turbo_frame: "workbench-hero" } do %>
          <span>[ CLOSE ]</span>
        <% end %>
      </div>
    </div>

    <%# ─── DUAL INTERFACE ─── %>
    <div class="flex flex-col md:flex-row w-full max-w-[1200px] md:h-[740px] self-center rounded-2xl md:rounded-3xl overflow-hidden bg-[#050505] border border-zinc-800 shadow-[0_20px_80px_rgba(0,0,0,0.8)] my-6 md:my-10 mx-auto">

      <%# ─── LEFT: ACOUSTIC CORE ─── %>
      <div class="w-full md:w-[420px] h-[280px] md:h-full relative flex flex-col items-center justify-center shrink-0 overflow-hidden bg-zinc-950 border-b md:border-b-0 md:border-r border-zinc-800">

        <%# ─── LAYER 1: TONES (circles + diamond) ─── %>
        <%# This layer reacts to tone MP3 audio — Rocky's raw biology %>
        <div class="absolute inset-0 flex items-center justify-center">
          <%# Radial gradient glow (reacts to tone amplitude) %>
          <div class="absolute w-[300px] h-[300px] md:w-[600px] md:h-[600px] rounded-full transition-all duration-100" data-rocky-chat-target="toneGlow" style="background-image: radial-gradient(circle farthest-corner at 50% 50% in oklab, oklab(83.7% 0.016 0.164 / 10%) 0%, oklab(0% 0 .0001 / 0%) 70%)"></div>
          <%# Outer circle %>
          <div class="absolute w-[200px] h-[200px] md:w-[400px] md:h-[400px] rounded-full border-2 transition-all duration-75" data-rocky-chat-target="toneCircleOuter" style="border-color: rgba(251,191,36,0.08)"></div>
          <%# Inner circle %>
          <div class="absolute w-[130px] h-[130px] md:w-[250px] md:h-[250px] rounded-full border-2 transition-all duration-75" data-rocky-chat-target="toneCircleInner" style="border-color: rgba(251,191,36,0.15)"></div>
          <%# Center diamond (glows with tone energy) %>
          <div class="w-14 h-14 md:w-25 md:h-25 flex items-center justify-center rounded-[12px] md:rounded-[20px] relative bg-zinc-950 border-2 md:border-4 border-yellow-400 shrink-0 transition-all duration-75" data-rocky-chat-target="toneDiamond" style="transform: rotate(45deg); box-shadow: inset 0 0 30px rgba(251,191,36,0.3), 0 0 50px rgba(251,191,36,0.5)">
            <div class="w-5 h-5 md:w-10 md:h-10 border-2 border-dashed border-yellow-400/40"></div>
          </div>
        </div>

        <%# ─── LAYER 2: SPEECH (translation waveform bars) ─── %>
        <%# This layer reacts to TTS audio — Rocky's translated voice %>
        <%# Constrained to circle layer height (400px), centered %>
        <div class="absolute flex items-end justify-center px-4 md:px-10 gap-1 md:gap-1.5 w-full h-[200px] md:h-[400px] top-1/2 -translate-y-1/2" data-rocky-chat-target="speechbars">
          <div class="speechbar w-1.5 rounded-[3px] bg-teal-400 shrink-0 transition-[height] duration-75" style="height: 15%; opacity: 0.3; box-shadow: 0 0 8px rgba(45,212,191,0.3)" data-idle-height="15%"></div>
          <div class="speechbar w-1.5 rounded-[3px] bg-teal-400 shrink-0 transition-[height] duration-75" style="height: 34%; opacity: 0.3; box-shadow: 0 0 8px rgba(45,212,191,0.3)" data-idle-height="34%"></div>
          <div class="speechbar w-1.5 rounded-[3px] bg-teal-400 shrink-0 transition-[height] duration-75" style="height: 56%; opacity: 0.3; box-shadow: 0 0 8px rgba(45,212,191,0.3)" data-idle-height="56%"></div>
          <div class="speechbar w-1.5 rounded-[3px] bg-teal-400 shrink-0 transition-[height] duration-75" style="height: 87%; opacity: 0.3; box-shadow: 0 0 8px rgba(45,212,191,0.3)" data-idle-height="87%"></div>
          <div class="speechbar w-1.5 rounded-[3px] bg-teal-400 shrink-0 transition-[height] duration-75" style="height: 43%; opacity: 0.3; box-shadow: 0 0 8px rgba(45,212,191,0.3)" data-idle-height="43%"></div>
          <div class="speechbar w-1.5 rounded-[3px] bg-teal-400 shrink-0 transition-[height] duration-75" style="height: 100%; opacity: 0.3; box-shadow: 0 0 8px rgba(45,212,191,0.3)" data-idle-height="100%"></div>
          <div class="speechbar w-1.5 rounded-[3px] bg-teal-400 shrink-0 transition-[height] duration-75" style="height: 25%; opacity: 0.3; box-shadow: 0 0 8px rgba(45,212,191,0.3)" data-idle-height="25%"></div>
          <div class="speechbar w-1.5 rounded-[3px] bg-teal-400 shrink-0 transition-[height] duration-75" style="height: 68%; opacity: 0.3; box-shadow: 0 0 8px rgba(45,212,191,0.3)" data-idle-height="68%"></div>
          <div class="speechbar w-1.5 rounded-[3px] bg-teal-400 shrink-0 transition-[height] duration-75" style="height: 37%; opacity: 0.3; box-shadow: 0 0 8px rgba(45,212,191,0.3)" data-idle-height="37%"></div>
        </div>

        <%# Bottom label %>
        <div class="absolute bottom-4 md:bottom-8 flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-[3px] bg-teal-400 shadow-[0_0_8px_rgba(45,212,191,0.8)]"></div>
          <span class="tracking-[0.2em] text-zinc-500 font-mono text-[11px]">ACOUSTIC_CORE_V3</span>
        </div>
      </div>

      <%# ─── RIGHT: CHAT AREA ─── %>
      <div class="flex-1 min-h-[400px] md:min-h-0 md:h-full flex flex-col relative bg-[#050505]">
        <%# Background glow %>
        <div class="absolute top-1/2 -left-50 w-[1000px] h-[1000px]" style="background-image: radial-gradient(circle farthest-corner at 50% 50% in oklab, oklab(83.7% 0.016 0.164 / 5%) 0%, oklab(0% 0 .0001 / 0%) 60%); transform: translateY(-50%)"></div>

        <%# ─── Chat Messages (scrollable, order 1 on desktop, 2 on mobile) ─── %>
        <div class="order-2 md:order-none flex-1 flex flex-col relative py-6 px-4 md:py-10 md:px-12 overflow-y-auto gap-6 md:gap-8" data-rocky-chat-target="messages" id="rocky-chat-messages">

          <%# Welcome message from Rocky %>
          <div class="flex flex-col gap-3">
            <span class="opacity-80 tracking-[0.05em] text-yellow-400 font-mono text-[13px]">*warm, welcoming hum*</span>
            <div class="max-w-[580px] rounded-tl-sm rounded-bl-2xl rounded-r-2xl bg-teal-400/5 border-l-4 border-teal-400 shadow-[0_10px_30px_rgba(45,212,191,0.05)] p-4 md:p-7">
              <p class="text-[16px] md:text-[22px] leading-[1.5] tracking-[0.02em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-medium m-0">"Greetings, friend. Rocky here. Am ready to help. Ask about space science, Eridian biology, or anything. Is what friend do."</p>
            </div>
          </div>

          <%# Persisted messages (logged in) %>
          <% @messages.each do |msg| %>
            <% if msg.role == "user" %>
              <div class="flex justify-end">
                <div class="max-w-[440px] rounded-t-2xl rounded-br-sm rounded-bl-2xl py-4 px-4 md:py-5 md:px-6 bg-zinc-900 border border-zinc-800 shadow-[0_4px_20px_rgba(0,0,0,0.5)]">
                  <p class="text-[16px] leading-[1.5] text-zinc-50 font-['Inter',system-ui,sans-serif]"><%= msg.content %></p>
                </div>
              </div>
            <% else %>
              <div class="flex flex-col gap-3">
                <div class="max-w-[580px] rounded-tl-sm rounded-bl-2xl rounded-r-2xl bg-teal-400/5 border-l-4 border-teal-400 shadow-[0_10px_30px_rgba(45,212,191,0.05)] p-4 md:p-7">
                  <p class="text-[16px] md:text-[22px] leading-[1.5] tracking-[0.02em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-medium m-0"><%= raw msg.content.gsub(/\*🎵\s*(.*?)\s*🎵\*/) { "<span class='text-yellow-400 font-mono text-[13px] opacity-80 tracking-[0.05em]'>*#{$1}*</span>" }.gsub("\n", "<br>") %></p>
                </div>
              </div>
            <% end %>
          <% end %>

        </div>

        <%# ─── TRANSMIT BAR (order 2 on desktop, 1 on mobile) ─── %>
        <div class="order-1 md:order-none flex items-center py-4 px-4 md:py-6 md:px-12 gap-3 md:gap-4 relative bg-zinc-950 border-t md:border-t border-b md:border-b-0 border-zinc-800">
          <span class="hidden md:inline text-zinc-600 font-mono text-[13px]">TRANSMIT //</span>
          <input type="text"
                 placeholder="Speak to Rocky..."
                 class="flex-1 bg-transparent border-none outline-none text-zinc-50 font-['Inter',system-ui,sans-serif] text-[16px] placeholder:text-zinc-700"
                 data-rocky-chat-target="input"
                 data-action="keydown->rocky-chat#handleKeydown">
          <button class="rounded-lg py-3 px-7 bg-teal-400 shadow-[0_4px_15px_rgba(45,212,191,0.3)] hover:bg-teal-300 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
                  data-rocky-chat-target="sendButton"
                  data-action="click->rocky-chat#submit">
            <span class="tracking-[0.05em] uppercase text-zinc-950 font-['Inter',system-ui,sans-serif] font-extrabold text-sm">Send</span>
          </button>
        </div>
      </div>

    </div>

    <%# ─── WAVEFORM STYLES ─── %>
    <style>
      .speechbar {
        transform-origin: bottom;
        min-height: 6px;
      }
    </style>

  </div>
</turbo-frame>
