<%# Workbench Navigation %>
<%# Usage: render 'shared/workbench_nav', active_page: 'workbench' %>
<% active = local_assigns[:active_page] || 'workbench' %>

<%# ─── SYSTEM STATUS BAR ─── %>
<div class="hidden md:flex justify-between items-center w-full py-3 px-6 bg-[#050505] border-b border-zinc-800">
  <div class="flex items-center gap-4">
    <span class="text-green-400 font-mono text-[13px]">[ SYS.<%= active.upcase %>_ONLINE ]</span>
    <span class="text-zinc-400 font-mono text-[13px]">// ROGUE MEDIA LAB // WORKBENCH V2.0</span>
  </div>
  <div class="flex gap-6">
    <div class="flex items-center gap-2">
      <div class="w-2 h-2 rounded-sm bg-green-400"></div>
      <span class="text-zinc-400 font-mono text-[13px]">RAILS SYSTEM: NOMINAL</span>
    </div>
    <div class="flex items-center gap-2">
      <div class="w-2 h-2 rounded-sm bg-yellow-500"></div>
      <span class="text-zinc-400 font-mono text-[13px]">AI EXPERIMENTS: ACTIVE</span>
    </div>
  </div>
</div>

<%# ─── MAIN NAVIGATION ─── %>
<div class="flex flex-col md:flex-row justify-between items-center w-full py-4 md:py-8 px-6 md:px-16 bg-zinc-950 border-b border-zinc-800 gap-4 md:gap-0">
  <%# Logo %>
  <div class="flex items-center gap-3">
    <div class="w-8 h-8 rounded-sm bg-orange-600"></div>
    <span class="tracking-[0.05em] uppercase text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-xl md:text-[28px]">Rogue Media Lab</span>
  </div>
  <%# Nav Links (hidden on mobile) %>
  <div class="hidden md:flex gap-12">
    <%# Workbench %>
    <% if active == 'workbench' %>
      <div class="flex items-center pb-1 border-b-2 border-orange-600">
        <span class="tracking-[0.02em] text-zinc-50 font-['Inter',system-ui,sans-serif] font-medium text-[15px]">Workbench</span>
      </div>
    <% else %>
      <div class="flex items-center">
        <a href="<%= root_path %>" class="tracking-[0.02em] text-zinc-400 font-['Inter',system-ui,sans-serif] font-medium text-[15px] hover:text-zinc-200 transition-colors">Workbench</a>
      </div>
    <% end %>

    <%# The Studio %>
    <% if active == 'studio' %>
      <div class="flex items-center pb-1 border-b-2 border-blue-500">
        <span class="tracking-[0.02em] text-zinc-50 font-['Inter',system-ui,sans-serif] font-medium text-[15px]">The Studio</span>
        <span class="ml-1.5 text-[11px] text-blue-400 font-['Inter',system-ui,sans-serif] font-medium py-0.5 px-1.5 bg-blue-500/10 border border-blue-500/30 rounded-sm">APPS</span>
      </div>
    <% else %>
      <div class="flex items-center gap-1.5">
        <a href="<%= studio_path %>" class="tracking-[0.02em] text-zinc-400 font-['Inter',system-ui,sans-serif] font-medium text-[15px] hover:text-zinc-200 transition-colors">The Studio</a>
        <span class="text-[11px] text-zinc-500 font-['Inter',system-ui,sans-serif] font-medium py-0.5 px-1.5 border border-zinc-800 rounded-sm">APPS</span>
      </div>
    <% end %>

    <%# The Lab %>
    <% if active == 'lab' %>
      <div class="flex items-center pb-1 border-b-2 border-orange-600">
        <span class="tracking-[0.02em] text-zinc-50 font-['Inter',system-ui,sans-serif] font-medium text-[15px]">The Lab</span>
        <span class="ml-1.5 text-[11px] text-orange-400 font-['Inter',system-ui,sans-serif] font-medium py-0.5 px-1.5 bg-orange-500/10 border border-orange-500/30 rounded-sm">TOOLS</span>
      </div>
    <% else %>
      <div class="flex items-center gap-1.5">
        <span class="tracking-[0.02em] text-zinc-400 font-['Inter',system-ui,sans-serif] font-medium text-[15px]">The Lab</span>
        <span class="text-[11px] text-zinc-500 font-['Inter',system-ui,sans-serif] font-medium py-0.5 px-1.5 border border-zinc-800 rounded-sm">TOOLS</span>
      </div>
    <% end %>

    <%# Erudition %>
    <% if active == 'erudition' %>
      <div class="flex items-center pb-1 border-b-2 border-purple-500">
        <span class="tracking-[0.02em] text-zinc-50 font-['Inter',system-ui,sans-serif] font-medium text-[15px]">Erudition</span>
        <span class="ml-1.5 text-[11px] text-purple-400 font-['Inter',system-ui,sans-serif] font-medium py-0.5 px-1.5 bg-purple-500/10 border border-purple-500/30 rounded-sm">ACADEMY</span>
      </div>
    <% else %>
      <div class="flex items-center gap-1.5">
        <span class="tracking-[0.02em] text-zinc-400 font-['Inter',system-ui,sans-serif] font-medium text-[15px]">Erudition</span>
        <span class="text-[11px] text-zinc-500 font-['Inter',system-ui,sans-serif] font-medium py-0.5 px-1.5 border border-zinc-800 rounded-sm">ACADEMY</span>
      </div>
    <% end %>
  </div>
  <%# CTA Buttons %>
  <div class="flex gap-4">
    <div class="flex items-center justify-center rounded-md py-2 px-4 md:py-2.5 md:px-5 bg-zinc-900 border border-zinc-800 cursor-pointer hover:bg-zinc-800 transition-colors">
      <span class="text-zinc-200 font-['Inter',system-ui,sans-serif] font-semibold text-xs md:text-sm">Patreon</span>
    </div>
    <div class="flex items-center justify-center rounded-md py-2 px-4 md:py-2.5 md:px-5 bg-zinc-50 cursor-pointer hover:bg-zinc-200 transition-colors">
      <span class="text-zinc-950 font-['Inter',system-ui,sans-serif] font-semibold text-xs md:text-sm">Substack</span>
    </div>
  </div>
</div>
