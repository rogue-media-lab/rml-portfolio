<%# The Studio — Product Showcase %>
<% content_for(:title) { "The Studio — Rogue Media Lab" } %>
<% content_for(:body_class) { "bg-[#050505] text-zinc-50" } %>
<% content_for(:main_class) { "flex flex-col min-h-screen w-full" } %>

<div class="w-full min-h-screen bg-[#050505] antialiased">

  <%= render 'shared/workbench_nav', active_page: 'studio' %>

  <%# ─── STUDIO HERO ─── %>
  <div class="flex flex-col items-center justify-center w-full pt-16 md:pt-25 pb-16 md:pb-20 gap-6 md:gap-8 px-6 md:px-16">
    <div class="flex flex-col items-center max-w-200 gap-4 md:gap-6">
      <%# Badge %>
      <div class="flex items-center rounded-full py-1.5 px-3 gap-2 bg-blue-500/5 border border-blue-500/30">
        <div class="w-1.5 h-1.5 rounded-[3px] bg-blue-500"></div>
        <span class="text-center text-blue-500 font-mono text-xs">Hand-Crafted Apps &amp; Prototypes</span>
      </div>
      <%# Headline %>
      <h1 class="text-4xl md:text-[72px] leading-[1.1] tracking-[0.02em] uppercase text-center text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold m-0">Refined Tools for<br>Modern Consumers.</h1>
      <%# Subtitle %>
      <p class="text-base md:text-[20px] leading-[1.6] max-w-162 text-center text-zinc-400 font-['Inter',system-ui,sans-serif] m-0">Polished, production-ready applications born from the Lab. From working demo's built into this portfolio to custom, handcrafted, working solutions.</p>
    </div>
  </div>

  <%# ─── STUDIO SHOWCASE ─── %>
  <div class="flex flex-col w-full pt-10 pb-20 md:pb-30 gap-28 md:gap-40 px-6 md:px-16">

    <%# ─── ZUKE MUSIC (left showcase) ─── %>
    <div class="flex flex-col lg:flex-row items-center w-full gap-8 lg:gap-16">
      <%# Preview card with hero image %>
      <div class="w-full lg:flex-[1.2] lg:shrink-0 lg:basis-0 h-72 lg:h-125 relative flex flex-col rounded-2xl lg:rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800">
        <div class="flex justify-between items-center border-b border-zinc-800 p-4 lg:p-6">
          <span class="tracking-[0.05em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-lg lg:text-xl">ZUKE // PLAYER</span>
          <div class="flex gap-2 lg:gap-3">
            <div class="w-3 h-3 rounded-md bg-red-500"></div>
            <div class="w-3 h-3 rounded-md bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-md bg-green-500"></div>
          </div>
        </div>
        <div class="flex-1 flex items-center justify-center overflow-hidden">
          <%= image_tag "zuke-hero.jpg", alt: "Zuke Media Player — Music with Attitude", class: "w-full h-full object-cover" %>
        </div>
      </div>
      <%# Product info %>
      <div class="w-full lg:flex-1 flex flex-col gap-6 lg:gap-8">
        <div class="flex flex-col gap-3">
          <span class="text-blue-500 font-mono text-[13px]">01 // SOCIAL MEDIA PLAYER</span>
          <h2 class="uppercase text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-3xl lg:text-5xl m-0">Zuke Music</h2>
          <p class="text-base lg:text-[18px] leading-[1.6] text-zinc-400 font-['Inter',system-ui,sans-serif] m-0">A visual music player that builds soundscapes with live imagery and mood-centric social features. Powered by server-side waveform generation and HLS streaming.</p>
        </div>
        <div class="flex gap-4">
          <a href="<%= zuke_index_path %>" class="rounded-lg py-3 px-6 bg-blue-500 cursor-pointer hover:bg-blue-400 transition-colors">
            <span class="uppercase text-zinc-950 font-['Inter',system-ui,sans-serif] font-bold text-sm">Launch Demo</span>
          </a>
        </div>
      </div>
    </div>

    <%# ─── HERMIT PLUS (right showcase) ─── %>
    <div class="flex flex-col lg:flex-row-reverse items-center w-full gap-8 lg:gap-16">
      <%# Preview card with hero image %>
      <div class="w-full lg:flex-[1.2] lg:shrink-0 lg:basis-0 h-72 lg:h-125 relative flex flex-col rounded-2xl lg:rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800">
        <div class="flex justify-between items-center border-b border-zinc-800 p-4 lg:p-6">
          <span class="tracking-[0.05em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-lg lg:text-xl">HERMIT PLUS // HUB</span>
          <div class="flex gap-2 lg:gap-3">
            <div class="w-3 h-3 rounded-md bg-red-500"></div>
            <div class="w-3 h-3 rounded-md bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-md bg-green-500"></div>
          </div>
        </div>
        <div class="flex-1 flex items-center justify-center overflow-hidden">
          <%= image_tag "hermit_plus/hermit-plus-preview.png", alt: "Hermit Plus — Netflix-style Minecraft content hub", class: "w-full h-full object-cover" %>
        </div>
      </div>
      <%# Product info %>
      <div class="w-full lg:flex-1 flex flex-col gap-6 lg:gap-8">
        <div class="flex flex-col gap-3">
          <span class="text-blue-500 font-mono text-[13px]">02 // MINECRAFT HUB</span>
          <h2 class="uppercase text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-3xl lg:text-5xl m-0">Hermit Plus</h2>
          <p class="text-base lg:text-[18px] leading-[1.6] text-zinc-400 font-['Inter',system-ui,sans-serif] m-0">A Netflix-style browsing experience for Hermitcraft fans. Track your favorite hermits, discover new creators, and watch every episode from every perspective — all in one place.</p>
        </div>
        <div class="flex gap-4">
          <a href="<%= hermits_path %>" class="rounded-lg py-3 px-6 bg-blue-500 cursor-pointer hover:bg-blue-400 transition-colors">
            <span class="uppercase text-zinc-950 font-['Inter',system-ui,sans-serif] font-bold text-sm">Launch Demo</span>
          </a>
        </div>
      </div>
    </div>

    <%# ─── CLOUGH CAMPAIGN (left showcase) ─── %>
    <div class="flex flex-col lg:flex-row items-center w-full gap-8 lg:gap-16">
      <%# Preview card with SEO card image %>
      <div class="w-full lg:flex-[1.2] lg:shrink-0 lg:basis-0 h-72 lg:h-125 relative flex flex-col rounded-2xl lg:rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800">
        <div class="flex justify-between items-center border-b border-zinc-800 p-4 lg:p-6">
          <span class="tracking-[0.05em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-lg lg:text-xl">CLOUGH // CAMPAIGN</span>
          <div class="flex gap-2 lg:gap-3">
            <div class="w-3 h-3 rounded-md bg-red-500"></div>
            <div class="w-3 h-3 rounded-md bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-md bg-green-500"></div>
          </div>
        </div>
        <div class="flex-1 flex items-center justify-center overflow-hidden">
          <%= image_tag "clough-og.jpg", alt: "Clough for Congress — Enough is Enough", class: "w-full h-full object-cover" %>
        </div>
      </div>
      <%# Product info %>
      <div class="w-full lg:flex-1 flex flex-col gap-6 lg:gap-8">
        <div class="flex flex-col gap-3">
          <span class="text-blue-500 font-mono text-[13px]">03 // POLITICAL CAMPAIGN</span>
          <h2 class="uppercase text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-3xl lg:text-5xl m-0">Clough for Congress</h2>
          <p class="text-base lg:text-[18px] leading-[1.6] text-zinc-400 font-['Inter',system-ui,sans-serif] m-0">A full-stack campaign site built with Rails 8. Featuring SEO/AEO optimization, dynamic content management, and a bold visual identity. Enough is Enough.</p>
        </div>
        <div class="flex gap-4">
          <a href="https://cloughforsc5.com//" target="_blank" class="rounded-lg py-3 px-6 bg-blue-500 cursor-pointer hover:bg-blue-400 transition-colors">
            <span class="uppercase text-zinc-950 font-['Inter',system-ui,sans-serif] font-bold text-sm">View Live</span>
          </a>
          <a href="https://github.com/rogue-media-lab/clough-d5" target="_blank" class="rounded-lg py-3 px-6 border border-zinc-800 cursor-pointer hover:bg-zinc-800 transition-colors">
            <span class="text-zinc-50 font-['Inter',system-ui,sans-serif] font-semibold text-sm">GitHub Repo</span>
          </a>
        </div>
      </div>
    </div>

    <%# ─── Brooke N Maisy (right showcase) ─── %>
    <div class="flex flex-col lg:flex-row-reverse items-center w-full gap-8 lg:gap-16">
      <%# Preview card with hero image %>
      <div class="w-full lg:flex-[1.2] lg:shrink-0 lg:basis-0 h-72 lg:h-125 relative flex flex-col rounded-2xl lg:rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800">
        <div class="flex justify-between items-center border-b border-zinc-800 p-4 lg:p-6">
          <span class="tracking-[0.05em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-lg lg:text-xl">Brooke & Maisy // Site</span>
          <div class="flex gap-2 lg:gap-3">
            <div class="w-3 h-3 rounded-md bg-red-500"></div>
            <div class="w-3 h-3 rounded-md bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-md bg-green-500"></div>
          </div>
        </div>
        <div class="flex-1 flex items-center justify-center overflow-hidden">
          <%= image_tag "brooke-maisy.png", alt: "Hermit Plus — Netflix-style Minecraft content hub", class: "w-full h-full object-cover" %>
        </div>
      </div>
      <%# Product info %>
      <div class="w-full lg:flex-1 flex flex-col gap-6 lg:gap-8">
        <div class="flex flex-col gap-3">
          <span class="text-blue-500 font-mono text-[13px]">04 // BROOKE & MAISY</span>
          <h2 class="uppercase text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-3xl lg:text-5xl m-0">Brooke & Maisy</h2>
          <p class="text-base lg:text-[18px] leading-[1.6] text-zinc-400 font-['Inter',system-ui,sans-serif] m-0">Interior Design Studio site and solution. The front face is a website with app functionality, built in Rails, but behind the scene is the custom built software solution custom built for the studio.</p>
        </div>
        <div class="flex gap-4">
          <a href="https://www.brookenmaisy.com/" target="_blank" class="rounded-lg py-3 px-6 bg-blue-500 cursor-pointer hover:bg-blue-400 transition-colors">
            <span class="uppercase text-zinc-950 font-['Inter',system-ui,sans-serif] font-bold text-sm">View Live</span>
          </a>
          <a href="https://github.com/rogue-media-lab/brooke-maisy" target="_blank" class="rounded-lg py-3 px-6 border border-zinc-800 cursor-pointer hover:bg-zinc-800 transition-colors">
            <span class="text-zinc-50 font-['Inter',system-ui,sans-serif] font-semibold text-sm">GitHub Repo</span>
          </a>
        </div>
      </div>
    </div>

    <%# ─── Salt and Tar (left showcase) ─── %>
    <div class="flex flex-col lg:flex-row items-center w-full gap-8 lg:gap-16">
      <%# Preview card with SEO card image %>
      <div class="w-full lg:flex-[1.2] lg:shrink-0 lg:basis-0 h-72 lg:h-125 relative flex flex-col rounded-2xl lg:rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800">
        <div class="flex justify-between items-center border-b border-zinc-800 p-4 lg:p-6">
          <span class="tracking-[0.05em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-lg lg:text-xl">SALT & TAR // REDESIGN</span>
          <div class="flex gap-2 lg:gap-3">
            <div class="w-3 h-3 rounded-md bg-red-500"></div>
            <div class="w-3 h-3 rounded-md bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-md bg-green-500"></div>
          </div>
        </div>
        <div class="flex-1 flex items-center justify-center overflow-hidden">
          <%= image_tag "s&t.png", alt: "Salt and Tar Fan Made", class: "w-full h-full object-cover" %>
        </div>
      </div>
      <%# Product info %>
      <div class="w-full lg:flex-1 flex flex-col gap-6 lg:gap-8">
        <div class="flex flex-col gap-3">
          <span class="text-blue-500 font-mono text-[13px]">05 // FAN MADE SITE</span>
          <h2 class="uppercase text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-3xl lg:text-5xl m-0">Salt and Tar</h2>
          <p class="text-base lg:text-[18px] leading-[1.6] text-zinc-400 font-['Inter',system-ui,sans-serif] m-0">A fan made redesign concept for Salt and Tar. They are a sailing couple building a wooden ship that I have admired for years. This is my attempt to create a concept worthy.</p>
        </div>
        <div class="flex gap-4">
          <a href="<%= salt_and_tar_index_path %>" class="rounded-lg py-3 px-6 bg-blue-500 cursor-pointer hover:bg-blue-400 transition-colors">
            <span class="uppercase text-zinc-950 font-['Inter',system-ui,sans-serif] font-bold text-sm">Launch Demo</span>
          </a>
        </div>
      </div>
    </div>

  <%# ─── CarUs (right showcase) ─── %>
    <div class="flex flex-col lg:flex-row-reverse items-center w-full gap-8 lg:gap-16">
      <%# Preview card %>
      <div class="w-full lg:flex-[1.2] lg:shrink-0 lg:basis-0 h-72 lg:h-125 relative flex flex-col rounded-2xl lg:rounded-3xl overflow-hidden bg-zinc-900 border border-zinc-800">
        <div class="flex justify-between items-center border-b border-zinc-800 p-4 lg:p-6">
          <span class="tracking-[0.05em] text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-lg lg:text-xl">CARUS // PLATFORM</span>
          <div class="flex gap-2 lg:gap-3">
            <div class="w-3 h-3 rounded-md bg-red-500"></div>
            <div class="w-3 h-3 rounded-md bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-md bg-green-500"></div>
          </div>
        </div>
        <div class="flex-1 flex items-center justify-center bg-gradient-to-br from-blue-600 to-blue-800 p-8">
          <span class="text-6xl md:text-8xl font-bold text-white/20 tracking-widest uppercase select-none">CarUs</span>
        </div>
      </div>
      <%# Product info %>
      <div class="w-full lg:flex-1 flex flex-col gap-6 lg:gap-8">
        <div class="flex flex-col gap-3">
          <span class="text-blue-500 font-mono text-[13px]">06 // TWO-SIDED MARKETPLACE</span>
          <h2 class="uppercase text-zinc-50 font-['Barlow_Condensed',system-ui,sans-serif] font-bold text-3xl lg:text-5xl m-0">CarUs</h2>
          <p class="text-base lg:text-[18px] leading-[1.6] text-zinc-400 font-['Inter',system-ui,sans-serif] m-0">A two-sided auto shop + car owner platform. Customers find trusted mechanics, track maintenance, and grab flash deals. Shops fill idle bays with time-limited offers.</p>
        </div>
        <div class="flex gap-4">
          <a href="<%= carus_root_path %>" class="rounded-lg py-3 px-6 bg-blue-500 cursor-pointer hover:bg-blue-400 transition-colors">
            <span class="uppercase text-zinc-950 font-['Inter',system-ui,sans-serif] font-bold text-sm">Launch Demo</span>
          </a>
        </div>
      </div>
    </div>

  </div>

  <%= render 'shared/workbench_footer', section_name: 'The Studio' %>

</div>
