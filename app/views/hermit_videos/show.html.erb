<!-- Video Detail Show — React Detail style -->
<section class="relative w-full min-h-screen">
  <!-- Full-screen background thumbnail -->
  <div class="fixed inset-0 z-0">
    <% if @video.thumbnail_url.present? %>
      <%= image_tag @video.thumbnail_url, alt: @video.title, class: "w-full h-full object-cover" %>
    <% else %>
      <div class="w-full h-full bg-hermit-dk-green"></div>
    <% end %>
  </div>

  <!-- Black fade overlay — React BlackFade style -->
  <div class="fixed inset-0 z-[1] bg-gradient-to-r from-black/80 via-black/50 to-transparent"></div>

  <!-- Content -->
  <div class="relative z-10 min-h-screen flex items-center">
    <div class="max-w-7xl mx-auto px-4 md:px-10 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

        <!-- Left Column — Video Info -->
        <div class="flex flex-col justify-center py-20 lg:py-0">
          <!-- Alias Banner Image -->
          <% if @hermit.banner_url.present? %>
            <div class="h-[15vh] min-h-[120px] max-h-[180px] w-auto max-w-[400px] mb-4">
              <%= image_tag @hermit.banner_url, alt: "#{@hermit.alias} banner", class: "h-full w-auto object-contain" %>
            </div>
          <% end %>

          <h1 class="text-white font-kanit text-3xl md:text-4xl font-bold mb-2"><%= @video.title %></h1>

          <!-- Controls — React Controls style -->
          <div class="flex flex-wrap items-center gap-4 mt-6">
            <%= link_to hermit_watch_path(@video), class: "inline-flex items-center gap-2 bg-white hover:bg-gray-200 text-black font-bold py-3 px-6 rounded text-sm uppercase tracking-wider transition-colors" do %>
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              Play
            <% end %>
            <%= link_to hermit_profile_path(@hermit), class: "inline-flex items-center gap-2 bg-black/50 hover:bg-black/70 border border-white/50 text-white font-bold py-3 px-6 rounded text-sm uppercase tracking-wider transition-colors" do %>
              Info
            <% end %>
            <% if user_signed_in? %>
              <% if current_user.favorite_videos.include?(@video) %>
                <%= button_to hermit_favorites_path(video_id: @video.id), method: :delete, class: "w-10 h-10 rounded-full bg-hermit-yellow text-hermit-dk-green flex items-center justify-center transition-colors hover:scale-110", title: "Remove from Favorites" do %>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                <% end %>
              <% else %>
                <%= button_to hermit_favorites_path(video_id: @video.id), method: :post, class: "w-10 h-10 rounded-full bg-white/20 hover:bg-white/30 text-white flex items-center justify-center transition-colors hover:scale-110", title: "Add to Favorites" do %>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                <% end %>
              <% end %>
            <% else %>
              <%= link_to new_user_session_path, class: "w-10 h-10 rounded-full bg-white/20 hover:bg-white/30 text-white flex items-center justify-center transition-colors", title: "Sign in to favorite" do %>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
              <% end %>
            <% end %>
          </div>

          <!-- Subtitle -->
          <p class="text-white/80 font-mPlusCode text-sm mt-6">
            S<%= @video.season %> E<%= @video.episode %> — <%= @hermit.alias %>
          </p>

          <!-- Description -->
          <% if @video.description.present? %>
            <p class="text-white/70 font-mPlusCode text-sm leading-relaxed mt-4 max-w-xl">
              <%= @video.description %>
            </p>
          <% end %>
        </div>

        <!-- Right Column — Trailer / Cast -->
        <div class="hidden lg:flex flex-col items-center justify-center gap-6">
          <!-- Trailer thumbnail -->
          <div class="rounded-xl overflow-hidden border-4 border-hermit-burnt/30 shadow-2xl max-w-[400px]">
            <% if @video.thumbnail_url.present? %>
              <%= image_tag @video.thumbnail_url, alt: @video.title, class: "w-full aspect-video object-cover" %>
            <% end %>
          </div>

          <!-- Cast row — React RestDiv style -->
          <% if @appearing_hermits.any? %>
            <div class="flex flex-wrap justify-center gap-3">
              <% @appearing_hermits.each do |hermit| %>
                <%= link_to hermit_profile_path(hermit), class: "group/cast" do %>
                  <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-white/30 group-hover/cast:border-white transition-colors bg-hermit-dk-green">
                    <% if hermit.avatar_url.present? %>
                      <%= image_tag hermit.avatar_url, alt: hermit.alias, class: "w-full h-full object-cover" %>
                    <% else %>
                      <div class="w-full h-full flex items-center justify-center">
                        <span class="font-kanit text-hermit-yellow text-[10px]"><%= hermit.alias.first(2) %></span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
            <p class="text-white/50 font-mPlusCode text-xs">Cast</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile cast section -->
  <% if @appearing_hermits.any? %>
    <div class="lg:hidden relative z-10 px-4 pb-10">
      <h3 class="font-kanit text-white text-lg font-bold mb-3">Cast</h3>
      <div class="flex flex-wrap gap-3">
        <% @appearing_hermits.each do |hermit| %>
          <%= link_to hermit_profile_path(hermit), class: "flex items-center gap-2 bg-white/10 rounded-full pr-3 pl-1 py-1 backdrop-blur-sm" do %>
            <div class="w-8 h-8 rounded-full overflow-hidden bg-hermit-dk-green">
              <% if hermit.avatar_url.present? %>
                <%= image_tag hermit.avatar_url, alt: hermit.alias, class: "w-full h-full object-cover" %>
              <% end %>
            </div>
            <span class="font-kanit text-white text-sm font-bold"><%= hermit.alias %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
